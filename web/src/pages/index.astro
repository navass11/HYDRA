  html.dark .filter-btn:hover {
    border-color: #2dd4bf;
    color: #99f6e4;
  }
  html.dark .hero-bottom-fade {
    background-image: linear-gradient(to top, #020617, rgba(2, 6, 23, 0.78), transparent);
