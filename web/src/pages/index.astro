---
import Layout from '../layouts/Layout.astro';
import notebooksMeta from '../data/notebooks.json';
import { pilotCases } from '../data/pilot_cases';

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base.replace(/\/$/, '')}${path}`;

const modules = [
  {
    // Cloud with precipitation drops — satellite & gauge data pipeline
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 14a4 4 0 0 1 3.9-4H8a6 6 0 0 1 11.6 1.5A3.5 3.5 0 0 1 17 18H5.5A3.5 3.5 0 0 1 4 14Z"/><line x1="8" y1="21" x2="8" y2="19"/><line x1="12" y1="22" x2="12" y2="19.5"/><line x1="16" y1="21" x2="16" y2="19"/></svg>',
    title: 'Fuentes de datos',
    description: 'Descarga automática de precipitación (Meteostat, GPM, ERA5, AEMET), caudal (GloFAS, GRDC, USGS), cambio climático (CMIP6/ESGF) y texturas de suelo (SoilGrids).',
    color: 'text-sky-700 bg-sky-100',
    bg: 'bg-white',
    border: 'border-sky-100',
    href: asset('/modules/fuentes-datos'),
  },
  {
    // GEV frequency curve with T=100 return period marker
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 19q4 0 6-5 2-6 3-7 1-1 3 2 2 3 4 7"/><line x1="3" y1="19" x2="21" y2="19"/><line x1="19" y1="8" x2="19" y2="19" stroke-dasharray="3 2"/><circle cx="19" cy="8" r="1.5" fill="currentColor" stroke="none"/><path d="M6 13q1-1 2 0t2 0" stroke-width="1.2"/></svg>',
    title: 'Análisis climático',
    description: 'Series temporales, valores extremos, análisis de frecuencia regional, cópulas, interpolación espacial y modelos jerárquicos bayesianos.',
    color: 'text-indigo-700 bg-indigo-100',
    bg: 'bg-white',
    border: 'border-indigo-100',
    href: asset('/modules/analisis-climatico'),
  },
  {
    // Three overlapping synthetic ensemble traces
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 12C4 9 5 9 7 12S10 15 12 12 15 9 17 12 20 15 22 12"/><path d="M2 7C4 5 5 5 7 7S10 9 12 7 15 5 17 7 20 9 22 7" stroke-width="1.2" stroke-opacity="0.5"/><path d="M2 17C4 15 5 15 7 17S10 19 12 17 15 15 17 17 20 19 22 17" stroke-width="1.2" stroke-opacity="0.5"/></svg>',
    title: 'Generación estocástica',
    description: 'Generación estocástica de series (CoSMoS) y precipitación (NSRP via NEOPRENE), incluyendo modelos multisitio espacio-temporales.',
    color: 'text-emerald-700 bg-emerald-100',
    bg: 'bg-white',
    border: 'border-emerald-100',
    href: asset('/modules/generacion-estocastica'),
  },
  {
    // Flood hydrograph rising + falling limb above baseline
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="2" y1="19" x2="22" y2="19"/><path d="M3 19C6 19 8 17 10 12 12 7 13 5 14 6 15 7 16 11 18 16 19 18 21 19 22 19"/><line x1="3" y1="13" x2="7" y2="13" stroke-dasharray="2 2" stroke-width="1.2"/><line x1="18" y1="13" x2="22" y2="13" stroke-dasharray="2 2" stroke-width="1.2"/></svg>',
    title: 'Modelización',
    description: 'Integración y automatización de modelos hidrológicos (HEC-HMS, SWAT+) e hidráulicos (HEC-RAS, SFINCS).',
    color: 'text-amber-800 bg-amber-100',
    bg: 'bg-white',
    border: 'border-orange-100',
    href: asset('/modules/modelizacion'),
  },
];

const tools = [
  {
    title: 'Generación estocástica',
    description: 'Ajusta un modelo estacional CoSMoS a una serie diaria y genera un ensemble sintético reproducible.',
    href: asset('/tools/stochastic'),
    tag: 'Clima',
    color: 'text-emerald-700 bg-emerald-100',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 10C3 7 6 7 7 10 8 13 11 13 12 10 13 7 16 7 17 10 18 13 21 13 22 10" stroke-width="1.1" stroke-opacity="0.45"/><path d="M2 13C3 10 6 10 7 13 8 16 11 16 12 13 13 10 16 10 17 13 18 16 21 16 22 13"/><path d="M2 16C3 13 6 13 7 16 8 19 11 19 12 16 13 13 16 13 17 16 18 19 21 19 22 16" stroke-width="1.1" stroke-opacity="0.45"/></svg>',
  },
  {
    title: 'Modelado hidráulico',
    description: 'Canal compuesto con llanura de inundación. Ajusta rugosidad Manning, caudal y geometría, y observa cómo cambia la mancha de calados y el régimen hidráulico.',
    href: asset('/tools/hydraulic'),
    tag: 'Hidráulica',
    color: 'text-teal-800 bg-teal-100',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 18 Q4 14 6 16 Q8 18 10 16 Q12 14 14 16 Q16 18 18 16 Q20 14 22 16" stroke-width="1.5"/><path d="M3 21L7 13L11 11L13 11L17 13L21 21" stroke-width="1.4"/><path d="M2 21 L22 21" stroke-width="1.2"/><path d="M7 13 L7 21 M17 13 L17 21" stroke-width="0.9" stroke-dasharray="2 2" stroke-opacity="0.6"/></svg>',
  },
  {
    title: 'Sensibilidad de Manning',
    description: 'Explora ensembles hidráulicos y relaciona rugosidad, calados y área inundada mediante correlaciones y regresión.',
    href: asset('/tools/sensitivity'),
    tag: 'Hidráulica',
    color: 'text-amber-800 bg-amber-100',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 21L7 14L11 12L13 12L17 14L21 21"/><path d="M5 12Q12 10 19 12"/><path d="M5 9Q12 7 19 9" stroke-dasharray="3 2" stroke-width="1.3"/><path d="M9 17L13 17M12 15L14 17L12 19" stroke-width="1.1"/></svg>',
  },
  {
    title: 'Eventos + GEV bayesiana',
    description: 'Selecciona eventos extremos y estima niveles de retorno con una GEV MAP bayesiana y bandas aproximadas.',
    href: asset('/tools/statistical'),
    tag: 'Extremos',
    color: 'text-indigo-800 bg-indigo-100',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 17L4 17L5 15L6 17L8 16L9 17L11 6L13 17L15 15L16 17L18 16L19 17L22 17"/><line x1="2" y1="11" x2="22" y2="11" stroke-dasharray="3 2" stroke-width="1.2"/><circle cx="11" cy="6" r="2.2" stroke-width="1.5"/></svg>',
  },
  {
    title: 'Descarga Meteostat',
    description: 'Busca estaciones en el mapa, selecciona periodo y descarga datos diarios o mensuales de temperatura, precipitación y viento.',
    href: asset('/tools/meteostat'),
    tag: 'Datos',
    color: 'text-sky-800 bg-sky-100',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 14a4 4 0 0 1 3.9-4H8a6 6 0 0 1 11.6 1.5A3.5 3.5 0 0 1 17 18H5.5A3.5 3.5 0 0 1 4 14Z"/><path d="M8 21L8 19M12 22L12 19.5M16 21L16 19" stroke-width="1.5"/></svg>',
  },
  {
    title: 'Cópulas de eventos',
    description: 'Ajusta dependencias multivariantes entre pico, volumen, duración y variables discretas para generar eventos sintéticos.',
    href: asset('/tools/copulas'),
    tag: 'Análisis',
    color: 'text-violet-800 bg-violet-100',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="3" y1="21" x2="3" y2="4" stroke-width="1.2"/><line x1="3" y1="21" x2="22" y2="21" stroke-width="1.2"/><ellipse cx="12.5" cy="13" rx="7" ry="4" transform="rotate(-30 12.5 13)" stroke-width="1.4"/><ellipse cx="12.5" cy="13" rx="3.5" ry="2" transform="rotate(-30 12.5 13)" stroke-width="1"/><circle cx="8" cy="17" r="0.9" fill="currentColor" stroke="none"/><circle cx="11" cy="15" r="0.9" fill="currentColor" stroke="none"/><circle cx="14" cy="11" r="0.9" fill="currentColor" stroke="none"/><circle cx="17" cy="8" r="0.9" fill="currentColor" stroke="none"/><circle cx="6" cy="19" r="0.9" fill="currentColor" stroke="none"/><circle cx="20" cy="6" r="0.9" fill="currentColor" stroke="none"/></svg>',
  },
  {
    title: 'Eventos compuestos',
    description: 'Ajusta una cópula bivariante y obtén curvas de período de retorno conjunto OR para pares de variables hidro-climáticas.',
    href: asset('/tools/compound'),
    tag: 'Análisis',
    color: 'text-purple-800 bg-purple-100',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="3" y1="21" x2="3" y2="4" stroke-width="1.2"/><line x1="3" y1="21" x2="22" y2="21" stroke-width="1.2"/><path d="M5 17 Q8 8 12 8 Q16 8 19 5" stroke-width="1.5" stroke-dasharray="3 2"/><path d="M5 19 Q9 13 13 12 Q17 11 20 8" stroke-width="1.5"/><circle cx="8" cy="16" r="1.8" fill="rgba(139,92,246,0.4)" stroke="rgb(109,40,217)"/><circle cx="12" cy="12" r="1.8" fill="rgba(139,92,246,0.4)" stroke="rgb(109,40,217)"/><circle cx="16" cy="10" r="1.8" fill="rgba(139,92,246,0.4)" stroke="rgb(109,40,217)"/></svg>',
  },
  {
    title: 'Interpolación espacial',
    description: 'Compara IDW, Kriging Ordinario, RBF y vecino más cercano sobre el mismo dataset. Sube 3 CSV y obtén RMSE de validación cruzada.',
    href: asset('/tools/interpolation'),
    tag: 'Espacial',
    color: 'text-teal-800 bg-teal-100',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="5" cy="6" r="1.8"/><circle cx="18" cy="5" r="1.8"/><circle cx="9" cy="14" r="1.8"/><circle cx="19" cy="15" r="1.8"/><line x1="6.5" y1="7.2" x2="7.8" y2="12.3" stroke-width="1.1" stroke-opacity="0.6"/><line x1="17" y1="6.8" x2="18.3" y2="13.2" stroke-width="1.1" stroke-opacity="0.6"/><line x1="11" y1="14" x2="17" y2="15" stroke-width="1.1" stroke-opacity="0.6"/><line x1="6.8" y1="6" x2="16.2" y2="5.2" stroke-width="1.1" stroke-opacity="0.6"/><circle cx="12" cy="10" r="2.5" fill="rgba(13,148,136,0.2)" stroke="rgb(13,148,136)" stroke-width="1.5"/></svg>',
  },
  {
    title: 'Curva IDF',
    description: 'Ajusta una GEV a los máximos anuales por duración y genera la curva Intensidad-Duración-Frecuencia.',
    href: asset('/tools/idf'),
    tag: 'Extremos',
    color: 'text-blue-800 bg-blue-100',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="14" width="3" height="5" rx="0.5"/><rect x="8" y="10" width="3" height="9" rx="0.5"/><rect x="13" y="6" width="3" height="13" rx="0.5"/><rect x="18" y="3" width="3" height="16" rx="0.5"/><line x1="2" y1="20" x2="22" y2="20" stroke-width="1.2"/></svg>',
  },
  {
    title: 'Corrección de sesgo',
    description: 'Aplica quantile mapping entre series observada y modelo. Genera QQ-plot y estadísticas antes/después.',
    href: asset('/tools/bias'),
    tag: 'Clima',
    color: 'text-cyan-800 bg-cyan-100',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="3" y1="21" x2="3" y2="4" stroke-width="1.2"/><line x1="3" y1="21" x2="22" y2="21" stroke-width="1.2"/><path d="M5 19 Q9 14 13 10 Q17 6 19 4" stroke-width="1.4" stroke-dasharray="3 2" stroke-opacity="0.6"/><path d="M5 19 Q9 16 13 14 Q17 12 19 4" stroke-width="1.8"/></svg>',
  },
  {
    title: 'Análisis de tendencia',
    description: 'Mann-Kendall, punto de cambio de Pettitt y pendiente de Sen sobre series anuales o mensuales.',
    href: asset('/tools/trend'),
    tag: 'Clima',
    color: 'text-rose-800 bg-rose-100',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="3,18 7,12 11,14 15,9 19,7"/><line x1="3" y1="18" x2="21" y2="18" stroke-width="1.2"/><line x1="21" y1="7" x2="21" y2="18" stroke-width="1.2" stroke-dasharray="2 2"/></svg>',
  },
  {
    title: 'Frecuencia regional',
    description: 'Análisis regional por L-momentos: discordancia, heterogeneidad y curva de crecimiento GEV regional.',
    href: asset('/tools/rfa'),
    tag: 'Espacial',
    color: 'text-fuchsia-800 bg-fuchsia-100',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 19 Q5 14 7 12" stroke-width="1.2" stroke-opacity="0.5"/><path d="M6 19 Q8 13 10 10" stroke-width="1.2" stroke-opacity="0.5"/><path d="M9 19 Q11 12 13 9" stroke-width="1.2" stroke-opacity="0.5"/><path d="M5 20 Q10 10 17 5" stroke-width="2" stroke-linecap="round"/><circle cx="17" cy="5" r="2" fill="currentColor" stroke="none"/><line x1="2" y1="20" x2="22" y2="20" stroke-width="1.2"/></svg>',
  },
];

const catColors: Record<string, string> = {
  'Clima':         'bg-teal-100 text-teal-700',
  'Análisis esp.': 'bg-violet-100 text-violet-700',
  'Datos':         'bg-blue-100 text-blue-700',
  'Modelización':  'bg-orange-100 text-orange-700',
  'Caso piloto':   'bg-cyan-100 text-cyan-700',
};

const pilotNotebooks = notebooksMeta.filter(nb => nb.category === 'Caso piloto');
const generalNotebooks = notebooksMeta.filter(nb => nb.category !== 'Caso piloto');

type AccentStyle = { card: string; label: string; labelHover: string; divider: string; runHover: string; icon: string };
const accentStyles: Record<string, AccentStyle> = {
  sky:     { card: 'bg-sky-950/50 border-sky-500/30 hover:border-sky-400/60 hover:bg-sky-900/60',     label: 'text-sky-400',     labelHover: 'hover:text-sky-300',     divider: 'bg-sky-500/25',     runHover: 'group-hover:text-sky-400',     icon: 'opacity-60 group-hover:opacity-100' },
  orange:  { card: 'bg-orange-950/50 border-orange-500/30 hover:border-orange-400/60 hover:bg-orange-900/60', label: 'text-orange-400', labelHover: 'hover:text-orange-300', divider: 'bg-orange-500/25', runHover: 'group-hover:text-orange-400', icon: 'opacity-60 group-hover:opacity-100' },
  emerald: { card: 'bg-emerald-950/50 border-emerald-500/30 hover:border-emerald-400/60 hover:bg-emerald-900/60', label: 'text-emerald-400', labelHover: 'hover:text-emerald-300', divider: 'bg-emerald-500/25', runHover: 'group-hover:text-emerald-400', icon: 'opacity-60 group-hover:opacity-100' },
  purple:  { card: 'bg-purple-950/50 border-purple-500/30 hover:border-purple-400/60 hover:bg-purple-900/60', label: 'text-purple-400', labelHover: 'hover:text-purple-300', divider: 'bg-purple-500/25', runHover: 'group-hover:text-purple-400', icon: 'opacity-60 group-hover:opacity-100' },
};
const pilotCaseGroups = pilotCases.map(pc => {
  const prefix = `pilot_cases--${pc.slug.replace(/-/g, '_')}--`;
  return { pc, style: accentStyles[pc.accentColor] ?? accentStyles.sky, notebooks: pilotNotebooks.filter(nb => nb.slug.startsWith(prefix)) };
}).filter(g => g.notebooks.length > 0);

const notebookSessionHref = (slug: string) => {
  // slug uses '--' as path separator (e.g. "data_sources--rainfall--OGIMET_download")
  const path = slug.replaceAll('--', '/') + '.ipynb';
  return `/api/notebooks/session?path=${encodeURIComponent(path)}`;
};
---

<Layout title="HYDRA — Hidrología y Clima en Python">

  <!-- ── HERO ── -->
  <section class="relative min-h-[92vh] flex items-center overflow-hidden">
    <img
      src={asset('/assets/hero-landscape.svg')}
      alt=""
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="hero-overlay absolute inset-0"></div>
    <div class="hero-bottom-fade absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-white via-white/80 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path class="hero-wave-fill" d="M0 80L48 74.7C96 69.3 192 58.7 288 58.7C384 58.7 480 69.3 576 74.7C672 80 768 80 864 69.3C960 58.7 1056 37.3 1152 32C1248 26.7 1344 37.3 1392 42.7L1440 48V120H1392C1344 120 1248 120 1152 120C1056 120 960 120 864 120C768 120 672 120 576 120C480 120 384 120 288 120C192 120 96 120 48 120H0V80Z" fill="white"/>
      </svg>
    </div>

    <div class="relative max-w-7xl mx-auto px-6 pt-24 pb-40 w-full">
      <div class="max-w-3xl">
        <img src={asset('/favicon.png')} alt="HYDRA" class="h-28 w-28 rounded-3xl shadow-2xl mb-8" />
        <div class="flex flex-wrap gap-2 mb-7">
          <span class="text-xs font-bold px-3 py-1.5 rounded-full bg-cyan-400 text-slate-900 tracking-wide">Python</span>
          <span class="text-xs font-bold px-3 py-1.5 rounded-full bg-blue-500 text-white tracking-wide" data-t-es="Hidrología" data-t-en="Hydrology">Hidrología</span>
          <span class="text-xs font-bold px-3 py-1.5 rounded-full bg-teal-500 text-white tracking-wide" data-t-es="Clima" data-t-en="Climate">Clima</span>
          <span class="text-xs font-bold px-3 py-1.5 rounded-full bg-slate-700 text-white tracking-wide" data-t-es="Riesgo" data-t-en="Risk">Riesgo</span>
        </div>
        <h1 class="hero-title text-5xl md:text-7xl font-extrabold tracking-tight mb-6 leading-tight">HYDRA</h1>
        <p class="hero-desc text-xl md:text-2xl mb-10 leading-relaxed max-w-2xl">
          <span data-i18n="hero.description">Librería modular para análisis hidrológico, climático y modelización de inundaciones. Integra datos, extremos, generación estocástica y modelos físicos en flujos reproducibles.</span>
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#notebooks"
             class="hero-btn-primary font-semibold px-6 py-3 rounded-xl transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5">
            <span data-i18n="hero.notebooks">Ver notebooks</span> →
          </a>
          <a href="#herramientas"
             class="bg-cyan-400 text-slate-950 font-semibold px-6 py-3 rounded-xl hover:bg-cyan-300 transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5">
            <span data-i18n="hero.tools">Explorar herramientas</span>
          </a>
          <a href="https://github.com/navass11/pyhydra" target="_blank"
             class="hero-btn-ghost font-semibold px-6 py-3 rounded-xl transition-all backdrop-blur-sm">
            GitHub
          </a>
        </div>
        <div class="flex flex-wrap gap-8 mt-14 hero-stats">
          <div><span class="block text-3xl font-bold">{notebooksMeta.length}</span><span data-i18n="stats.notebooks">Notebooks</span></div>
          <div><span class="block text-3xl font-bold">4</span><span data-i18n="stats.modules">Módulos</span></div>
          <div><span class="block text-3xl font-bold">10+</span><span data-i18n="stats.sources">Fuentes de datos</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── MÓDULOS ── -->
  <section id="modulos" class="py-20 max-w-7xl mx-auto px-6">
    <div class="text-center mb-16 fade-in">
      <h2 class="text-4xl font-bold mb-4" data-i18n="modules.title">Módulos principales</h2>
      <p class="text-slate-500 text-lg max-w-2xl mx-auto">
        <span data-i18n="modules.description">Cuatro bloques conectados para pasar de datos brutos a escenarios, simulaciones y productos de riesgo.</span>
      </p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {modules.map((m, i) => (
        <a
          href={m.href}
          class={`fade-in rounded-2xl border p-6 ${m.bg} ${m.border} hover:shadow-lg transition-all hover:-translate-y-1 group`}
          style={`transition-delay: ${i * 80}ms`}
        >
          <div class={`w-12 h-12 rounded-xl ${m.color} flex items-center justify-center mb-4 shadow-sm`}>
            <div class="h-7 w-7" set:html={m.icon} />
          </div>
          <h3 class="font-bold text-gray-900 mb-2 text-lg">{m.title}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{m.description}</p>
          <span class="inline-flex mt-4 text-sm font-semibold text-hydra-700 group-hover:text-hydra-900"><span data-i18n="modules.view">Ver módulo</span> →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ── HERRAMIENTAS ── -->
  <section id="herramientas" class="py-20 bg-slate-950 text-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="mb-12 fade-in">
        <h2 class="text-4xl font-bold mb-4" data-i18n="tools.title">Herramientas interactivas</h2>
        <p class="text-slate-300 text-lg max-w-2xl">
          <span data-i18n="tools.description">Interfaces ligeras para probar funcionalidades de HYDRA sin abrir un notebook.</span>
        </p>
      </div>
      <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-6">
        {tools.map((tool, i) => (
          <a
            href={tool.href}
            class="fade-in group rounded-2xl border border-white/10 bg-white/[0.06] p-6 hover:bg-white/[0.1] transition-all hover:-translate-y-1"
            style={`transition-delay: ${i * 80}ms`}
          >
            <div class="flex items-start gap-5">
              <div class={`h-12 w-12 shrink-0 rounded-xl ${tool.color} flex items-center justify-center`}>
                <div class="h-7 w-7" set:html={tool.icon} />
              </div>
              <div>
                <div class="flex items-center gap-3 mb-2">
                  <h3 class="text-xl font-bold">{tool.title}</h3>
                  <span class="rounded-full bg-white/10 px-2.5 py-1 text-xs text-slate-300">{tool.tag}</span>
                </div>
                <p class="text-slate-300 leading-relaxed mb-4">{tool.description}</p>
