<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.notebook-card');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat!;
      btns.forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      cards.forEach(card => {
        card.style.display = (cat === 'Todos' || card.dataset.cat === cat) ? '' : 'none';
      });
    });
  });

  (document.querySelector('.filter-btn') as HTMLButtonElement)?.click();
</script>

