---
import Layout from '../../layouts/Layout.astro';
import { pilotCases } from '../../data/pilot_cases';

export function getStaticPaths() {
  return pilotCases.map((c) => ({
    params: { slug: c.slug },
    props: { case: c },
  }));
}

const { case: pc } = Astro.props;
const base = import.meta.env.BASE_URL;
const notebookSessionHref = (path: string) => `/api/notebooks/session?path=${encodeURIComponent(path)}`;

const stepColors: Record<number, string> = {
  1: 'border-sky-500/30 bg-sky-950/50',
  2: 'border-violet-500/30 bg-violet-950/50',
  3: 'border-indigo-500/30 bg-indigo-950/50',
  4: 'border-amber-500/30 bg-amber-950/50',
  5: 'border-amber-500/30 bg-amber-950/50',
  6: 'border-purple-500/30 bg-purple-950/50',
  7: 'border-orange-500/30 bg-orange-950/50',
  8: 'border-rose-500/30 bg-rose-950/50',
};

const stepNumColors: Record<number, string> = {
  1: 'text-sky-300 bg-sky-900/60',
  2: 'text-violet-300 bg-violet-900/60',
  3: 'text-indigo-300 bg-indigo-900/60',
  4: 'text-amber-300 bg-amber-900/60',
  5: 'text-amber-300 bg-amber-900/60',
  6: 'text-purple-300 bg-purple-900/60',
  7: 'text-orange-300 bg-orange-900/60',
  8: 'text-rose-300 bg-rose-900/60',
};

const stepTitleColors: Record<number, string> = {
  1: 'group-hover:text-sky-300',
  2: 'group-hover:text-violet-300',
  3: 'group-hover:text-indigo-300',
  4: 'group-hover:text-amber-300',
  5: 'group-hover:text-amber-300',
  6: 'group-hover:text-purple-300',
  7: 'group-hover:text-orange-300',
  8: 'group-hover:text-rose-300',
};
---

<Layout title={`${pc.title} — HYDRA`}>

  <!-- ── HERO ── -->
  <section class={`pt-24 pb-16 bg-gradient-to-br ${pc.color} text-white`}>
    <div class="max-w-7xl mx-auto px-6">
      <a href={`${base}#casos-piloto`} class="inline-flex items-center gap-2 text-white/65 hover:text-white text-sm mb-6 transition-colors" data-i18n="back.cases">
        ← Casos piloto
      </a>
      <div class="flex flex-wrap items-center gap-3 mb-5">
        <span class="inline-flex rounded-full bg-white/12 border border-white/20 px-3 py-1 text-sm text-white/80" data-t-es="Caso Piloto" data-t-en="Pilot case">
          {pc.tag}
        </span>
        <span class="inline-flex rounded-full bg-white/12 border border-white/20 px-3 py-1 text-sm text-white/80">
          {pc.river}
        </span>
        <span class="inline-flex rounded-full bg-white/12 border border-white/20 px-3 py-1 text-sm text-white/80">
          {pc.region}<span data-t-es=", España" data-t-en=", Spain">, España</span>
        </span>
      </div>
      <h1 class="text-4xl md:text-6xl font-extrabold mb-4">{pc.title}</h1>
      <p
        class="text-xl text-white/78 max-w-3xl leading-relaxed"
        data-t-es={pc.subtitle.es}
        data-t-en={pc.subtitle.en}
      >{pc.subtitle.es}</p>

      <!-- Stats row -->
      <div class="flex flex-wrap gap-10 mt-10">
        {pc.stats.map((s) => (
          <div>
            <span class="block text-3xl font-bold text-white">{s.value}</span>
            <span class="text-sm text-white/65" data-t-es={s.label.es} data-t-en={s.label.en}>{s.label.es}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <main class="bg-slate-950 text-white">
    <div class="max-w-7xl mx-auto px-6 py-14 space-y-16">

      <!-- ── RESUMEN + RETO ── -->
      <section class="grid lg:grid-cols-2 gap-10">
        <div>
          <h2 class="text-2xl font-bold text-white mb-4" data-i18n="case.summary">Descripción del caso</h2>
          <p
            class="text-slate-300 leading-relaxed text-lg"
            data-t-es={pc.summary.es}
            data-t-en={pc.summary.en}
          >{pc.summary.es}</p>
        </div>
        <div class="rounded-2xl border border-amber-500/30 bg-amber-950/40 p-7">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 rounded-lg bg-amber-500/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
              </svg>
            </div>
            <h3 class="font-bold text-amber-300 text-lg" data-i18n="case.challenge">Reto hidrológico</h3>
          </div>
          <p
            class="text-amber-200/80 leading-relaxed"
            data-t-es={pc.challenge.es}
            data-t-en={pc.challenge.en}
          >{pc.challenge.es}</p>
        </div>
      </section>

      <!-- ── ENFOQUE HYDRA ── -->
      <section class="rounded-2xl border border-blue-500/30 bg-blue-950/40 p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 rounded-xl bg-blue-600/50 flex items-center justify-center">
            <svg class="w-5 h-5 text-blue-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 8v4l3 3"/>
            </svg>
          </div>
          <h2 class="text-xl font-bold text-blue-200" data-i18n="case.approach">Enfoque HYDRA</h2>
        </div>
        <p
          class="text-blue-100/75 leading-relaxed max-w-5xl"
          data-t-es={pc.approach.es}
          data-t-en={pc.approach.en}
          data-html="true"
          set:html={pc.approach.es}
        />
      </section>

      <!-- ── WORKFLOW ── -->
      <section>
        <div class="mb-8">
          <h2 class="text-3xl font-bold text-white mb-2" data-i18n="case.workflow.title">Flujo de trabajo</h2>
          <p class="text-slate-400" data-i18n="case.workflow.description">{pc.steps.length} notebooks ejecutables — haz clic en cualquier paso para abrir en Jupyter Lab.</p>
        </div>

        <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-5">
          {pc.steps.map((step) => (
            <a
              href={notebookSessionHref(step.notebookPath)}
              target="_blank"
              rel="noopener noreferrer"
              class={`group rounded-2xl border-2 p-5 transition-all hover:shadow-lg hover:shadow-black/40 hover:-translate-y-0.5 ${stepColors[step.number] ?? 'border-white/10 bg-white/5'}`}
            >
              <div class="flex items-center gap-3 mb-3">
                <span class={`inline-flex w-8 h-8 rounded-lg items-center justify-center text-sm font-black ${stepNumColors[step.number] ?? 'bg-white/10 text-slate-300'}`}>
                  {String(step.number).padStart(2, '0')}
                </span>
                <div class="flex flex-wrap gap-1">
                  {step.tags.map((tag) => (
                    <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-white/10 text-slate-300">{tag}</span>
                  ))}
                </div>
              </div>
              <h3
                class={`font-bold text-white mb-2 transition-colors ${stepTitleColors[step.number] ?? 'group-hover:text-cyan-300'}`}
                data-t-es={step.title.es}
                data-t-en={step.title.en}
              >{step.title.es}</h3>
              <p
                class="text-sm text-slate-400 leading-relaxed"
                data-t-es={step.description.es}
                data-t-en={step.description.en}
              >{step.description.es}</p>
              <span class="inline-flex mt-3 text-xs font-semibold text-slate-500 group-hover:text-cyan-400 transition-colors">
                ▶ <span data-i18n="case.open_notebook">Abrir notebook</span>
              </span>
            </a>
          ))}
        </div>
      </section>

      {pc.references?.length ? (
        <section>
          <div class="mb-6">
            <h2 class="text-3xl font-bold text-white mb-2" data-i18n="case.references.title">Referencias del caso</h2>
            <p class="text-slate-400 max-w-3xl" data-i18n="case.references.description">
              Fuentes de datos, métodos y validaciones que sustentan el caso piloto.
            </p>
          </div>
          <div class="grid md:grid-cols-2 gap-5">
            {pc.references.map((ref) => (
              <article class="rounded-xl border border-white/10 bg-white/[0.05] p-5">
                <h3
                  class="font-bold text-white mb-2"
                  data-t-es={ref.title.es}
                  data-t-en={ref.title.en}
                >{ref.title.es}</h3>
                <p
                  class="text-sm text-slate-400 leading-relaxed"
                  data-t-es={ref.description.es}
                  data-t-en={ref.description.en}
                >{ref.description.es}</p>
                {ref.href ? (
                  <a
                    href={ref.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex mt-4 text-sm font-semibold text-cyan-400 hover:text-cyan-200 transition-colors"
                    data-t-es={ref.cta?.es ?? 'Abrir referencia'}
                    data-t-en={ref.cta?.en ?? 'Open reference'}
                  >
                    {ref.cta?.es ?? 'Abrir referencia'} →
                  </a>
                ) : null}
              </article>
            ))}
          </div>
        </section>
      ) : null}

      <!-- ── FIGURA SVG ── -->
      {pc.figures.map((fig) => (
        <section class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
          <h3
            class="font-bold text-white mb-1"
            data-t-es={fig.title.es}
            data-t-en={fig.title.en}
          >{fig.title.es}</h3>
          <p
            class="text-sm text-slate-400 mb-5 max-w-3xl"
            data-t-es={fig.caption.es}
            data-t-en={fig.caption.en}
          >{fig.caption.es}</p>
          <div class="w-full overflow-x-auto rounded-xl" set:html={fig.svg} />
        </section>
      ))}

      <!-- ── CONCLUSIONES ── -->
      <section class="grid lg:grid-cols-[1fr_1.5fr] gap-10 items-start">
        <div>
          <h2 class="text-3xl font-bold text-white mb-3" data-i18n="case.findings.title">Hallazgos clave</h2>
          <p class="text-slate-400 leading-relaxed" data-i18n="case.findings.description">Resultados principales extraídos del análisis.</p>
        </div>
        <ul class="space-y-4">
          {pc.keyFindings.map((finding) => (
            <li class="flex gap-4 rounded-xl border border-white/10 p-5 bg-white/[0.04]">
              <div class="mt-0.5 flex-shrink-0 w-6 h-6 rounded-full bg-cyan-600/60 flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
              <p
                class="text-slate-300 leading-relaxed"
                data-t-es={finding.es}
                data-t-en={finding.en}
              >{finding.es}</p>
            </li>
          ))}
        </ul>
      </section>

      <!-- ── NAVEGACIÓN VOLVER ── -->
      <div class="border-t border-white/10 pt-10 flex items-center justify-between">
        <a href={`${base}#casos-piloto`} class="inline-flex items-center gap-2 text-slate-400 hover:text-cyan-300 font-medium transition-colors">
          ← <span data-i18n="case.back_all">Todos los casos piloto</span>
        </a>
        <a href={`${base}#modulos`} class="inline-flex items-center gap-2 text-slate-400 hover:text-cyan-300 font-medium transition-colors">
          <span data-i18n="case.explore_modules">Explorar módulos HYDRA</span> →
        </a>
      </div>

    </div>
  </main>
</Layout>
