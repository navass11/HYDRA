---
import Layout from '../../layouts/Layout.astro';
import { modules } from '../../data/modules';

export function getStaticPaths() {
  return modules.map((module) => ({
    params: { slug: module.slug },
    props: { module },
  }));
}

const { module } = Astro.props;
const relatedTools: Record<string, Array<{ label: string; href: string }>> = {
  'fuentes-datos': [{ label: 'Descarga OGIMET', href: '/tools/ogimet' }],
  'analisis-climatico': [
    { label: 'Eventos + GEV bayesiana', href: '/tools/statistical' },
    { label: 'Cópulas de eventos', href: '/tools/copulas' },
  ],
  'generacion-estocastica': [
    { label: 'Generación estocástica', href: '/tools/stochastic' },
    { label: 'Cópulas de eventos', href: '/tools/copulas' },
  ],
  'modelizacion': [{ label: 'Sensibilidad de Manning', href: '/tools/sensitivity' }],
};
---

<Layout title={`${module.title} — HYDRA`}>
  <section class={`pt-24 pb-14 bg-gradient-to-br ${module.color} text-white`}>
    <div class="max-w-7xl mx-auto px-6">
      <a href={`${import.meta.env.BASE_URL}#modulos`} class="inline-flex items-center gap-2 text-white/65 hover:text-white text-sm mb-6 transition-colors" data-i18n="back.modules">
        ← Volver a módulos
      </a>
      <span class="inline-flex rounded-full bg-white/12 border border-white/20 px-3 py-1 text-sm text-white/78 mb-5">{module.tag}</span>
      <h1 class="text-4xl md:text-6xl font-extrabold mb-4">{module.title}</h1>
      <p class="text-xl text-white/78 max-w-3xl leading-relaxed" data-t-es={module.subtitle.es} data-t-en={module.subtitle.en}>{module.subtitle.es}</p>
    </div>
  </section>

  <!-- Navigation tabs -->
  <div class="border-b border-gray-200 bg-white sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-6 flex gap-1">
      <a href={`/modules/${module.slug}`}
         class="px-4 py-3 text-sm font-medium text-gray-900 border-b-2 border-hydra-600 transition-colors" data-i18n="module.tab.overview">
        Descripción general
      </a>
      <a href={`/modules/${module.slug}/reference`}
         class="px-4 py-3 text-sm font-medium text-gray-500 hover:text-gray-900 border-b-2 border-transparent hover:border-gray-300 transition-colors" data-i18n="module.tab.api">
        API Reference
      </a>
    </div>
  </div>

  <main class="max-w-7xl mx-auto px-6 py-12 space-y-12">
    <section class="grid lg:grid-cols-[1.1fr_0.9fr] gap-10 items-start">
      <div>
        <h2 class="text-3xl font-bold text-gray-900 mb-4">En que consiste</h2>
        <p class="text-lg text-gray-600 leading-relaxed mb-6" data-t-es={module.summary.es} data-t-en={module.summary.en}>{module.summary.es}</p>
        <p class="text-gray-600 leading-relaxed" data-t-es={module.purpose.es} data-t-en={module.purpose.en}>{module.purpose.es}</p>
      </div>
      <div class="rounded-2xl border border-gray-100 bg-gray-50 p-6">
        <h3 class="font-semibold text-gray-900 mb-4">Herramientas relacionadas</h3>
        <div class="flex flex-wrap gap-3">
          {(relatedTools[module.slug] ?? []).map((tool) => (
            <a href={tool.href} class="rounded-xl bg-white border border-gray-200 px-4 py-2 text-sm font-semibold text-hydra-700 hover:border-hydra-300 hover:bg-hydra-50 transition-colors">
              {tool.label} →
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="grid md:grid-cols-3 gap-6">
      <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm">
        <h3 class="font-bold text-gray-900 mb-4">Flujo de trabajo</h3>
        <ol class="space-y-3">
          {module.workflow.map((item, index) => (
            <li class="flex gap-3 text-sm text-gray-600">
              <span class="h-7 w-7 shrink-0 rounded-full bg-hydra-100 text-hydra-700 flex items-center justify-center font-bold">{index + 1}</span>
              <span data-t-es={item.es} data-t-en={item.en}>{item.es}</span>
            </li>
          ))}
        </ol>
      </div>
      <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm">
        <h3 class="font-bold text-gray-900 mb-4">Entradas</h3>
        <ul class="space-y-3">
          {module.inputs.map((item) => (
            <li class="text-sm text-gray-600 flex gap-2">
              <span class="text-cyan-600 font-bold">•</span>
              <span data-t-es={item.es} data-t-en={item.en}>{item.es}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm">
        <h3 class="font-bold text-gray-900 mb-4">Salidas</h3>
        <ul class="space-y-3">
          {module.outputs.map((item) => (
            <li class="text-sm text-gray-600 flex gap-2">
              <span class="text-emerald-600 font-bold">•</span>
              <span data-t-es={item.es} data-t-en={item.en}>{item.es}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section>
      <div class="mb-6">
        <h2 class="text-3xl font-bold text-gray-900 mb-2">Capacidades implementadas</h2>
        <p class="text-gray-500">Funciones tecnicas que el modulo cubre dentro de HYDRA y que deben aparecer en la memoria como parte del manual practico.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-4">
        {module.capabilities.map((item) => (
          <div class="rounded-2xl border border-gray-100 bg-white p-5 shadow-sm">
            <p class="text-gray-700 leading-relaxed" data-t-es={item.es} data-t-en={item.en}>{item.es}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="grid lg:grid-cols-[0.95fr_1.05fr] gap-8 items-start">
      <div class="rounded-2xl border border-gray-100 bg-gray-50 p-6">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Validacion y control</h2>
        <ul class="space-y-3">
          {module.validation.map((item) => (
            <li class="flex gap-3 text-sm text-gray-600">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-emerald-500"></span>
              <span data-t-es={item.es} data-t-en={item.en}>{item.es}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Piezas de codigo HYDRA</h2>
        <div class="space-y-3">
          {module.methods.map((method) => (
            <div class="rounded-xl border border-gray-100 bg-gray-50 p-4">
              <p class="font-mono text-sm font-semibold text-hydra-700">{method.name}</p>
              <p class="text-sm text-gray-600 mt-1" data-t-es={method.description.es} data-t-en={method.description.en}>{method.description.es}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section>
      <div class="mb-6">
        <h2 class="text-3xl font-bold text-gray-900 mb-2">Figuras de analisis</h2>
        <p class="text-gray-500">Esquemas iniciales para explicar la logica metodologica del modulo dentro de la memoria y la web.</p>
      </div>
      <div class="grid lg:grid-cols-2 gap-8">
        {module.figures.map((figure) => (
          <figure class="rounded-2xl border border-gray-100 bg-white shadow-sm overflow-hidden">
            <div class="[&_svg]:w-full [&_svg]:h-auto" set:html={figure.svg} />
            <figcaption class="p-5 border-t border-gray-100">
              <p class="font-semibold text-gray-900" data-t-es={figure.title.es} data-t-en={figure.title.en}>{figure.title.es}</p>
              <p class="text-sm text-gray-500 mt-1" data-t-es={figure.caption.es} data-t-en={figure.caption.en}>{figure.caption.es}</p>
            </figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section>
      <div class="mb-6">
        <h2 class="text-3xl font-bold text-gray-900 mb-2">Uso industrial</h2>
        <p class="text-gray-500">Como se traduce el modulo en trabajo operativo, transferencia y casos de estudio.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        {module.industrialUse.map((item) => (
          <div class="rounded-2xl border border-amber-100 bg-amber-50 p-5 text-amber-950 leading-relaxed" data-t-es={item.es} data-t-en={item.en}>{item.es}</div>
        ))}
      </div>
    </section>

    <section class="rounded-2xl bg-slate-950 text-white p-8">
      <h2 class="text-2xl font-bold mb-5">Papel dentro de HYDRA</h2>
      <div class="grid md:grid-cols-3 gap-5">
        {module.hydra.map((item) => (
          <div class="rounded-xl bg-white/8 border border-white/10 p-5 text-white/78 leading-relaxed" data-t-es={item.es} data-t-en={item.en}>{item.es}</div>
        ))}
      </div>
    </section>
  </main>
</Layout>
