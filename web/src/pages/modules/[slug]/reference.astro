---
import Layout from '../../../layouts/Layout.astro';
import { modules } from '../../../data/modules';
import { apiDocs } from '../../../data/apiDocs';
import type { ApiItem, ApiParam, ApiMethod } from '../../../data/apiDocs';

export function getStaticPaths() {
  return modules.map((module) => ({
    params: { slug: module.slug },
    props: { module },
  }));
}

const { module } = Astro.props;
const docs = apiDocs.find((d) => d.slug === module.slug);
const items = docs?.items ?? [];
const classes = items.filter((i) => i.kind === 'class');
const functions = items.filter((i) => i.kind === 'function');
---

<Layout title={`${module.title} — API Reference — HYDRA`}>
  <!-- Header -->
  <section class={`pt-24 pb-14 bg-gradient-to-br ${module.color} text-white`}>
    <div class="max-w-7xl mx-auto px-6">
      <a href={`/modules/${module.slug}`} class="inline-flex items-center gap-2 text-white/65 hover:text-white text-sm mb-6 transition-colors">
        ← Volver al módulo
      </a>
      <span class="inline-flex rounded-full bg-white/12 border border-white/20 px-3 py-1 text-sm text-white/78 mb-5">{module.tag}</span>
      <h1 class="text-4xl md:text-5xl font-extrabold mb-3">{module.title}</h1>
      <p class="text-lg text-white/78 font-mono tracking-wide">API Reference</p>
    </div>
  </section>

  <!-- Navigation tabs -->
  <div class="border-b border-gray-200 bg-white sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-6 flex gap-1">
      <a href={`/modules/${module.slug}`}
         class="px-4 py-3 text-sm font-medium text-gray-500 hover:text-gray-900 border-b-2 border-transparent hover:border-gray-300 transition-colors">
        Descripción general
      </a>
      <a href={`/modules/${module.slug}/reference`}
         class="px-4 py-3 text-sm font-medium text-gray-900 border-b-2 border-hydra-600 transition-colors">
        API Reference
      </a>
    </div>
  </div>

  <main class="max-w-7xl mx-auto px-6 py-12">
    <!-- Quick index -->
    {items.length > 0 && (
      <div class="mb-10 rounded-2xl border border-gray-100 bg-gray-50 p-6">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Índice</h2>
        <div class="flex flex-wrap gap-2">
          {items.map((item) => (
            <a href={`#${item.name}`}
               class={`rounded-lg px-3 py-1 text-sm font-mono font-semibold transition-colors ${
                 item.kind === 'class'
                   ? 'bg-violet-100 text-violet-800 hover:bg-violet-200'
                   : 'bg-sky-100 text-sky-800 hover:bg-sky-200'
               }`}>
              {item.kind === 'class' ? 'class ' : ''}{item.name}
            </a>
          ))}
        </div>
      </div>
    )}

    {/* Classes section */}
    {classes.length > 0 && (
      <section class="mb-16 space-y-12">
        <h2 class="text-2xl font-bold text-gray-900 border-b border-gray-200 pb-3">Clases</h2>
        {classes.map((item) => (
          <article id={item.name} class="scroll-mt-20">
            <!-- Class header -->
            <div class="rounded-t-2xl border border-b-0 border-gray-200 bg-violet-50 p-6">
              <div class="flex flex-wrap items-start gap-3 mb-3">
                <span class="rounded-full bg-violet-200 px-3 py-0.5 text-xs font-semibold text-violet-800 uppercase tracking-wide">class</span>
                <code class="text-xl font-bold text-gray-900">{item.name}</code>
              </div>
              <code class="text-sm text-gray-500 font-mono">from {item.module} import {item.name}</code>
            </div>

            <div class="rounded-b-2xl border border-gray-200 bg-white p-6 space-y-6">
              <!-- Description -->
              <p class="text-gray-700 leading-relaxed" data-t-es={item.description.es} data-t-en={item.description.en}>{item.description.es}</p>

              {/* Note */}
              {item.note && (
                <div class="rounded-xl bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-800">
                  <span class="font-semibold">Dependencia: </span><span data-t-es={item.note.es} data-t-en={item.note.en}>{item.note.es}</span>
                </div>
              )}

              {/* Constructor params */}
              {item.params && item.params.length > 0 && (
                <div>
                  <h4 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-3">Parámetros del constructor</h4>
                  <div class="rounded-xl border border-gray-100 overflow-hidden">
                    <table class="w-full text-sm">
                      <thead class="bg-gray-50 border-b border-gray-100">
                        <tr>
                          <th class="text-left px-4 py-2 font-semibold text-gray-600 w-32">Nombre</th>
                          <th class="text-left px-4 py-2 font-semibold text-gray-600 w-36">Tipo</th>
                          <th class="text-left px-4 py-2 font-semibold text-gray-600 w-28">Defecto</th>
                          <th class="text-left px-4 py-2 font-semibold text-gray-600">Descripción</th>
                        </tr>
                      </thead>
                      <tbody class="divide-y divide-gray-50">
                        {item.params.map((p) => (
                          <tr class="hover:bg-gray-50/50">
                            <td class="px-4 py-2.5"><code class="text-violet-700 font-semibold">{p.name}</code></td>
                            <td class="px-4 py-2.5"><code class="text-gray-600 text-xs">{p.type}</code></td>
                            <td class="px-4 py-2.5"><code class="text-gray-500 text-xs">{p.default ?? '—'}</code></td>
                            <td class="px-4 py-2.5 text-gray-700" data-t-es={p.description.es} data-t-en={p.description.en}>{p.description.es}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              )}

              {/* Methods */}
              {item.methods && item.methods.length > 0 && (
                <div>
                  <h4 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-3">Métodos</h4>
                  <div class="space-y-4">
                    {item.methods.map((m) => (
                      <div class="rounded-xl border border-gray-100 bg-gray-50/50">
                        <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-100 bg-white rounded-t-xl">
                          <code class="font-bold text-gray-900">{m.name}</code>
                          <code class="text-xs text-gray-500 font-mono">{m.signature}</code>
                        </div>
                        <div class="px-4 py-3 space-y-3">
                          <p class="text-sm text-gray-700" data-t-es={m.description.es} data-t-en={m.description.en}>{m.description.es}</p>
                          {m.params && m.params.length > 0 && (
                            <div class="rounded-lg border border-gray-100 overflow-hidden">
                              <table class="w-full text-xs">
                                <thead class="bg-gray-100 border-b border-gray-100">
                                  <tr>
                                    <th class="text-left px-3 py-1.5 font-semibold text-gray-600 w-28">Parámetro</th>
                                    <th class="text-left px-3 py-1.5 font-semibold text-gray-600 w-32">Tipo</th>
                                    <th class="text-left px-3 py-1.5 font-semibold text-gray-600">Descripción</th>
                                  </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-50">
                                  {m.params.map((p) => (
                                    <tr class="bg-white">
                                      <td class="px-3 py-1.5"><code class="text-violet-700">{p.name}</code></td>
                                      <td class="px-3 py-1.5"><code class="text-gray-500">{p.type}</code></td>
                                      <td class="px-3 py-1.5 text-gray-700" data-t-es={p.description.es} data-t-en={p.description.en}>{p.description.es}</td>
                                    </tr>
                                  ))}
                                </tbody>
                              </table>
                            </div>
                          )}
                          {m.returns && (
                            <p class="text-xs text-gray-600">
                              <span class="font-semibold text-gray-800">Returns:</span>{' '}
                              <span data-t-es={m.returns.es} data-t-en={m.returns.en}>{m.returns.es}</span>
                            </p>
                          )}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {/* Example */}
              {item.example && (
                <div>
                  <h4 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-2">Ejemplo</h4>
                  <pre class="rounded-xl bg-gray-900 text-gray-100 p4 text-sm overflow-x-auto font-mono leading-relaxed"><code>{item.example}</code></pre>
                </div>
              )}
            </div>
          </article>
        ))}
      </section>
    )}

    {/* Functions section */}
    {functions.length > 0 && (
      <section class="space-y-10">
        <h2 class="text-2xl font-bold text-gray-900 border-b border-gray-200 pb-3">Funciones</h2>
        {functions.map((item) => (
          <article id={item.name} class="scroll-mt-20">
            <div class="rounded-t-2xl border border-b-0 border-gray-200 bg-sky-50 p-6">
              <div class="flex flex-wrap items-start gap-3 mb-3">
                <span class="rounded-full bg-sky-200 px-3 py-0.5 text-xs font-semibold text-sky-800 uppercase tracking-wide">function</span>
                <code class="text-xl font-bold text-gray-900">{item.name}</code>
              </div>
              <code class="text-sm text-gray-500 font-mono">from {item.module} import {item.name}</code>
            </div>

            <div class="rounded-b-2xl border border-gray-200 bg-white p-6 space-y-6">
              <p class="text-gray-700 leading-relaxed" data-t-es={item.description.es} data-t-en={item.description.en}>{item.description.es}</p>

              {item.note && (
                <div class="rounded-xl bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-800">
                  <span class="font-semibold">Dependencia: </span><span data-t-es={item.note.es} data-t-en={item.note.en}>{item.note.es}</span>
                </div>
              )}

              {item.params && item.params.length > 0 && (
                <div>
                  <h4 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-3">Parámetros</h4>
                  <div class="rounded-xl border border-gray-100 overflow-hidden">
                    <table class="w-full text-sm">
                      <thead class="bg-gray-50 border-b border-gray-100">
                        <tr>
                          <th class="text-left px-4 py-2 font-semibold text-gray-600 w-36">Nombre</th>
                          <th class="text-left px-4 py-2 font-semibold text-gray-600 w-40">Tipo</th>
                          <th class="text-left px-4 py-2 font-semibold text-gray-600 w-28">Defecto</th>
                          <th class="text-left px-4 py-2 font-semibold text-gray-600">Descripción</th>
                        </tr>
                      </thead>
                      <tbody class="divide-y divide-gray-50">
                        {item.params.map((p) => (
                          <tr class="hover:bg-gray-50/50">
                            <td class="px-4 py-2.5"><code class="text-sky-700 font-semibold">{p.name}</code></td>
                            <td class="px-4 py-2.5"><code class="text-gray-600 text-xs">{p.type}</code></td>
                            <td class="px-4 py-2.5"><code class="text-gray-500 text-xs">{p.default ?? '—'}</code></td>
                            <td class="px-4 py-2.5 text-gray-700" data-t-es={p.description.es} data-t-en={p.description.en}>{p.description.es}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              )}

              {item.returns && (
                <div>
                  <h4 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-1">Returns</h4>
                  <p class="text-sm text-gray-700" data-t-es={item.returns.es} data-t-en={item.returns.en}>{item.returns.es}</p>
                </div>
              )}

              {item.example && (
                <div>
                  <h4 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-2">Ejemplo</h4>
                  <pre class="rounded-xl bg-gray-900 text-gray-100 p-4 text-sm overflow-x-auto font-mono leading-relaxed"><code>{item.example}</code></pre>
                </div>
              )}
            </div>
          </article>
        ))}
      </section>
    )}

    {items.length === 0 && (
      <div class="text-center py-20 text-gray-400">
        <p class="text-lg">Sin documentación disponible todavía para este módulo.</p>
      </div>
    )}
  </main>
</Layout>

<script>
  const applyApiLang = (lang: string) => {
    document.querySelectorAll<HTMLElement>('[data-t-es]').forEach((el) => {
      el.textContent = lang === 'en' ? (el.dataset.tEn ?? '') : (el.dataset.tEs ?? '');
    });
  };

  applyApiLang(document.documentElement.lang || 'es');

  new MutationObserver(() => {
    applyApiLang(document.documentElement.lang || 'es');
  }).observe(document.documentElement, { attributes: true, attributeFilter: ['lang'] });
</script>
