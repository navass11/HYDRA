---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Descarga Meteostat — HYDRA">
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />
  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
    is:inline
  ></script>

  <section class="pt-24 pb-10 bg-gradient-to-br from-slate-950 via-sky-950 to-cyan-800 text-white">
    <div class="max-w-7xl mx-auto px-6">
      <a href="/" class="inline-flex items-center gap-2 text-white/65 hover:text-white text-sm mb-6 transition-colors">
        ← Volver al inicio
      </a>
      <h1 class="text-4xl font-extrabold mb-2">Descarga Meteostat</h1>
      <p class="text-white/76 text-lg max-w-3xl">
        Busca estaciones meteorológicas en el mapa, selecciona periodo y variable, y descarga datos diarios o mensuales en CSV.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-6 py-10">
    <div class="grid lg:grid-cols-[340px_1fr] gap-8">

      <!-- ── PANEL DE CONTROL ── -->
      <aside class="space-y-6">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 space-y-5">

          <!-- Búsqueda -->
          <div>
            <label class="block text-sm font-semibold text-gray-800 mb-2">Buscar en el mapa</label>
            <div class="flex gap-2">
              <input id="search-lat" type="number" step="0.01" placeholder="Lat" value="40.42"
                class="w-1/2 rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-hydra-400" />
              <input id="search-lon" type="number" step="0.01" placeholder="Lon" value="-3.70"
                class="w-1/2 rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-hydra-400" />
            </div>
            <div class="flex gap-2 mt-2">
              <input id="search-radius" type="number" min="10" max="2000" value="300" placeholder="Radio km"
                class="w-1/2 rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-hydra-400" />
              <button id="search-btn"
                class="flex-1 bg-sky-600 hover:bg-sky-700 text-white font-semibold py-2 rounded-lg text-sm transition-colors">
                Buscar
              </button>
            </div>
          </div>

          <!-- Estación seleccionada -->
          <div class="rounded-xl bg-sky-50 border border-sky-100 p-4">
            <p class="text-xs font-semibold text-sky-700 uppercase tracking-wide mb-1">Estación seleccionada</p>
            <p id="selected-name" class="font-semibold text-gray-900 text-sm">—</p>
            <p id="selected-meta" class="text-xs text-gray-500 mt-0.5">Haz clic en una estación del mapa</p>
            <input id="selected-wmo" type="hidden" value="" />
          </div>

          <!-- Fechas -->
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-semibold text-gray-800 mb-2" for="start-date">Inicio</label>
              <input id="start-date" type="date" value="2020-01-01"
                class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-hydra-400" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-800 mb-2" for="end-date">Fin</label>
              <input id="end-date" type="date" value="2023-12-31"
                class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-hydra-400" />
            </div>
          </div>

          <!-- Frecuencia -->
          <div>
            <label class="block text-sm font-semibold text-gray-800 mb-2">Frecuencia</label>
            <div class="flex gap-2">
              <label class="flex-1 flex items-center justify-center gap-2 rounded-lg border border-gray-200 py-2 text-sm cursor-pointer has-[:checked]:border-hydra-500 has-[:checked]:bg-hydra-50">
                <input type="radio" name="freq" value="daily" checked class="accent-hydra-600" />
                Diaria
              </label>
              <label class="flex-1 flex items-center justify-center gap-2 rounded-lg border border-gray-200 py-2 text-sm cursor-pointer has-[:checked]:border-hydra-500 has-[:checked]:bg-hydra-50">
                <input type="radio" name="freq" value="monthly" class="accent-hydra-600" />
                Mensual
              </label>
            </div>
          </div>

          <button id="load-btn"
            class="w-full bg-hydra-600 hover:bg-hydra-700 text-white font-semibold py-3 rounded-xl transition-colors">
            Cargar datos
          </button>
          <button id="download-btn" disabled
            class="w-full border border-gray-200 text-gray-400 font-semibold py-3 rounded-xl transition-colors disabled:opacity-50 disabled:cursor-not-allowed hover:not-disabled:border-hydra-300">
            Descargar CSV
          </button>
          <div id="error-box" class="hidden bg-red-50 border border-red-200 rounded-lg p-3 text-sm text-red-700"></div>
        </div>

        <div class="bg-sky-50 border border-sky-100 rounded-2xl p-5 text-sm text-sky-900 space-y-2">
          <p class="font-semibold">Integración HYDRA</p>
          <p>Usa <code class="text-sky-700">pyhydra.data_sources.rainfall.meteostat</code> para reproducir esta descarga en Python con el mismo periodo y estación.</p>
        </div>
      </aside>

      <!-- ── PANEL PRINCIPAL ── -->
      <main class="space-y-8">

        <!-- Mapa -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
          <div class="flex flex-wrap items-start justify-between gap-4 mb-5">
            <div>
              <h3 class="font-semibold text-gray-800 mb-1">Red de estaciones Meteostat</h3>
              <p id="stations-count" class="text-sm text-gray-400">Introduce coordenadas y radio para cargar estaciones.</p>
            </div>
          </div>
          <div id="meteostat-map" class="relative z-0 h-[440px] min-h-[360px] w-full rounded-xl border border-gray-100 overflow-hidden bg-slate-100"></div>
        </div>

        <!-- Stats y preview -->
        <div id="data-panel" class="hidden space-y-6">
          <!-- Stats -->
          <div class="grid md:grid-cols-4 gap-4">
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">Estación</p>
              <p id="stat-wmo" class="text-xl font-bold text-gray-900">—</p>
            </div>
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">Registros</p>
              <p id="stat-rows" class="text-xl font-bold text-gray-900">—</p>
            </div>
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">Inicio</p>
              <p id="stat-start" class="text-xl font-bold text-gray-900">—</p>
            </div>
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">Fin</p>
              <p id="stat-end" class="text-xl font-bold text-gray-900">—</p>
            </div>
          </div>

          <!-- Tabla de preview -->
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 overflow-x-auto">
            <h3 class="font-semibold text-gray-800 mb-4">Vista previa (primeras 500 filas)</h3>
            <table id="data-table" class="w-full text-sm text-left border-collapse">
              <thead id="data-thead" class="text-xs text-gray-500 uppercase tracking-wide border-b border-gray-100"></thead>
              <tbody id="data-tbody" class="divide-y divide-gray-50"></tbody>
            </table>
          </div>
        </div>

        <div id="loading-msg" class="hidden text-center py-16 text-gray-400">
          <div class="inline-block h-8 w-8 animate-spin rounded-full border-4 border-hydra-300 border-t-hydra-600 mb-4"></div>
          <p class="font-medium">Cargando datos de Meteostat…</p>
        </div>
      </main>
    </div>
  </div>
</Layout>

<style>
  :global(.leaflet-popup-content-wrapper) { border-radius: 8px; }
  :global(.leaflet-container) { font-family: Inter, system-ui, sans-serif; }
</style>

<script>
declare const L: any;

type MeteoStation = {
  wmo: string;
  name: string;
  country: string;
  region: string;
  latitude: number;
  longitude: number;
  elevation: number | null;
  icao: string;
};

const searchLatEl = document.getElementById('search-lat') as HTMLInputElement;
const searchLonEl = document.getElementById('search-lon') as HTMLInputElement;
const searchRadiusEl = document.getElementById('search-radius') as HTMLInputElement;
const searchBtn = document.getElementById('search-btn')!;
const selectedNameEl = document.getElementById('selected-name')!;
const selectedMetaEl = document.getElementById('selected-meta')!;
const selectedWmoEl = document.getElementById('selected-wmo') as HTMLInputElement;
const startDateEl = document.getElementById('start-date') as HTMLInputElement;
const endDateEl = document.getElementById('end-date') as HTMLInputElement;
const loadBtn = document.getElementById('load-btn')!;
const downloadBtn = document.getElementById('download-btn') as HTMLButtonElement;
const errorBox = document.getElementById('error-box')!;
const stationsCountEl = document.getElementById('stations-count')!;
const dataPanel = document.getElementById('data-panel')!;
const loadingMsg = document.getElementById('loading-msg')!;

let map: any = null;
const stationMarkers: any[] = [];
let selectedStation: MeteoStation | null = null;
let lastData: { wmo: string; start: string; end: string; freq: string } | null = null;

function showError(msg: string) {
  errorBox.textContent = msg;
  errorBox.classList.remove('hidden');
}
function clearError() {
  errorBox.textContent = '';
  errorBox.classList.add('hidden');
}
function freq(): string {
  return (document.querySelector('input[name="freq"]:checked') as HTMLInputElement)?.value ?? 'daily';
}

function initMap() {
  const mapEl = document.getElementById('meteostat-map');
  if (!mapEl || typeof L === 'undefined') return;
  map = L.map('meteostat-map', { scrollWheelZoom: false }).setView([40.4, -3.7], 6);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 18,
    attribution: '&copy; OpenStreetMap',
  }).addTo(map);
  window.setTimeout(() => map.invalidateSize(), 0);
  window.addEventListener('resize', () => map.invalidateSize());
}

function clearMarkers() {
  stationMarkers.forEach(m => m.remove());
  stationMarkers.length = 0;
}

function markerStyle(active = false) {
  return {
    radius: active ? 9 : 6,
    color: active ? '#0f172a' : '#ffffff',
    weight: active ? 3 : 2,
    fillColor: active ? '#22d3ee' : '#0891b2',
    fillOpacity: 0.92,
  };
}

function selectStation(st: MeteoStation) {
  selectedStation = st;
  selectedNameEl.textContent = st.name;
  selectedMetaEl.textContent = `WMO ${st.wmo} · ${st.latitude.toFixed(3)}, ${st.longitude.toFixed(3)}${st.elevation != null ? ` · ${st.elevation} m` : ''} · ${st.country}`;
  selectedWmoEl.value = st.wmo;
  stationMarkers.forEach(m => {
    if (m._stData?.wmo === st.wmo) {
      m.setStyle(markerStyle(true));
    } else {
      m.setStyle(markerStyle(false));
    }
  });
}

async function searchStations() {
  clearError();
  const lat = parseFloat(searchLatEl.value);
  const lon = parseFloat(searchLonEl.value);
  const radius = parseFloat(searchRadiusEl.value);
  if (isNaN(lat) || isNaN(lon) || isNaN(radius)) {
    showError('Introduce coordenadas y radio válidos.');
    return;
  }
  searchBtn.textContent = 'Buscando…';
  searchBtn.setAttribute('disabled', '');
  try {
    const res = await fetch(`/api/meteostat/stations?lat=${lat}&lon=${lon}&radius=${radius}&limit=100`);
    const data = await res.json();
    if (!res.ok) throw new Error(data.detail ?? 'Error en la búsqueda');
    const stations: MeteoStation[] = data.stations ?? [];
    clearMarkers();
    stationsCountEl.textContent = `${stations.length} estaciones encontradas en un radio de ${radius} km.`;
    stations.forEach(st => {
      const m = L.circleMarker([st.latitude, st.longitude], markerStyle(false)).addTo(map);
      m._stData = st;
      m.bindPopup(`
        <div class="text-sm">
          <p class="font-semibold text-gray-900">${st.name}</p>
          <p class="text-gray-500">WMO ${st.wmo} · ${st.country}</p>
          <p class="text-gray-500">${st.latitude.toFixed(4)}, ${st.longitude.toFixed(4)}${st.elevation != null ? ` · ${st.elevation} m` : ''}</p>
          <button type="button" data-wmo="${st.wmo}"
            class="mt-2 rounded-md bg-cyan-500 px-3 py-1.5 text-xs font-semibold text-slate-950 w-full">
            Seleccionar estación
          </button>
        </div>
      `);
      m.on('click', () => selectStation(st));
      stationMarkers.push(m);
    });
    map.on('popupopen', (evt: any) => {
      const btn = evt.popup.getElement()?.querySelector('[data-wmo]');
      btn?.addEventListener('click', () => {
        const wmo = btn.getAttribute('data-wmo');
        const st = stations.find(s => s.wmo === wmo);
        if (st) { selectStation(st); map.closePopup(); }
      });
    });
    if (stations.length > 0) {
      const bounds = L.latLngBounds(stations.map((s: MeteoStation) => [s.latitude, s.longitude]));
      map.fitBounds(bounds, { padding: [24, 24], maxZoom: 10 });
    }
  } catch (err: any) {
    showError(err.message ?? 'Error desconocido');
  } finally {
    searchBtn.textContent = 'Buscar';
    searchBtn.removeAttribute('disabled');
  }
}

function renderTable(columns: string[], rows: Record<string, any>[]) {
  const thead = document.getElementById('data-thead')!;
  const tbody = document.getElementById('data-tbody')!;
  thead.innerHTML = '<tr>' + columns.map(c => `<th class="py-2 px-3 font-medium text-gray-500 whitespace-nowrap">${c}</th>`).join('') + '</tr>';
  tbody.innerHTML = rows.slice(0, 500).map(row =>
    '<tr>' + columns.map(c => `<td class="py-1.5 px-3 text-gray-700 whitespace-nowrap">${row[c] ?? ''}</td>`).join('') + '</tr>'
  ).join('');
}

async function loadData() {
  clearError();
  const wmo = selectedWmoEl.value;
  if (!wmo) { showError('Selecciona primero una estación en el mapa.'); return; }
  const start = startDateEl.value;
  const end = endDateEl.value;
  if (!start || !end || end < start) { showError('El periodo no es válido.'); return; }
  const f = freq();

  dataPanel.classList.add('hidden');
  loadingMsg.classList.remove('hidden');
  loadBtn.setAttribute('disabled', '');
  downloadBtn.disabled = true;

  try {
    const res = await fetch(`/api/meteostat/data?station=${encodeURIComponent(wmo)}&start=${start}&end=${end}&freq=${f}`);
    const data = await res.json();
    if (!res.ok) throw new Error(data.detail ?? 'Error cargando datos');

    document.getElementById('stat-wmo')!.textContent = wmo;
    document.getElementById('stat-rows')!.textContent = String(data.n_rows);
    document.getElementById('stat-start')!.textContent = start;
    document.getElementById('stat-end')!.textContent = end;
    renderTable(data.columns, data.preview);

    lastData = { wmo, start, end, freq: f };
    downloadBtn.disabled = false;
    dataPanel.classList.remove('hidden');
  } catch (err: any) {
    showError(err.message ?? 'Error desconocido');
  } finally {
    loadingMsg.classList.add('hidden');
    loadBtn.removeAttribute('disabled');
  }
}

async function downloadCsv() {
  if (!lastData) return;
  const { wmo, start, end, freq: f } = lastData;
  const url = `/api/meteostat/data?station=${encodeURIComponent(wmo)}&start=${start}&end=${end}&freq=${f}&download=true`;
  const a = document.createElement('a');
  a.href = url;
  a.download = `meteostat_${wmo}_${start}_${end}_${f}.csv`;
  a.click();
}

searchBtn.addEventListener('click', searchStations);
loadBtn.addEventListener('click', loadData);
downloadBtn.addEventListener('click', downloadCsv);

initMap();
</script>
