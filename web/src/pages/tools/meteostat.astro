---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Descarga Meteostat — HYDRA">
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />
  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
    is:inline
  ></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js" is:inline></script>

  <section class="pt-24 pb-10 bg-gradient-to-br from-slate-950 via-sky-950 to-cyan-800 text-white">
    <div class="max-w-7xl mx-auto px-6">
      <a href="/" class="inline-flex items-center gap-2 text-white/65 hover:text-white text-sm mb-6 transition-colors">
        ← Volver al inicio
      </a>
      <h1 class="text-4xl font-extrabold mb-2">Descarga Meteostat</h1>
      <p class="text-white/76 text-lg max-w-3xl">
        Busca estaciones meteorológicas en el mapa, selecciona periodo y variable, y descarga datos diarios o mensuales en CSV.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-6 py-10">
    <div class="grid lg:grid-cols-[340px_1fr] gap-8">

      <!-- ── PANEL DE CONTROL ── -->
      <aside class="space-y-6">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 space-y-5">

          <!-- Búsqueda por rectángulo -->
          <div>
            <label class="block text-sm font-semibold text-gray-800 mb-2">Zona de búsqueda</label>
            <button id="draw-btn"
              class="w-full bg-sky-600 hover:bg-sky-700 text-white font-semibold py-2 rounded-lg text-sm transition-colors flex items-center justify-center gap-2">
              <span id="draw-icon">⬛</span>
              <span id="draw-label">Dibujar zona en el mapa</span>
            </button>
            <p id="draw-hint" class="hidden mt-2 text-xs text-sky-700 bg-sky-50 border border-sky-100 rounded-lg px-3 py-2">
              Haz clic y arrastra sobre el mapa para definir la zona.
            </p>
            <div id="bbox-info" class="hidden mt-2 text-xs text-gray-500 bg-gray-50 rounded-lg px-3 py-2 space-y-0.5">
              <p id="bbox-text"></p>
            </div>
          </div>

          <!-- Estación seleccionada -->
          <div class="rounded-xl bg-sky-50 border border-sky-100 p-4">
            <p class="text-xs font-semibold text-sky-700 uppercase tracking-wide mb-1">Estación seleccionada</p>
            <p id="selected-name" class="font-semibold text-gray-900 text-sm">—</p>
            <p id="selected-meta" class="text-xs text-gray-500 mt-0.5">Haz clic en una estación del mapa</p>
            <input id="selected-wmo" type="hidden" value="" />
          </div>

          <!-- Fechas -->
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-semibold text-gray-800 mb-2" for="start-date">Inicio</label>
              <input id="start-date" type="date" value="2020-01-01"
                class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-hydra-400" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-800 mb-2" for="end-date">Fin</label>
              <input id="end-date" type="date" value="2023-12-31"
                class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-hydra-400" />
            </div>
          </div>

          <!-- Frecuencia -->
          <div>
            <label class="block text-sm font-semibold text-gray-800 mb-2">Frecuencia</label>
            <div class="flex gap-2">
              <label class="flex-1 flex items-center justify-center gap-2 rounded-lg border border-gray-200 py-2 text-sm cursor-pointer has-[:checked]:border-hydra-500 has-[:checked]:bg-hydra-50 dark:has-[:checked]:bg-hydra-900/20 dark:has-[:checked]:border-hydra-400 dark:text-gray-200">
                <input type="radio" name="freq" value="daily" checked class="accent-hydra-600" />
                Diaria
              </label>
              <label class="flex-1 flex items-center justify-center gap-2 rounded-lg border border-gray-200 py-2 text-sm cursor-pointer has-[:checked]:border-hydra-500 has-[:checked]:bg-hydra-50 dark:has-[:checked]:bg-hydra-900/20 dark:has-[:checked]:border-hydra-400 dark:text-gray-200">
                <input type="radio" name="freq" value="monthly" class="accent-hydra-600" />
                Mensual
              </label>
            </div>
          </div>

          <button id="load-btn"
            class="w-full bg-hydra-600 hover:bg-hydra-700 text-white font-semibold py-3 rounded-xl transition-colors">
            Cargar datos
          </button>
          <button id="download-btn" disabled
            class="w-full border border-gray-200 text-gray-400 font-semibold py-3 rounded-xl transition-colors disabled:opacity-50 disabled:cursor-not-allowed hover:not-disabled:border-hydra-300">
            Descargar CSV
          </button>
          <div id="error-box" class="hidden bg-red-50 border border-red-200 rounded-lg p-3 text-sm text-red-700"></div>
        </div>

        <div class="bg-sky-50 border border-sky-100 rounded-2xl p-5 text-sm text-sky-900 space-y-2">
          <p class="font-semibold">Integración HYDRA</p>
          <p>Usa <code class="text-sky-700 break-all">pyhydra.data_sources.rainfall.meteostat</code> para reproducir esta descarga en Python con el mismo periodo y estación.</p>
        </div>
      </aside>

      <!-- ── PANEL PRINCIPAL ── -->
      <main class="space-y-8 min-w-0">

        <!-- Mapa -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
          <div class="flex flex-wrap items-start justify-between gap-4 mb-5">
            <div>
              <h3 class="font-semibold text-gray-800 mb-1">Red de estaciones Meteostat</h3>
              <p id="stations-count" class="text-sm text-gray-400">Introduce coordenadas y radio para cargar estaciones.</p>
            </div>
          </div>
          <div id="meteostat-map" class="relative z-0 h-[440px] min-h-[360px] w-full rounded-xl border border-gray-100 overflow-hidden bg-slate-100"></div>
        </div>

        <!-- Stats y preview -->
        <div id="data-panel" class="hidden space-y-6">
          <!-- Stats -->
          <div class="grid md:grid-cols-4 gap-4">
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">Estación</p>
              <p id="stat-wmo" class="text-xl font-bold text-gray-900">—</p>
            </div>
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">Registros</p>
              <p id="stat-rows" class="text-xl font-bold text-gray-900">—</p>
            </div>
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">Inicio</p>
              <p id="stat-start" class="text-xl font-bold text-gray-900">—</p>
            </div>
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">Fin</p>
              <p id="stat-end" class="text-xl font-bold text-gray-900">—</p>
            </div>
          </div>

          <!-- Gráfica -->
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 space-y-4">
            <div>
              <h3 class="font-semibold text-gray-800 mb-3">Visualización de variables</h3>
              <p class="text-xs text-gray-400 mb-3">Activa/desactiva variables. Eje izquierdo = primera variable activa · Eje derecho = segunda.</p>
              <div id="var-toggles" class="flex flex-wrap gap-2"></div>
            </div>
            <div class="relative" style="height:380px">
              <canvas id="data-chart"></canvas>
            </div>
          </div>
        </div>

        <div id="loading-msg" class="hidden text-center py-16 text-gray-400">
          <div class="inline-block h-8 w-8 animate-spin rounded-full border-4 border-hydra-300 border-t-hydra-600 mb-4"></div>
          <p class="font-medium">Cargando datos de Meteostat…</p>
        </div>
      </main>
    </div>
  </div>
</Layout>

<style>
  :global(.leaflet-popup-content-wrapper) { border-radius: 8px; }
  :global(.leaflet-container) { font-family: Inter, system-ui, sans-serif; }
  :global(html.dark) label:has(input[name="freq"]:checked) {
    background-color: rgba(20, 184, 166, 0.15) !important;
    border-color: rgba(45, 212, 191, 0.8) !important;
    color: #e5e7eb !important;
  }
</style>

<script>
declare const L: any;
declare const Chart: any;

type MeteoStation = {
  wmo: string;
  name: string;
  country: string;
  region: string;
  latitude: number;
  longitude: number;
  elevation: number | null;
  icao: string;
};

// DOM refs
const drawBtn       = document.getElementById('draw-btn')!;
const drawLabel     = document.getElementById('draw-label')!;
const drawHint      = document.getElementById('draw-hint')!;
const bboxInfo      = document.getElementById('bbox-info')!;
const bboxText      = document.getElementById('bbox-text')!;
const selectedNameEl  = document.getElementById('selected-name')!;
const selectedMetaEl  = document.getElementById('selected-meta')!;
const selectedWmoEl   = document.getElementById('selected-wmo') as HTMLInputElement;
const startDateEl   = document.getElementById('start-date') as HTMLInputElement;
const endDateEl     = document.getElementById('end-date') as HTMLInputElement;
const loadBtn       = document.getElementById('load-btn')!;
const downloadBtn   = document.getElementById('download-btn') as HTMLButtonElement;
const errorBox      = document.getElementById('error-box')!;
const stationsCountEl = document.getElementById('stations-count')!;
const dataPanel     = document.getElementById('data-panel')!;
const loadingMsg    = document.getElementById('loading-msg')!;

let map: any = null;
const stationMarkers: any[] = [];
let allStations: MeteoStation[] = [];
let lastData: { wmo: string; start: string; end: string; freq: string } | null = null;
let chart: any = null;
let chartRows: Record<string, any>[] = [];
let activeVars: Set<string> = new Set();

const PALETTE = ['#0891b2','#f97316','#10b981','#8b5cf6','#ef4444','#f59e0b','#06b6d4','#ec4899'];

function buildVarToggles(columns: string[]) {
  const numCols = columns.filter(c => c !== 'date' && c !== 'fecha' && c !== 'hora');
  const container = document.getElementById('var-toggles')!;
  container.innerHTML = '';
  activeVars.clear();
  numCols.forEach((col, i) => {
    const color = PALETTE[i % PALETTE.length];
    const on = i < 4;
    if (on) activeVars.add(col);
    const btn = document.createElement('button');
    btn.className = 'var-btn px-3 py-1.5 rounded-full text-xs font-semibold border-2 transition-all cursor-pointer';
    btn.textContent = col;
    const setStyle = (active: boolean) => {
      btn.style.borderColor = color;
      btn.style.backgroundColor = active ? color + '22' : 'transparent';
      btn.style.color = active ? color : '#9ca3af';
    };
    setStyle(on);
    btn.addEventListener('click', () => {
      const has = activeVars.has(col);
      if (has) activeVars.delete(col); else activeVars.add(col);
      setStyle(!has);
      renderChart();
    });
    container.appendChild(btn);
  });
}

function renderChart() {
  if (!chartRows.length || !activeVars.size) return;
  const isDark = document.documentElement.classList.contains('dark');
  const gridColor  = isDark ? 'rgba(148,163,184,0.12)' : 'rgba(0,0,0,0.07)';
  const tickColor  = isDark ? '#94a3b8' : '#6b7280';
  const labels = chartRows.map(r => r.date ?? r.fecha ?? '');
  const varList = [...activeVars];
  const datasets = varList.map((col, i) => ({
    label: col,
    data: chartRows.map(r => (r[col] !== null && r[col] !== undefined ? Number(r[col]) : null)),
    borderColor:     PALETTE[i % PALETTE.length],
    backgroundColor: PALETTE[i % PALETTE.length] + '18',
    borderWidth: 1.5,
    pointRadius: chartRows.length > 90 ? 0 : 3,
    tension: 0.3,
    yAxisID: i === 0 ? 'yL' : 'yR',
    spanGaps: true,
  }));
  if (chart) { chart.destroy(); chart = null; }
  const ctx = (document.getElementById('data-chart') as HTMLCanvasElement).getContext('2d')!;
  chart = new Chart(ctx, {
    type: 'line',
    data: { labels, datasets },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      interaction: { mode: 'index', intersect: false },
      plugins: { legend: { display: false } },
      scales: {
        x:  { ticks: { maxTicksLimit: 10, maxRotation: 0, color: tickColor }, grid: { color: gridColor } },
        yL: { type: 'linear', position: 'left',
               title: { display: true, text: varList[0] ?? '', color: tickColor },
               ticks: { color: tickColor }, grid: { color: gridColor } },
        ...(varList.length > 1 ? { yR: {
          type: 'linear', position: 'right',
          title: { display: true, text: varList[1], color: tickColor },
          ticks: { color: tickColor }, grid: { drawOnChartArea: false },
        } } : {}),
      },
    },
  });
}

// Draw state
let drawMode = false;
let drawStart: any = null;
let drawRect: any = null;
let currentBbox: { latMin: number; latMax: number; lonMin: number; lonMax: number } | null = null;

function showError(msg: string) {
  errorBox.textContent = msg;
  errorBox.classList.remove('hidden');
}
function clearError() {
  errorBox.textContent = '';
  errorBox.classList.add('hidden');
}
function freq(): string {
  return (document.querySelector('input[name="freq"]:checked') as HTMLInputElement)?.value ?? 'daily';
}

// Exposed globally so popup buttons can call it inline
(window as any).__meteoSelectWmo = (wmo: string) => {
  const st = allStations.find(s => s.wmo === wmo);
  if (st) { selectStation(st); map?.closePopup(); }
};

function initMap() {
  const mapEl = document.getElementById('meteostat-map');
  if (!mapEl || typeof L === 'undefined') return;
  map = L.map('meteostat-map', { scrollWheelZoom: false }).setView([40.4, -3.7], 6);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 18,
    attribution: '&copy; OpenStreetMap',
  }).addTo(map);
  window.setTimeout(() => map.invalidateSize(), 0);
  window.addEventListener('resize', () => map.invalidateSize());

  // Rectangle drawing events
  map.on('mousedown', (e: any) => {
    if (!drawMode) return;
    e.originalEvent.preventDefault();
    drawStart = e.latlng;
    if (drawRect) { drawRect.remove(); drawRect = null; }
    drawRect = L.rectangle([drawStart, drawStart], {
      color: '#0891b2', weight: 2, dashArray: '6 3', fillOpacity: 0.08, interactive: false,
    }).addTo(map);
  });

  map.on('mousemove', (e: any) => {
    if (!drawMode || !drawStart) return;
    drawRect?.setBounds(L.latLngBounds(drawStart, e.latlng));
  });

  map.on('mouseup', (e: any) => {
    if (!drawMode || !drawStart) return;
    const bounds = L.latLngBounds(drawStart, e.latlng);
    drawStart = null;
    exitDrawMode();
    if (Math.abs(bounds.getNorth() - bounds.getSouth()) < 0.05 ||
        Math.abs(bounds.getEast() - bounds.getWest()) < 0.05) {
      showError('El rectángulo es demasiado pequeño. Arrastra más para definir la zona.');
      drawRect?.remove(); drawRect = null;
      return;
    }
    currentBbox = {
      latMin: bounds.getSouth(),
      latMax: bounds.getNorth(),
      lonMin: bounds.getWest(),
      lonMax: bounds.getEast(),
    };
    bboxText.textContent =
      `N ${currentBbox.latMax.toFixed(2)}  S ${currentBbox.latMin.toFixed(2)}  ` +
      `W ${currentBbox.lonMin.toFixed(2)}  E ${currentBbox.lonMax.toFixed(2)}`;
    bboxInfo.classList.remove('hidden');
    searchStations();
  });
}

function enterDrawMode() {
  drawMode = true;
  drawLabel.textContent = 'Cancelar dibujo';
  drawBtn.classList.remove('bg-sky-600', 'hover:bg-sky-700');
  drawBtn.classList.add('bg-amber-500', 'hover:bg-amber-600');
  drawHint.classList.remove('hidden');
  map.dragging.disable();
  map.getContainer().style.cursor = 'crosshair';
}

function exitDrawMode() {
  drawMode = false;
  drawLabel.textContent = 'Dibujar zona en el mapa';
  drawBtn.classList.remove('bg-amber-500', 'hover:bg-amber-600');
  drawBtn.classList.add('bg-sky-600', 'hover:bg-sky-700');
  drawHint.classList.add('hidden');
  map.dragging.enable();
  map.getContainer().style.cursor = '';
  drawStart = null;
}

function clearMarkers() {
  stationMarkers.forEach(m => m.remove());
  stationMarkers.length = 0;
}

function markerStyle(active = false) {
  return {
    radius: active ? 9 : 6,
    color: active ? '#0f172a' : '#ffffff',
    weight: active ? 3 : 2,
    fillColor: active ? '#22d3ee' : '#0891b2',
    fillOpacity: 0.92,
  };
}

function selectStation(st: MeteoStation) {
  selectedNameEl.textContent = st.name;
  selectedMetaEl.textContent =
    `WMO ${st.wmo} · ${st.latitude.toFixed(3)}, ${st.longitude.toFixed(3)}` +
    `${st.elevation != null ? ` · ${st.elevation} m` : ''} · ${st.country}`;
  selectedWmoEl.value = st.wmo;
  stationMarkers.forEach(m =>
    m.setStyle(markerStyle(m._stData?.wmo === st.wmo))
  );
}

async function searchStations() {
  if (!currentBbox) { showError('Dibuja primero una zona en el mapa.'); return; }
  clearError();
  const { latMin, latMax, lonMin, lonMax } = currentBbox;
  const drawBtnEl = drawBtn as HTMLButtonElement;
  drawBtnEl.setAttribute('disabled', '');
  stationsCountEl.textContent = 'Buscando estaciones…';
  try {
    const url = `/api/meteostat/stations?lat_min=${latMin}&lat_max=${latMax}&lon_min=${lonMin}&lon_max=${lonMax}&limit=200`;
    const res = await fetch(url);
    let data: any = {};
    try { data = await res.json(); } catch { /* non-JSON */ }
    if (!res.ok) throw new Error(data.detail ?? `Error ${res.status}: ${res.statusText}`);
    allStations = data.stations ?? [];
    clearMarkers();
    if (drawRect) { drawRect.remove(); drawRect = null; }
    stationsCountEl.textContent = `${allStations.length} estaciones encontradas.`;
    allStations.forEach(st => {
      const m = L.circleMarker([st.latitude, st.longitude], markerStyle(false)).addTo(map);
      m._stData = st;
      m.bindPopup(`
        <div style="min-width:180px;font-size:13px">
          <p style="font-weight:600;margin:0 0 2px">${st.name}</p>
          <p style="color:#6b7280;margin:0 0 2px">WMO ${st.wmo} · ${st.country}</p>
          <p style="color:#6b7280;margin:0 0 8px">${st.latitude.toFixed(4)}, ${st.longitude.toFixed(4)}${st.elevation != null ? ` · ${st.elevation} m` : ''}</p>
          <button type="button"
            onclick="window.__meteoSelectWmo('${st.wmo}')"
            style="width:100%;background:#06b6d4;color:#0f172a;font-weight:600;font-size:12px;padding:6px 10px;border-radius:6px;border:none;cursor:pointer">
            Seleccionar estación
          </button>
        </div>
      `);
      m.on('click', () => selectStation(st));
      stationMarkers.push(m);
    });
    if (allStations.length > 0) {
      const bounds = L.latLngBounds(allStations.map((s: MeteoStation) => [s.latitude, s.longitude]));
      map.fitBounds(bounds, { padding: [24, 24], maxZoom: 10 });
    }
  } catch (err: any) {
    showError(err.message ?? 'Error desconocido');
    stationsCountEl.textContent = 'Error en la búsqueda.';
  } finally {
    drawBtnEl.removeAttribute('disabled');
  }
}

async function loadData() {
  clearError();
  const wmo = selectedWmoEl.value;
  if (!wmo) { showError('Selecciona primero una estación en el mapa.'); return; }
  const start = startDateEl.value;
  const end = endDateEl.value;
  if (!start || !end || end < start) { showError('El periodo no es válido.'); return; }
  const f = freq();

  dataPanel.classList.add('hidden');
  loadingMsg.classList.remove('hidden');
  loadBtn.setAttribute('disabled', '');
  downloadBtn.disabled = true;

  try {
    const res = await fetch(
      `/api/meteostat/data?station=${encodeURIComponent(wmo)}&start=${start}&end=${end}&freq=${f}`
    );
    let data: any = {};
    try { data = await res.json(); } catch { /* non-JSON */ }
    if (!res.ok) throw new Error(data.detail ?? `Error ${res.status}: ${res.statusText}`);

    document.getElementById('stat-wmo')!.textContent = wmo;
    document.getElementById('stat-rows')!.textContent = String(data.n_rows);
    document.getElementById('stat-start')!.textContent = start;
    document.getElementById('stat-end')!.textContent = end;
    chartRows = data.preview;
    buildVarToggles(data.columns);
    renderChart();

    lastData = { wmo, start, end, freq: f };
    downloadBtn.disabled = false;
    dataPanel.classList.remove('hidden');
  } catch (err: any) {
    showError(err.message ?? 'Error desconocido');
  } finally {
    loadingMsg.classList.add('hidden');
    loadBtn.removeAttribute('disabled');
  }
}

async function downloadCsv() {
  if (!lastData) return;
  const { wmo, start, end, freq: f } = lastData;
  const url =
    `/api/meteostat/data?station=${encodeURIComponent(wmo)}&start=${start}&end=${end}&freq=${f}&download=true`;
  const a = document.createElement('a');
  a.href = url;
  a.download = `meteostat_${wmo}_${start}_${end}_${f}.csv`;
  a.click();
}

drawBtn.addEventListener('click', () => {
  if (!map) return;
  if (drawMode) { exitDrawMode(); } else { enterDrawMode(); }
});
loadBtn.addEventListener('click', loadData);
downloadBtn.addEventListener('click', downloadCsv);

initMap();
</script>
