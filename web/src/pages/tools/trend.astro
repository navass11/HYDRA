---
import Layout from '../../layouts/Layout.astro';
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<Layout title="Análisis de tendencia — HYDRA">
  <script src="https://cdn.plot.ly/plotly-2.32.0.min.js" is:inline></script>

  <section class="pt-24 pb-10 bg-gradient-to-br from-slate-950 via-rose-950 to-rose-700 text-white">
    <div class="max-w-7xl mx-auto px-6">
      <a href="/" data-i18n="back.home" class="inline-flex items-center gap-2 text-white/65 hover:text-white text-sm mb-6 transition-colors">
        ← Volver al inicio
      </a>
      <h1 class="text-4xl font-extrabold mb-2" data-t-es="Análisis de tendencia" data-t-en="Trend Analysis">Análisis de tendencia</h1>
      <p class="text-white/75 text-lg max-w-3xl" data-t-es="Mann-Kendall, punto de cambio de Pettitt y pendiente de Sen sobre series anuales o mensuales. Detecta tendencias significativas y cambios estructurales." data-t-en="Mann-Kendall, Pettitt change point and Sen slope on annual or monthly series. Detects significant trends and structural changes.">
        Mann-Kendall, punto de cambio de Pettitt y pendiente de Sen sobre series anuales o mensuales. Detecta tendencias significativas y cambios estructurales.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-6 py-10" id="app" data-api-url={apiUrl}>
    <div class="grid lg:grid-cols-[320px_1fr] gap-8">

      <aside class="space-y-6">
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm p-6 space-y-6">
          <div>
            <h3 class="font-semibold text-gray-800 dark:text-slate-200 mb-3 text-sm uppercase tracking-wide" data-t-es="Datos" data-t-en="Data">Datos</h3>
            <div class="grid grid-cols-2 gap-2 mb-3">
              <button id="btn-demo" class="src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 border-rose-500 bg-rose-50 text-rose-700 dark:bg-rose-900/30 dark:text-rose-300">Demo</button>
              <button id="btn-upload" class="src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 border-gray-200 dark:border-slate-600 text-gray-600 dark:text-slate-400 hover:border-rose-300 transition-colors" data-t-es="Subir CSV" data-t-en="Upload CSV">Subir CSV</button>
            </div>
            <input type="file" id="file-input" accept=".csv" class="hidden" />
            <p id="file-name" class="text-xs text-gray-400 dark:text-slate-500 italic">Demo: precipitación anual 1974-2023 con tendencia positiva</p>
            <div id="csv-hint" class="hidden mt-2 text-xs text-gray-500 dark:text-slate-400 bg-gray-50 dark:bg-slate-700 rounded-lg p-3" data-t-es="CSV: dos columnas año, valor (o fecha parseable, valor). Datos anuales o mensuales." data-t-en="CSV: two columns year, value (or parseable date, value). Annual or monthly data.">
              CSV: dos columnas <code class="text-rose-600 dark:text-rose-300">año, valor</code> (o fecha parseable, valor). Datos anuales o mensuales.
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-800 dark:text-slate-200 mb-2" for="variable-select" data-t-es="Variable" data-t-en="Variable">Variable</label>
            <select id="variable-select" class="w-full rounded-lg border border-gray-200 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-rose-400">
              <option value="precipitation" data-t-es="Precipitación" data-t-en="Precipitation">Precipitación</option>
              <option value="temperature" data-t-es="Temperatura" data-t-en="Temperature">Temperatura</option>
              <option value="discharge" data-t-es="Caudal" data-t-en="Discharge">Caudal</option>
              <option value="other" data-t-es="Otra" data-t-en="Other">Otra</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-800 dark:text-slate-200 mb-2" for="aggregation-select" data-t-es="Agregación" data-t-en="Aggregation">Agregación</label>
            <select id="aggregation-select" class="w-full rounded-lg border border-gray-200 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-rose-400">
              <option value="annual" data-t-es="Anual" data-t-en="Annual">Anual</option>
              <option value="monthly" data-t-es="Mensual" data-t-en="Monthly">Mensual</option>
            </select>
          </div>

          <button id="run-btn" class="w-full bg-rose-600 hover:bg-rose-700 text-white font-semibold py-3 rounded-xl transition-colors flex items-center justify-center gap-2">
            <span id="run-label" data-t-es="Analizar tendencia" data-t-en="Analyse trend">Analizar tendencia</span>
            <svg id="run-arrow" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
            <svg id="run-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
            </svg>
          </button>
          <div id="error-box" class="hidden bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-700 rounded-lg p-3 text-sm text-red-700 dark:text-red-300"></div>
        </div>

        <div id="test-results-panel" class="hidden bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm p-5 space-y-4">
          <h3 class="font-semibold text-gray-800 dark:text-slate-200 text-sm uppercase tracking-wide" data-t-es="Resultados" data-t-en="Results">Resultados</h3>
          <div id="mk-card" class="rounded-xl border p-4 space-y-1"></div>
          <div id="pettitt-card" class="rounded-xl border p-4 space-y-1"></div>
          <div id="sen-card" class="rounded-xl border bg-gray-50 dark:bg-slate-700 p-4 space-y-1"></div>
        </div>
      </aside>

      <main>
        <div id="placeholder" class="min-h-[430px] flex flex-col items-center justify-center text-center rounded-2xl border-2 border-dashed border-gray-200 dark:border-slate-700 p-12">
          <div class="w-16 h-16 rounded-2xl bg-rose-100 dark:bg-rose-900/40 text-rose-800 dark:text-rose-300 flex items-center justify-center mb-4">
            <svg class="w-9 h-9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <polyline points="3,18 7,12 11,14 15,9 19,7"/>
              <line x1="3" y1="18" x2="21" y2="18" stroke-width="1.2"/>
              <line x1="21" y1="7" x2="21" y2="18" stroke-width="1.2" stroke-dasharray="2 2"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-700 dark:text-slate-300 mb-2" data-t-es="Listo para analizar" data-t-en="Ready to analyse">Listo para analizar</h3>
          <p class="text-gray-400 dark:text-slate-500 max-w-md" data-t-es="Ejecuta la demo o sube una serie anual para detectar tendencias y cambios." data-t-en="Run the demo or upload an annual series to detect trends and changes.">Ejecuta la demo o sube una serie anual para detectar tendencias y cambios.</p>
        </div>

        <div id="results" class="hidden space-y-8">
          <div id="stats-row" class="grid grid-cols-2 lg:grid-cols-4 gap-4"></div>

          <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm p-6">
            <h3 class="font-semibold text-gray-800 dark:text-slate-200 mb-1" data-t-es="Serie temporal con tendencia de Sen" data-t-en="Time series with Sen slope">Serie temporal con tendencia de Sen</h3>
            <p class="text-sm text-gray-400 dark:text-slate-500 mb-4" data-t-es="Línea continua = pendiente de Sen. Línea vertical = punto de cambio Pettitt (si significativo)." data-t-en="Solid line = Sen slope. Vertical line = Pettitt change point (if significant).">Línea continua = pendiente de Sen. Línea vertical = punto de cambio Pettitt (si significativo).</p>
            <div id="chart-series" class="h-96"></div>
          </div>
        </div>
      </main>
    </div>
  </div>
</Layout>

<script>
declare const Plotly: any;

const t = (es: string, en: string) => document.documentElement.lang === 'en' ? en : es;

const ROSE   = '#e11d48';
const SLATE  = '#475569';
const AMBER  = '#d97706';

const isDark = () => document.documentElement.classList.contains('dark');
const grid = () => isDark() ? '#334155' : '#e2e8f0';
const fontColor = () => isDark() ? '#94a3b8' : '#6b7280';

const layoutBase = {
  paper_bgcolor: 'transparent',
  plot_bgcolor:  'transparent',
  margin: { t: 20, r: 16, b: 52, l: 64 },
  font: { family: 'Inter, system-ui, sans-serif', size: 11 },
};

let useDemo = true;
let isRunning = false;

const appEl        = document.getElementById('app')!;
const apiUrl       = appEl.dataset.apiUrl!;
const btnDemo      = document.getElementById('btn-demo')!;
const btnUpload    = document.getElementById('btn-upload')!;
const fileInput    = document.getElementById('file-input') as HTMLInputElement;
const fileNameEl   = document.getElementById('file-name')!;
const csvHintEl    = document.getElementById('csv-hint')!;
const runBtn       = document.getElementById('run-btn')!;
const runLabel     = document.getElementById('run-label')!;
const runArrow     = document.getElementById('run-arrow')!;
const runSpinner   = document.getElementById('run-spinner')!;
const errorBox     = document.getElementById('error-box')!;
const placeholder  = document.getElementById('placeholder')!;
const resultsEl    = document.getElementById('results')!;
const testPanel    = document.getElementById('test-results-panel')!;

function setSource(demo: boolean) {
  useDemo = demo;
  btnDemo.className   = `src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 transition-colors ${demo ? 'border-rose-500 bg-rose-50 text-rose-700' : 'border-gray-200 text-gray-600 hover:border-rose-300'}`;
  btnUpload.className = `src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 transition-colors ${!demo ? 'border-rose-500 bg-rose-50 text-rose-700' : 'border-gray-200 text-gray-600 hover:border-rose-300'}`;
  csvHintEl.classList.toggle('hidden', demo);
  if (demo) fileNameEl.textContent = t('Demo: precipitación anual 1974-2023 con tendencia positiva', 'Demo: annual precipitation 1974–2023 with positive trend');
}

function setRunning(r: boolean) {
  isRunning = r;
  (runBtn as HTMLButtonElement).disabled = r;
  runLabel.textContent = r ? t('Analizando...', 'Analysing...') : t('Analizar tendencia', 'Analyse trend');
  runArrow.classList.toggle('hidden', r);
  runSpinner.classList.toggle('hidden', !r);
}

function showError(msg: string) { errorBox.textContent = msg; errorBox.classList.remove('hidden'); }
function clearError() { errorBox.classList.add('hidden'); errorBox.textContent = ''; }

btnDemo.addEventListener('click', () => setSource(true));
btnUpload.addEventListener('click', () => fileInput.click());
fileInput.addEventListener('change', () => {
  if (fileInput.files?.[0]) { setSource(false); fileNameEl.textContent = fileInput.files[0].name; }
});

runBtn.addEventListener('click', async () => {
  if (isRunning) return;
  clearError();
  if (!useDemo && !fileInput.files?.[0]) { showError(t('Selecciona un CSV o vuelve a usar los datos demo.', 'Select a CSV or switch back to demo data.')); return; }
  setRunning(true);

  const fd = new FormData();
  fd.append('demo',        useDemo ? 'true' : 'false');
  fd.append('variable',    (document.getElementById('variable-select') as HTMLSelectElement).value);
  fd.append('aggregation', (document.getElementById('aggregation-select') as HTMLSelectElement).value);
  if (!useDemo && fileInput.files?.[0]) fd.append('file', fileInput.files[0]);

  try {
    const res = await fetch(`${apiUrl}/api/trend/analyze`, { method: 'POST', body: fd });
    if (!res.ok) { const err = await res.json(); throw new Error(err.detail ?? t('Error en el servidor', 'Server error')); }
    renderResults(await res.json());
  } catch (err: any) {
    showError(err.message ?? t('Error desconocido', 'Unknown error'));
  } finally {
    setRunning(false);
  }
});

function badge(sig: boolean) {
  return sig
    ? `<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-rose-100 dark:bg-rose-900/50 text-rose-700 dark:text-rose-300">${t('Significativo p<0.05', 'Significant p<0.05')}</span>`
    : `<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 dark:bg-slate-700 text-gray-500 dark:text-slate-400">${t('No significativo', 'Not significant')}</span>`;
}

function statCard(label: string, value: string, unit = '', highlight = false) {
  const accent = highlight ? 'text-rose-600 dark:text-rose-400' : 'text-gray-900 dark:text-white';
  return `<div class="bg-gray-50 dark:bg-slate-800 rounded-xl p-4 border border-gray-100 dark:border-slate-700">
    <p class="text-xs text-gray-400 dark:text-slate-500 uppercase tracking-wide mb-2">${label}</p>
    <p class="text-2xl font-bold ${accent}">${value}</p>
    <p class="text-xs text-gray-400 dark:text-slate-500 mt-1">${unit}</p>
  </div>`;
}

function renderResults(data: any) {
  placeholder.classList.add('hidden');
  resultsEl.classList.remove('hidden');
  testPanel.classList.remove('hidden');

  const s   = data.summary;
  const mk  = data.mann_kendall;
  const pt  = data.pettitt;
  const sen = data.sens_slope;
  const lin = data.linear;

  document.getElementById('stats-row')!.innerHTML =
    statCard(t('Valores', 'Values'), `${s.n_values}`, `${s.start} – ${s.end}`) +
    statCard(t('Pendiente Sen', 'Sen slope'), `${sen.slope != null ? (sen.slope > 0 ? '+' : '') + sen.slope.toFixed(3) : '—'}`, t('unidades/año', 'units/year'), mk.significant) +
    statCard('Mann-Kendall τ', `${mk.tau}`, mk.trend) +
    statCard(t('p-valor MK', 'MK p-value'), `${mk.p_value}`, mk.significant ? t('significativo', 'significant') : t('no significativo', 'not significant'));

  // Side panel
  document.getElementById('mk-card')!.innerHTML = `
    <p class="text-xs font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wide mb-2">Mann-Kendall</p>
    <div class="flex items-center justify-between mb-1">
      <span class="text-sm text-gray-700 dark:text-slate-300">τ = <strong>${mk.tau}</strong></span>
      <span class="text-sm text-gray-500 dark:text-slate-400">p = ${mk.p_value}</span>
    </div>
    <p class="text-sm text-gray-700 dark:text-slate-300 mb-2 capitalize">${t('Tendencia:', 'Trend:')} <strong>${mk.trend}</strong></p>
    ${badge(mk.significant)}`;
  document.getElementById('mk-card')!.className =
    `rounded-xl border p-4 space-y-1 ${mk.significant ? 'border-rose-200 dark:border-rose-800 bg-rose-50 dark:bg-rose-950/40' : 'border-gray-100 dark:border-slate-700 bg-gray-50 dark:bg-slate-700/50'}`;

  const cpText = pt.change_year
    ? `${t('Año de cambio:', 'Change year:')} <strong>${pt.change_year}</strong>`
    : t('Sin cambio detectado', 'No change detected');
  document.getElementById('pettitt-card')!.innerHTML = `
    <p class="text-xs font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wide mb-2">Pettitt</p>
    <p class="text-sm text-gray-700 dark:text-slate-300 mb-1">${cpText}</p>
    <p class="text-sm text-gray-500 dark:text-slate-400 mb-2">p ≈ ${pt.p_value}</p>
    ${badge(pt.significant)}`;
  document.getElementById('pettitt-card')!.className =
    `rounded-xl border p-4 space-y-1 ${pt.significant ? 'border-amber-200 dark:border-amber-700 bg-amber-50 dark:bg-amber-950/40' : 'border-gray-100 dark:border-slate-700 bg-gray-50 dark:bg-slate-700/50'}`;

  document.getElementById('sen-card')!.innerHTML = `
    <p class="text-xs font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wide mb-2">${t('Pendiente de Sen', 'Sen Slope')}</p>
    <p class="text-sm text-gray-700 dark:text-slate-300">${t('Pendiente:', 'Slope:')} <strong>${sen.slope != null ? sen.slope.toFixed(4) : '—'}</strong> ${t('/año', '/year')}</p>
    <p class="text-sm text-gray-500 dark:text-slate-400">${t('IC 90%:', '90% CI:')} [${sen.slope_ci_low?.toFixed(4) ?? '—'}, ${sen.slope_ci_high?.toFixed(4) ?? '—'}]</p>
    <p class="text-sm text-gray-500 dark:text-slate-400">${t('Intercepto:', 'Intercept:')} ${sen.intercept?.toFixed(2) ?? '—'}</p>
    <p class="text-xs text-gray-400 dark:text-slate-500 mt-1">${t('Regresión lineal:', 'Linear regression:')} ${t('pendiente=', 'slope=')}${lin.slope?.toFixed(4) ?? '—'}, R²=${lin.r2?.toFixed(3) ?? '—'}</p>`;

  // Main chart
  const series = data.series as {date: string, value: number}[];
  const dates  = series.map(d => d.date);
  const values = series.map(d => d.value);

  const senLine = data.sen_line as {date: string, value: number}[];

  const traces: any[] = [
    { x: dates, y: values, mode: 'lines+markers', name: s.variable,
      line: { color: SLATE, width: 1.5 }, marker: { size: 5, color: SLATE } },
    { x: senLine.map(d => d.date), y: senLine.map(d => d.value),
      mode: 'lines', name: t('Pendiente Sen', 'Sen slope'),
      line: { color: ROSE, width: 2.5 } },
  ];

  const shapes: any[] = [];
  const annotations: any[] = [];

  if (pt.significant && pt.change_year) {
    shapes.push({
      type: 'line',
      x0: pt.change_year, x1: pt.change_year,
      y0: 0, y1: 1, yref: 'paper',
      line: { color: AMBER, width: 2, dash: 'dash' },
    });
    annotations.push({
      x: pt.change_year, y: 1, yref: 'paper',
      text: `Pettitt ${pt.change_year}`,
      showarrow: false, yanchor: 'bottom',
      font: { color: AMBER, size: 10 },
    });
  }

  Plotly.newPlot('chart-series', traces, {
    ...layoutBase,
    font: { ...layoutBase.font, color: fontColor() },
    shapes,
    annotations,
    xaxis: { title: t('Año', 'Year'), gridcolor: grid() },
    yaxis: { title: s.variable, gridcolor: grid() },
    legend: { orientation: 'h', y: -0.2 },
  }, { responsive: true, displayModeBar: false });
}
</script>
