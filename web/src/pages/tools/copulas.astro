---
import Layout from '../../layouts/Layout.astro';
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<Layout title="Cópulas de Eventos — HYDRA">
  <script src="https://cdn.plot.ly/plotly-2.32.0.min.js" is:inline></script>

  <section class="pt-24 pb-10 bg-gradient-to-br from-slate-950 via-violet-950 to-indigo-800 text-white">
    <div class="max-w-7xl mx-auto px-6">
      <a href="/" class="inline-flex items-center gap-2 text-white/65 hover:text-white text-sm mb-6 transition-colors" data-i18n="back.home">
        ← Volver al inicio
      </a>
      <h1 class="text-4xl font-extrabold mb-2">Cópulas multivariantes de eventos</h1>
      <p class="text-white/76 text-lg max-w-3xl">
        Ajusta una cópula a eventos hidrológicos, conserva dependencias entre variables y genera muestras sintéticas para análisis de escenarios.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-6 py-10" id="app" data-api-url={apiUrl}>
    <div class="grid lg:grid-cols-[350px_1fr] gap-8">
      <aside class="space-y-6">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 space-y-6">
          <div>
            <h3 class="font-semibold text-gray-800 mb-3 text-sm uppercase tracking-wide">Datos</h3>
            <div class="grid grid-cols-2 gap-2 mb-3">
              <button id="btn-demo" class="src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 border-hydra-500 bg-hydra-50 text-hydra-700">Demo</button>
              <button id="btn-upload" class="src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 border-gray-200 text-gray-600 hover:border-hydra-300 transition-colors">Subir CSV</button>
            </div>
            <input type="file" id="file-input" accept=".csv" class="hidden" />
            <p id="file-name" class="text-xs text-gray-400 italic">Demo: eventos Qmax, volumen, duración y estación</p>
            <div id="csv-hint" class="hidden mt-2 text-xs text-gray-500 bg-gray-50 rounded-lg p-3">
              CSV con columnas numéricas. Por defecto: <code class="text-hydra-700">Qmax, volume, duration, season</code>.
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-800 mb-2" for="continuous-vars">Variables continuas</label>
            <input id="continuous-vars" value="Qmax,volume,duration" class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-hydra-400" />
            <p class="text-xs text-gray-400 mt-1">Separadas por comas.</p>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-800 mb-2" for="discrete-vars">Variables discretas</label>
            <input id="discrete-vars" value="season" class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-hydra-400" />
          </div>

          <div>
            <label class="flex justify-between text-sm font-semibold text-gray-800 mb-2">
              Muestras sintéticas
              <span id="n-samples-val" class="text-hydra-600 font-bold">1000</span>
            </label>
            <input id="n-samples" type="range" min="100" max="5000" value="1000" step="100" class="w-full accent-hydra-600" />
          </div>

          <button id="run-btn" class="w-full bg-hydra-600 hover:bg-hydra-700 text-white font-semibold py-3 rounded-xl transition-colors flex items-center justify-center gap-2">
            <span id="run-label">Ajustar cópula</span>
            <svg id="run-arrow" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
            <svg id="run-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 0 0 12h4z"/>
            </svg>
          </button>
          <div id="error-box" class="hidden bg-red-50 border border-red-200 rounded-lg p-3 text-sm text-red-700"></div>
        </div>

        <div class="bg-violet-50 border border-violet-100 rounded-2xl p-5 text-sm text-violet-900 space-y-2">
          <p class="font-semibold">Método</p>
          <p>La herramienta usa <code class="text-violet-700">FloodEventCopula</code> de HYDRA para ajustar dependencias multivariantes y sintetizar eventos compatibles con la muestra observada.</p>
        </div>
      </aside>

      <main>
        <div id="placeholder" class="min-h-[430px] flex flex-col items-center justify-center text-center rounded-2xl border-2 border-dashed border-gray-200 p-12">
          <div class="w-16 h-16 rounded-2xl bg-violet-100 text-violet-800 flex items-center justify-center mb-4">
            <svg class="w-9 h-9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M4 19V5"/><path d="M4 19h16"/><path d="M7 16c3-8 7-8 10 0"/><path d="M7 10c3 8 7 8 10 0"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-700 mb-2">Listo para ajustar</h3>
          <p class="text-gray-400 max-w-md">Ejecuta la demo o sube eventos observados para comparar dependencias observadas y sintéticas.</p>
        </div>

        <div id="results" class="hidden space-y-8">
          <!-- Stats -->
          <div id="stats-row" class="grid grid-cols-2 lg:grid-cols-4 gap-4"></div>

          <!-- Scatter de todos los pares de variables continuas -->
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h3 class="font-semibold text-gray-800 mb-1">Observado vs sintético — dispersión por pares</h3>
            <p class="text-sm text-gray-400 mb-4">Todos los pares de variables continuas: puntos observados (verde oscuro) sobre nube sintética (violeta).</p>
            <div id="charts-pairs" class="grid gap-6"></div>
          </div>

          <!-- Distribuciones marginales -->
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h3 class="font-semibold text-gray-800 mb-1">Distribuciones marginales</h3>
            <p class="text-sm text-gray-400 mb-4">Histograma normalizado observado vs densidad sintética para cada variable continua.</p>
            <div id="charts-marginals" class="grid gap-6"></div>
          </div>

          <!-- Matrices de correlación -->
          <div class="grid lg:grid-cols-2 gap-8">
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
              <h3 class="font-semibold text-gray-800 mb-1">Correlación observada</h3>
              <div id="chart-corr-observed" class="h-72"></div>
            </div>
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
              <h3 class="font-semibold text-gray-800 mb-1">Correlación sintética</h3>
              <div id="chart-corr-synthetic" class="h-72"></div>
            </div>
          </div>

          <!-- Tabla de eventos sintéticos -->
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h3 class="font-semibold text-gray-800 mb-4">Primeros eventos sintéticos</h3>
            <div class="overflow-auto max-h-72">
              <table class="w-full text-sm">
                <thead id="synthetic-head" class="text-left text-gray-500"></thead>
                <tbody id="synthetic-body" class="divide-y divide-gray-100"></tbody>
              </table>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
</Layout>

<script>
declare const Plotly: any;

const layoutBase = {
  paper_bgcolor: 'transparent',
  plot_bgcolor: 'transparent',
  margin: { t: 20, r: 16, b: 48, l: 58 },
  font: { family: 'Inter, system-ui, sans-serif', size: 11 },
};

let useDemo = true;
let isRunning = false;

const appEl = document.getElementById('app')!;
const apiUrl = appEl.dataset.apiUrl!;
const btnDemo = document.getElementById('btn-demo')!;
const btnUpload = document.getElementById('btn-upload')!;
const fileInput = document.getElementById('file-input') as HTMLInputElement;
const fileNameEl = document.getElementById('file-name')!;
const csvHintEl = document.getElementById('csv-hint')!;
const sampleInput = document.getElementById('n-samples') as HTMLInputElement;
const sampleVal = document.getElementById('n-samples-val')!;
const runBtn = document.getElementById('run-btn')!;
const runLabel = document.getElementById('run-label')!;
const runArrow = document.getElementById('run-arrow')!;
const runSpinner = document.getElementById('run-spinner')!;
const errorBox = document.getElementById('error-box')!;
const placeholder = document.getElementById('placeholder')!;
const resultsEl = document.getElementById('results')!;

function setSource(demo: boolean) {
  useDemo = demo;
  btnDemo.className = `src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 transition-colors ${demo ? 'border-hydra-500 bg-hydra-50 text-hydra-700' : 'border-gray-200 text-gray-600 hover:border-hydra-300'}`;
  btnUpload.className = `src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 transition-colors ${!demo ? 'border-hydra-500 bg-hydra-50 text-hydra-700' : 'border-gray-200 text-gray-600 hover:border-hydra-300'}`;
  csvHintEl.classList.toggle('hidden', demo);
  if (demo) fileNameEl.textContent = 'Demo: eventos Qmax, volumen, duración y estación';
}

function setRunning(running: boolean) {
  isRunning = running;
  (runBtn as HTMLButtonElement).disabled = running;
  runLabel.textContent = running ? 'Ajustando...' : 'Ajustar cópula';
  runArrow.classList.toggle('hidden', running);
  runSpinner.classList.toggle('hidden', !running);
}

function showError(msg: string) { errorBox.textContent = msg; errorBox.classList.remove('hidden'); }
function clearError() { errorBox.classList.add('hidden'); errorBox.textContent = ''; }

btnDemo.addEventListener('click', () => setSource(true));
btnUpload.addEventListener('click', () => fileInput.click());
fileInput.addEventListener('change', () => {
  if (fileInput.files?.[0]) { setSource(false); fileNameEl.textContent = fileInput.files[0].name; }
});
sampleInput.addEventListener('input', () => { sampleVal.textContent = sampleInput.value; });

runBtn.addEventListener('click', async () => {
  if (isRunning) return;
  clearError();
  if (!useDemo && !fileInput.files?.[0]) { showError('Selecciona un CSV o vuelve a usar los datos demo.'); return; }
  setRunning(true);

  const fd = new FormData();
  fd.append('demo', useDemo ? 'true' : 'false');
  fd.append('continuous_vars', (document.getElementById('continuous-vars') as HTMLInputElement).value);
  fd.append('discrete_vars', (document.getElementById('discrete-vars') as HTMLInputElement).value);
  fd.append('n_samples', sampleInput.value);
  if (!useDemo && fileInput.files?.[0]) fd.append('file', fileInput.files[0]);

  try {
    const res = await fetch(`${apiUrl}/api/copulas/fit-sample`, { method: 'POST', body: fd });
    if (!res.ok) { const err = await res.json(); throw new Error(err.detail ?? 'Error en el servidor'); }
    renderResults(await res.json());
  } catch (err: any) {
    showError(err.message ?? 'Error desconocido');
  } finally {
    setRunning(false);
  }
});

function statCard(label: string, value: string, unit = '') {
  return `<div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
    <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">${label}</p>
    <p class="text-3xl font-bold text-gray-900">${value}</p>
    <p class="text-xs text-gray-400 mt-1">${unit}</p>
  </div>`;
}

function unpack(rows: any[], key: string): number[] {
  return rows.map(r => Number(r[key])).filter(Number.isFinite);
}

function corrMatrix(payload: any, vars: string[]) {
  return vars.map(row => vars.map(col => payload?.[row]?.[col] ?? null));
}

// Simple KDE using Gaussian kernel for marginal density
function kde(data: number[], xVals: number[], bandwidth?: number): number[] {
  const n = data.length;
  const h = bandwidth ?? (1.06 * Math.sqrt(data.reduce((a, v) => a + (v - data.reduce((s, x) => s + x, 0) / n) ** 2, 0) / n) * Math.pow(n, -0.2));
  return xVals.map(x => {
    const sum = data.reduce((acc, xi) => acc + Math.exp(-0.5 * ((x - xi) / h) ** 2), 0);
    return sum / (n * h * Math.sqrt(2 * Math.PI));
  });
}

function renderPairScatters(observed: any[], synthetic: any[], cont: string[]) {
  const container = document.getElementById('charts-pairs')!;
  const pairs: [string, string][] = [];
  for (let i = 0; i < cont.length; i++)
    for (let j = i + 1; j < cont.length; j++)
      pairs.push([cont[i], cont[j]]);

  // Responsive grid: 1 col if 1 pair, 2 cols if 2–4 pairs, 3 cols if more
  const cols = pairs.length === 1 ? 1 : pairs.length <= 4 ? 2 : 3;
  container.className = `grid gap-6 grid-cols-${cols}`;

  container.innerHTML = pairs.map(([x, y]) =>
    `<div id="pair-${x}-${y}" class="h-72"></div>`
  ).join('');

  pairs.forEach(([x, y]) => {
    Plotly.newPlot(`pair-${x}-${y}`, [
      {
        x: unpack(synthetic, x), y: unpack(synthetic, y),
        mode: 'markers', type: 'scatter', name: 'Sintético',
        marker: { color: '#7c3aed', size: 4, opacity: 0.25 },
      },
      {
        x: unpack(observed, x), y: unpack(observed, y),
        mode: 'markers', type: 'scatter', name: 'Observado',
        marker: { color: '#0f766e', size: 9, opacity: 0.85, line: { color: '#fff', width: 1 } },
      },
    ], {
      ...layoutBase,
      xaxis: { title: x, gridcolor: '#f1f5f9' },
      yaxis: { title: y, gridcolor: '#f1f5f9' },
      legend: { orientation: 'h', y: -0.28, x: 0 },
    }, { responsive: true, displayModeBar: false });
  });
}

function renderMarginals(observed: any[], synthetic: any[], cont: string[]) {
  const container = document.getElementById('charts-marginals')!;
  const cols = cont.length <= 2 ? cont.length : 3;
  container.className = `grid gap-6 grid-cols-${cols}`;
  container.innerHTML = cont.map(v => `<div id="marg-${v}" class="h-64"></div>`).join('');

  cont.forEach(v => {
    const obs = unpack(observed, v).sort((a, b) => a - b);
    const syn = unpack(synthetic, v);
    if (!obs.length || !syn.length) return;

    const xMin = Math.min(...obs, ...syn);
    const xMax = Math.max(...obs, ...syn);
    const xs = Array.from({ length: 120 }, (_, i) => xMin + (i / 119) * (xMax - xMin));
    const dens = kde(syn, xs);

    Plotly.newPlot(`marg-${v}`, [
      {
        x: obs, type: 'histogram', name: 'Observado',
        histnorm: 'probability density',
        marker: { color: 'rgba(15,118,110,0.55)', line: { color: '#0f766e', width: 1 } },
        nbinsx: Math.min(20, Math.max(8, Math.floor(obs.length / 4))),
      },
      {
        x: xs, y: dens, type: 'scatter', mode: 'lines', name: 'Sintético (KDE)',
        line: { color: '#7c3aed', width: 2.5 },
      },
    ], {
      ...layoutBase,
      margin: { t: 10, r: 16, b: 48, l: 54 },
      xaxis: { title: v, gridcolor: '#f1f5f9' },
      yaxis: { title: 'Densidad', gridcolor: '#f1f5f9' },
      legend: { orientation: 'h', y: -0.32, x: 0 },
      bargap: 0.05,
    }, { responsive: true, displayModeBar: false });
  });
}

function renderHeatmap(target: string, corr: any, vars: string[]) {
  Plotly.newPlot(target, [{
    z: corrMatrix(corr, vars), x: vars, y: vars,
    type: 'heatmap', zmin: -1, zmax: 1,
    colorscale: 'RdBu', reversescale: true,
    hovertemplate: '%{y} vs %{x}: %{z:.2f}<extra></extra>',
    text: corrMatrix(corr, vars).map(row => row.map(v => v != null ? v.toFixed(2) : '')),
    texttemplate: '%{text}',
  }], {
    ...layoutBase,
    margin: { t: 10, r: 20, b: 60, l: 70 },
  }, { responsive: true, displayModeBar: false });
}

function renderTable(rows: any[], vars: string[]) {
  const head = document.getElementById('synthetic-head')!;
  const body = document.getElementById('synthetic-body')!;
  head.innerHTML = `<tr>${vars.map(v => `<th class="py-2 pr-4 text-gray-500 font-semibold">${v}</th>`).join('')}</tr>`;
  body.innerHTML = rows.slice(0, 40).map(row =>
    `<tr>${vars.map(v => `<td class="py-2 pr-4 text-gray-700">${Number(row[v]).toFixed(3)}</td>`).join('')}</tr>`
  ).join('');
}

function renderResults(data: any) {
  placeholder.classList.add('hidden');
  resultsEl.classList.remove('hidden');

  const summary = data.summary;
  const cont: string[] = summary.continuous_vars;
  const disc: string[] = summary.discrete_vars;
  const vars = [...cont, ...disc];

  document.getElementById('stats-row')!.innerHTML = [
    statCard('Eventos observados', String(summary.n_observed), summary.source),
    statCard('Eventos sintéticos', String(summary.n_synthetic), 'muestras'),
    statCard(cont[0], String(summary[`${cont[0]}_syn_mean`]), 'media sintética'),
    statCard('Variables', String(vars.length), `${cont.length} continuas + ${disc.length} discreta(s)`),
  ].join('');

  renderPairScatters(data.observed, data.synthetic, cont);
  renderMarginals(data.observed, data.synthetic, cont);
  renderHeatmap('chart-corr-observed', data.observed_corr, vars);
  renderHeatmap('chart-corr-synthetic', data.synthetic_corr, vars);
  renderTable(data.synthetic, vars);
}
</script>
