---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Interpolación Espacial — HYDRA">
  <script src="https://cdn.plot.ly/plotly-2.32.0.min.js" is:inline></script>

  <section class="pt-24 pb-10 bg-gradient-to-br from-slate-950 via-teal-950 to-emerald-900 text-white">
    <div class="max-w-7xl mx-auto px-6">
      <a href="/" class="inline-flex items-center gap-2 text-white/65 hover:text-white text-sm mb-6 transition-colors">
        ← Volver al inicio
      </a>
      <h1 class="text-4xl font-extrabold mb-2">Interpolación Espacial</h1>
      <p class="text-white/76 text-lg max-w-3xl">
        Compara IDW, Kriging Ordinario, RBF y Vecino más cercano sobre el mismo conjunto de estaciones.
        Sube tres CSV (coordenadas, valores, puntos objetivo) y obtén el mapa interpolado y RMSE de validación cruzada.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-6 py-10">
    <div class="grid lg:grid-cols-[340px_1fr] gap-8">

      <!-- ── PANEL DE CONTROL ── -->
      <aside class="space-y-6">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 space-y-5">

          <!-- Fuente de datos -->
          <div>
            <label class="block text-sm font-semibold text-gray-800 mb-2">Fuente de datos</label>
            <label class="flex items-center gap-3 p-3 rounded-xl border border-gray-200 cursor-pointer mb-2 has-[:checked]:border-teal-500 has-[:checked]:bg-teal-50">
              <input type="radio" name="datasource" value="demo" checked class="accent-teal-600" />
              <span class="text-sm font-medium text-gray-700">Demo (lluvia, 8 estaciones Cantabria)</span>
            </label>
            <label class="flex items-center gap-3 p-3 rounded-xl border border-gray-200 cursor-pointer has-[:checked]:border-teal-500 has-[:checked]:bg-teal-50">
              <input type="radio" name="datasource" value="csv" class="accent-teal-600" />
              <span class="text-sm font-medium text-gray-700">CSV propio (3 archivos)</span>
            </label>
          </div>

          <!-- CSV uploads -->
          <div id="csv-area" class="hidden space-y-4 border-t border-gray-100 pt-4">
            <p class="text-xs text-gray-500 leading-relaxed">
              Los tres CSV deben tener el mismo separador (coma). Las filas de <strong>coordenadas</strong> y <strong>valores</strong> deben corresponder en orden.
            </p>
            <div>
              <label class="block text-xs font-semibold text-gray-700 mb-1">① Coordenadas de estaciones (lon, lat)</label>
              <input id="csv-stations" type="file" accept=".csv"
                class="block w-full text-sm text-gray-500 file:rounded-lg file:border-0 file:bg-teal-50 file:px-3 file:py-1.5 file:text-xs file:font-semibold file:text-teal-700 hover:file:bg-teal-100" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-700 mb-1">② Valores en estaciones (una columna numérica)</label>
              <input id="csv-values" type="file" accept=".csv"
                class="block w-full text-sm text-gray-500 file:rounded-lg file:border-0 file:bg-teal-50 file:px-3 file:py-1.5 file:text-xs file:font-semibold file:text-teal-700 hover:file:bg-teal-100" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-700 mb-1">③ Puntos de interpolación (lon, lat)</label>
              <input id="csv-targets" type="file" accept=".csv"
                class="block w-full text-sm text-gray-500 file:rounded-lg file:border-0 file:bg-teal-50 file:px-3 file:py-1.5 file:text-xs file:font-semibold file:text-teal-700 hover:file:bg-teal-100" />
            </div>
            <div class="grid grid-cols-2 gap-2">
              <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Col longitud</label>
                <input id="lon-col" type="text" value="lon" placeholder="lon"
                  class="w-full rounded-lg border border-gray-200 px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Col latitud</label>
                <input id="lat-col" type="text" value="lat" placeholder="lat"
                  class="w-full rounded-lg border border-gray-200 px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400" />
              </div>
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-700 mb-1">Col variable (vacío = primera numérica)</label>
              <input id="value-col" type="text" value="" placeholder="ej. precip_mm"
                class="w-full rounded-lg border border-gray-200 px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400" />
            </div>
          </div>

          <!-- Métodos -->
          <div>
            <label class="block text-sm font-semibold text-gray-800 mb-2">Métodos</label>
            <div class="space-y-2">
              {[
                ['idw', 'IDW (Ponderación distancia inversa)'],
                ['kriging_ordinary', 'Kriging Ordinario'],
                ['rbf_thin_plate', 'RBF Thin-plate spline'],
                ['rbf_linear', 'RBF Lineal'],
                ['nearest', 'Vecino más cercano'],
              ].map(([val, label]) => (
                <label class="flex items-center gap-3 cursor-pointer">
                  <input type="checkbox" name="method" value={val} checked={['idw','kriging_ordinary','rbf_thin_plate'].includes(val)} class="accent-teal-600 w-4 h-4" />
                  <span class="text-sm text-gray-700">{label}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- IDW power -->
          <div>
            <label class="flex justify-between text-sm font-semibold text-gray-800 mb-2">
              Potencia IDW
              <span id="idw-power-val" class="text-teal-600 font-bold">2</span>
            </label>
            <input id="idw-power" type="range" min="1" max="5" step="0.5" value="2" class="w-full accent-teal-600" />
          </div>

          <!-- LOOCV -->
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" id="run-loocv" checked class="accent-teal-600 w-4 h-4" />
            <span class="text-sm font-semibold text-gray-800">Calcular RMSE (LOOCV)</span>
          </label>

          <button id="run-btn"
            class="w-full bg-teal-600 hover:bg-teal-700 text-white font-semibold py-3 rounded-xl transition-colors">
            Interpolar
          </button>
          <div id="error-box" class="hidden bg-red-50 border border-red-200 rounded-lg p-3 text-sm text-red-700"></div>
        </div>

        <!-- Info -->
        <div class="bg-teal-50 border border-teal-100 rounded-2xl p-5 text-sm text-teal-900 space-y-2">
          <p class="font-semibold">Formato CSV esperado</p>
          <p><strong>CSV 1</strong> (estaciones): columnas <code>lon</code>, <code>lat</code></p>
          <p><strong>CSV 2</strong> (valores): una columna numérica por evento/variable</p>
          <p><strong>CSV 3</strong> (objetivos): columnas <code>lon</code>, <code>lat</code></p>
          <p class="pt-1">El LOOCV deja fuera cada estación y predice su valor para calcular el RMSE sin datos de test independientes.</p>
        </div>
      </aside>

      <!-- ── RESULTADOS ── -->
      <main class="space-y-8">

        <div id="placeholder" class="rounded-2xl border border-dashed border-gray-200 bg-gray-50 p-16 text-center text-gray-400">
          <svg class="w-12 h-12 mx-auto mb-4 text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="5" cy="6" r="2"/><circle cx="18" cy="5" r="2"/><circle cx="9" cy="14" r="2"/><circle cx="19" cy="15" r="2"/>
            <line x1="6.5" y1="7.2" x2="7.8" y2="12.3" stroke-width="1"/><line x1="17" y1="6.8" x2="18.3" y2="13.2" stroke-width="1"/>
            <line x1="11" y1="14" x2="17" y2="15" stroke-width="1"/>
            <path d="M12 17L12 21M10 19L12 21L14 19"/>
          </svg>
          <p class="font-medium text-gray-500">Configura los parámetros y haz clic en "Interpolar"</p>
        </div>

        <div id="loading-msg" class="hidden text-center py-16 text-gray-400">
          <div class="inline-block h-8 w-8 animate-spin rounded-full border-4 border-teal-300 border-t-teal-600 mb-4"></div>
          <p class="font-medium">Interpolando…</p>
        </div>

        <div id="results" class="hidden space-y-8">

          <!-- Stats -->
          <div class="grid md:grid-cols-3 gap-4">
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Estaciones</p>
              <p id="stat-stations" class="text-2xl font-bold text-gray-900">—</p>
            </div>
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Puntos objetivo</p>
              <p id="stat-targets" class="text-2xl font-bold text-gray-900">—</p>
            </div>
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Variable</p>
              <p id="stat-variable" class="text-2xl font-bold text-gray-900">—</p>
            </div>
          </div>

          <!-- ── MAPA ESPACIAL ── -->
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <div class="flex flex-wrap items-center justify-between gap-4 mb-4">
              <div>
                <h3 class="font-semibold text-gray-800">Mapa espacial interpolado</h3>
                <p class="text-sm text-gray-400 mt-0.5">Campo interpolado sobre malla regular 45×45. Puntos = estaciones observadas.</p>
              </div>
              <div class="flex items-center gap-2">
                <label class="text-sm font-medium text-gray-600">Método:</label>
                <select id="map-method-select"
                  class="rounded-lg border border-gray-200 px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 bg-white">
                </select>
              </div>
            </div>
            <div id="chart-map" class="h-96"></div>
          </div>

          <!-- RMSE comparativo -->
          <div id="rmse-panel" class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h3 class="font-semibold text-gray-800 mb-1">RMSE por método (LOOCV)</h3>
            <p class="text-sm text-gray-400 mb-5">El método con menor RMSE generaliza mejor sobre esta red de estaciones.</p>
            <div id="rmse-bars" class="space-y-3"></div>
          </div>

          <!-- Tabla de resultados en puntos objetivo -->
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 overflow-x-auto">
            <h3 class="font-semibold text-gray-800 mb-1">Valores interpolados en puntos objetivo</h3>
            <p class="text-sm text-gray-400 mb-4">Un fila por punto, una columna por método.</p>
            <table class="w-full text-sm border-collapse" id="targets-table">
              <thead id="targets-thead" class="text-xs text-gray-500 uppercase tracking-wide border-b border-gray-100"></thead>
              <tbody id="targets-tbody" class="divide-y divide-gray-50"></tbody>
            </table>
          </div>

          <!-- Tabla de estaciones con observado -->
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 overflow-x-auto">
            <h3 class="font-semibold text-gray-800 mb-4">Estaciones — valores observados</h3>
            <table class="w-full text-sm border-collapse">
              <thead class="text-xs text-gray-500 uppercase tracking-wide border-b border-gray-100">
                <tr>
                  <th class="py-2 px-3 text-left">Lat</th>
                  <th class="py-2 px-3 text-left">Lon</th>
                  <th class="py-2 px-3 text-right">Observado</th>
                </tr>
              </thead>
              <tbody id="stations-tbody" class="divide-y divide-gray-50"></tbody>
            </table>
          </div>

        </div><!-- /results -->
      </main>
    </div>
  </div>
</Layout>

<script>
declare const Plotly: any;

const dsRadios = document.querySelectorAll<HTMLInputElement>('input[name="datasource"]');
const csvArea = document.getElementById('csv-area')!;
const csvStations = document.getElementById('csv-stations') as HTMLInputElement;
const csvValues = document.getElementById('csv-values') as HTMLInputElement;
const csvTargets = document.getElementById('csv-targets') as HTMLInputElement;
const lonColEl = document.getElementById('lon-col') as HTMLInputElement;
const latColEl = document.getElementById('lat-col') as HTMLInputElement;
const valueColEl = document.getElementById('value-col') as HTMLInputElement;
const idwPowerEl = document.getElementById('idw-power') as HTMLInputElement;
const idwPowerVal = document.getElementById('idw-power-val')!;
const loocvEl = document.getElementById('run-loocv') as HTMLInputElement;
const runBtn = document.getElementById('run-btn')!;
const errorBox = document.getElementById('error-box')!;
const placeholder = document.getElementById('placeholder')!;
const loadingMsg = document.getElementById('loading-msg')!;
const resultsEl = document.getElementById('results')!;
const mapMethodSelect = document.getElementById('map-method-select') as HTMLSelectElement;

dsRadios.forEach(r => r.addEventListener('change', () => {
  csvArea.classList.toggle('hidden', r.value === 'demo' && r.checked);
}));

idwPowerEl.addEventListener('input', () => { idwPowerVal.textContent = idwPowerEl.value; });

function showError(msg: string) {
  errorBox.textContent = msg;
  errorBox.classList.remove('hidden');
}
function clearError() {
  errorBox.textContent = '';
  errorBox.classList.add('hidden');
}

const METHOD_LABELS: Record<string, string> = {
  idw: 'IDW',
  kriging_ordinary: 'Kriging Ord.',
  rbf_thin_plate: 'RBF Thin-plate',
  rbf_linear: 'RBF Lineal',
  nearest: 'Vecino más cercano',
};
const METHOD_COLORS: string[] = ['#0d9488', '#6366f1', '#f59e0b', '#ef4444', '#8b5cf6'];

let _gridData: any = null;
let _stationsData: any[] = [];
let _variable = '';

function renderMap(method: string) {
  if (!_gridData || !_gridData.values[method]) return;

  const { lats, lons, n, values } = _gridData;
  const flat = values[method] as (number | null)[];

  // Reshape flat → 2D (rows=lat, cols=lon)
  const z: (number | null)[][] = [];
  for (let r = 0; r < n; r++) {
    z.push(flat.slice(r * n, (r + 1) * n));
  }

  const heatmap = {
    type: 'heatmap',
    x: lons,
    y: lats,
    z,
    colorscale: 'YlGnBu',
    showscale: true,
    colorbar: { title: { text: _variable, side: 'right' }, thickness: 14, len: 0.9 },
    hovertemplate: 'lon: %{x:.3f}<br>lat: %{y:.3f}<br>%{z:.2f}<extra></extra>',
  };

  const scatter = {
    type: 'scatter',
    mode: 'markers+text',
    x: _stationsData.map(s => s.lon),
    y: _stationsData.map(s => s.lat),
    text: _stationsData.map(s => String(s.observed)),
    textposition: 'top center',
    textfont: { size: 10, color: '#1e293b' },
    marker: {
      color: _stationsData.map(s => s.observed),
      colorscale: 'YlGnBu',
      size: 12,
      line: { color: '#1e293b', width: 1.5 },
      showscale: false,
    },
    name: 'Estaciones',
    hovertemplate: 'lon: %{x:.3f}<br>lat: %{y:.3f}<br>obs: %{text}<extra>Estación</extra>',
  };

  Plotly.newPlot('chart-map', [heatmap, scatter], {
    paper_bgcolor: 'transparent',
    plot_bgcolor: '#f8fafc',
    margin: { t: 10, r: 20, b: 50, l: 60 },
    font: { family: 'Inter, system-ui, sans-serif', size: 11 },
    xaxis: { title: 'Longitud', gridcolor: '#e2e8f0' },
    yaxis: { title: 'Latitud', gridcolor: '#e2e8f0', scaleanchor: 'x', scaleratio: 1 },
    legend: { x: 0.01, y: 0.99, bgcolor: 'rgba(255,255,255,0.85)', bordercolor: '#e2e8f0', borderwidth: 1 },
  }, { responsive: true, displayModeBar: false });
}

mapMethodSelect.addEventListener('change', () => renderMap(mapMethodSelect.value));

function renderRmseBars(loocv: Record<string, number | null>, methods: string[]) {
  const validEntries = methods
    .filter(m => loocv[m] != null)
    .map(m => ({ m, rmse: loocv[m] as number }))
    .sort((a, b) => a.rmse - b.rmse);

  const maxRmse = Math.max(...validEntries.map(e => e.rmse), 1e-6);
  const container = document.getElementById('rmse-bars')!;
  container.innerHTML = validEntries.map((e, i) => `
    <div class="flex items-center gap-4">
      <span class="w-36 text-sm font-medium text-gray-700 text-right shrink-0">${METHOD_LABELS[e.m] ?? e.m}</span>
      <div class="flex-1 bg-gray-100 rounded-full h-4 overflow-hidden">
        <div class="h-4 rounded-full transition-all" style="width:${(e.rmse / maxRmse) * 100}%;background:${METHOD_COLORS[i % METHOD_COLORS.length]}"></div>
      </div>
      <span class="w-20 text-sm font-bold text-gray-900">${e.rmse.toFixed(4)}</span>
      ${i === 0 ? '<span class="text-xs font-semibold text-teal-600">✓ mejor</span>' : '<span class="w-12"></span>'}
    </div>
  `).join('');
}

async function runInterpolation() {
  clearError();
  const demo = (document.querySelector('input[name="datasource"]:checked') as HTMLInputElement)?.value === 'demo';
  const selectedMethods = Array.from(document.querySelectorAll<HTMLInputElement>('input[name="method"]:checked')).map(el => el.value);
  if (selectedMethods.length === 0) { showError('Selecciona al menos un método.'); return; }

  const formData = new FormData();
  formData.append('demo', demo ? 'true' : 'false');
  formData.append('methods', selectedMethods.join(','));
  formData.append('idw_power', idwPowerEl.value);
  formData.append('run_loocv', loocvEl.checked ? 'true' : 'false');

  if (!demo) {
    const fs = csvStations.files?.[0], fv = csvValues.files?.[0], ft = csvTargets.files?.[0];
    if (!fs || !fv || !ft) { showError('Sube los tres archivos CSV.'); return; }
    formData.append('stations_csv', fs);
    formData.append('values_csv', fv);
    formData.append('targets_csv', ft);
    formData.append('lon_col', lonColEl.value.trim());
    formData.append('lat_col', latColEl.value.trim());
    formData.append('value_col', valueColEl.value.trim());
  }

  placeholder.classList.add('hidden');
  resultsEl.classList.add('hidden');
  loadingMsg.classList.remove('hidden');
  runBtn.setAttribute('disabled', '');

  try {
    const res = await fetch('/api/interpolation/compare', { method: 'POST', body: formData });
    const data = await res.json();
    if (!res.ok) throw new Error(data.detail ?? 'Error en la interpolación');

    const { summary, stations, targets, grid } = data;

    document.getElementById('stat-stations')!.textContent = String(summary.n_stations);
    document.getElementById('stat-targets')!.textContent = String(summary.n_targets);
    document.getElementById('stat-variable')!.textContent = summary.variable;

    // Populate method selector for map
    _gridData = grid;
    _stationsData = stations;
    _variable = summary.variable;
    mapMethodSelect.innerHTML = summary.methods
      .map((m: string) => `<option value="${m}">${METHOD_LABELS[m] ?? m}</option>`)
      .join('');

    const hasSomeLoocv = Object.values(summary.loocv_rmse ?? {}).some(v => v != null);
    const rmsePanel = document.getElementById('rmse-panel')!;
    if (hasSomeLoocv) {
      renderRmseBars(summary.loocv_rmse, summary.methods);
      // Pre-select method with best RMSE
      const best = Object.entries(summary.loocv_rmse as Record<string, number | null>)
        .filter(([, v]) => v != null)
        .sort(([, a], [, b]) => (a as number) - (b as number))[0]?.[0];
      if (best && summary.methods.includes(best)) mapMethodSelect.value = best;
      rmsePanel.classList.remove('hidden');
    } else {
      rmsePanel.classList.add('hidden');
    }

    resultsEl.classList.remove('hidden');

    // Render map after DOM is visible
    requestAnimationFrame(() => renderMap(mapMethodSelect.value));

    // Targets table
    const thead = document.getElementById('targets-thead')!;
    const tbody = document.getElementById('targets-tbody')!;
    const cols = ['lat', 'lon', ...summary.methods];
    thead.innerHTML = '<tr>' + cols.map(c => `<th class="py-2 px-3 font-medium text-left">${METHOD_LABELS[c] ?? c}</th>`).join('') + '</tr>';
    tbody.innerHTML = targets.map((row: any) =>
      '<tr>' + cols.map(c => `<td class="py-1.5 px-3 text-gray-700">${row[c] ?? '—'}</td>`).join('') + '</tr>'
    ).join('');

    // Stations table
    document.getElementById('stations-tbody')!.innerHTML = stations.map((st: any) =>
      `<tr>
        <td class="py-1.5 px-3 text-gray-700">${st.lat}</td>
        <td class="py-1.5 px-3 text-gray-700">${st.lon}</td>
        <td class="py-1.5 px-3 text-right font-medium text-gray-900">${st.observed}</td>
      </tr>`
    ).join('');

  } catch (err: any) {
    showError(err.message ?? 'Error desconocido');
    placeholder.classList.remove('hidden');
  } finally {
    loadingMsg.classList.add('hidden');
    runBtn.removeAttribute('disabled');
  }
}

runBtn.addEventListener('click', runInterpolation);
</script>
