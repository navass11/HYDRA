---
import Layout from '../../layouts/Layout.astro';
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<Layout title="Curva IDF — HYDRA">
  <script src="https://cdn.plot.ly/plotly-2.32.0.min.js" is:inline></script>

  <section class="pt-24 pb-10 bg-gradient-to-br from-slate-950 via-blue-950 to-blue-800 text-white">
    <div class="max-w-7xl mx-auto px-6">
      <a href="/" data-i18n="back.home" class="inline-flex items-center gap-2 text-white/65 hover:text-white text-sm mb-6 transition-colors">
        ← Volver al inicio
      </a>
      <h1 class="text-4xl font-extrabold mb-2" data-t-es="Curvas IDF" data-t-en="IDF Curves">Curvas IDF</h1>
      <p class="text-white/75 text-lg max-w-3xl" data-t-es="Ajusta una GEV a los máximos anuales de intensidad por duración y genera la curva Intensidad-Duración-Frecuencia." data-t-en="Fits a GEV to annual maximum intensities per duration and generates the Intensity-Duration-Frequency curve.">
        Ajusta una GEV a los máximos anuales de intensidad por duración y genera la curva Intensidad-Duración-Frecuencia.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-6 py-10" id="app" data-api-url={apiUrl}>
    <div class="grid lg:grid-cols-[320px_1fr] gap-8">

      <aside class="space-y-6">
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm p-6 space-y-6">
          <div>
            <h3 class="font-semibold text-gray-800 dark:text-slate-200 mb-3 text-sm uppercase tracking-wide" data-t-es="Datos" data-t-en="Data">Datos</h3>
            <div class="grid grid-cols-2 gap-2 mb-3">
              <button id="btn-demo" class="src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 border-blue-500 bg-blue-50 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300">Demo</button>
              <button id="btn-upload" class="src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 border-gray-200 dark:border-slate-600 text-gray-600 dark:text-slate-400 hover:border-blue-300 transition-colors" data-t-es="Subir CSV" data-t-en="Upload CSV">Subir CSV</button>
            </div>
            <input type="file" id="file-input" accept=".csv" class="hidden" />
            <p id="file-name" class="text-xs text-gray-400 dark:text-slate-500 italic">Demo: máximos anuales sintéticos (40 años, 7 duraciones)</p>
            <div id="csv-hint" class="hidden mt-2 text-xs text-gray-500 dark:text-slate-400 bg-gray-50 dark:bg-slate-700 rounded-lg p-3" data-t-es="CSV: primera columna = año (ignorada), columnas siguientes = duraciones (ej. 10min, 30min, 1h, 2h, 6h, 12h, 24h). Valores en mm/h." data-t-en="CSV: first column = year (ignored), following columns = durations (e.g. 10min, 30min, 1h, 2h, 6h, 12h, 24h). Values in mm/h.">
              CSV: primera columna = año (ignorada), columnas siguientes = duraciones
              (<code class="text-blue-700 dark:text-blue-300">10min, 30min, 1h, 2h, 6h, 12h, 24h</code>).
              Valores en mm/h.
            </div>
          </div>

          <button id="run-btn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-xl transition-colors flex items-center justify-center gap-2">
            <span id="run-label" data-t-es="Calcular IDF" data-t-en="Compute IDF">Calcular IDF</span>
            <svg id="run-arrow" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
            <svg id="run-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
            </svg>
          </button>
          <div id="error-box" class="hidden bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-700 rounded-lg p-3 text-sm text-red-700 dark:text-red-300"></div>
        </div>

        <div class="bg-blue-50 dark:bg-blue-950/50 border border-blue-100 dark:border-blue-800 rounded-2xl p-5 text-sm text-blue-900 dark:text-blue-200 space-y-2">
          <p class="font-semibold" data-t-es="Método" data-t-en="Method">Método</p>
          <p data-t-es="Se ajusta una GEV con estimación MAP bayesiana (via fit_gev_map) a los máximos anuales de cada duración. Los niveles de retorno se obtienen con la fórmula de la GEV." data-t-en="A GEV is fitted with Bayesian MAP estimation (via fit_gev_map) to the annual maxima of each duration. Return levels are derived from the GEV formula.">Se ajusta una GEV con estimación MAP bayesiana (via <code>fit_gev_map</code>) a los máximos anuales de cada duración. Los niveles de retorno se obtienen con la fórmula de la GEV.</p>
        </div>
      </aside>

      <main>
        <div id="placeholder" class="min-h-[430px] flex flex-col items-center justify-center text-center rounded-2xl border-2 border-dashed border-gray-200 dark:border-slate-700 p-12">
          <div class="w-16 h-16 rounded-2xl bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300 flex items-center justify-center mb-4">
            <svg class="w-9 h-9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <rect x="3" y="14" width="3" height="5" rx="0.5"/>
              <rect x="8" y="10" width="3" height="9" rx="0.5"/>
              <rect x="13" y="6" width="3" height="13" rx="0.5"/>
              <rect x="18" y="3" width="3" height="16" rx="0.5"/>
              <line x1="2" y1="20" x2="22" y2="20" stroke-width="1.2"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-700 dark:text-slate-300 mb-2" data-t-es="Listo para calcular" data-t-en="Ready to compute">Listo para calcular</h3>
          <p class="text-gray-400 dark:text-slate-500 max-w-md" data-t-es="Ejecuta la demo o sube un CSV con máximos anuales por duración." data-t-en="Run the demo or upload a CSV with annual maxima by duration.">Ejecuta la demo o sube un CSV con máximos anuales por duración.</p>
        </div>

        <div id="results" class="hidden space-y-8">
          <div id="stats-row" class="grid grid-cols-2 lg:grid-cols-3 gap-4"></div>

          <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm p-6">
            <h3 class="font-semibold text-gray-800 dark:text-slate-200 mb-1" data-t-es="Curva IDF" data-t-en="IDF Curve">Curva IDF</h3>
            <p class="text-sm text-gray-400 dark:text-slate-500 mb-4" data-t-es="Intensidad (mm/h) vs duración en escala log-log. Una curva por periodo de retorno." data-t-en="Intensity (mm/h) vs duration on a log-log scale. One curve per return period.">Intensidad (mm/h) vs duración en escala log-log. Una curva por periodo de retorno.</p>
            <div id="chart-idf" class="h-96"></div>
          </div>

          <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm p-6">
            <h3 class="font-semibold text-gray-800 dark:text-slate-200 mb-4" data-t-es="Tabla IDF (mm/h)" data-t-en="IDF Table (mm/h)">Tabla IDF (mm/h)</h3>
            <div class="overflow-auto">
              <table class="w-full text-sm" id="idf-table">
                <thead class="text-left text-gray-500 dark:text-slate-400"></thead>
                <tbody class="divide-y divide-gray-100 dark:divide-slate-700"></tbody>
              </table>
            </div>
          </div>

          <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm p-6">
            <h3 class="font-semibold text-gray-800 dark:text-slate-200 mb-4" data-t-es="Parámetros GEV por duración" data-t-en="GEV Parameters by Duration">Parámetros GEV por duración</h3>
            <div class="overflow-auto">
              <table class="w-full text-sm" id="params-table">
                <thead class="text-left text-gray-500 dark:text-slate-400"></thead>
                <tbody class="divide-y divide-gray-100 dark:divide-slate-700"></tbody>
              </table>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
</Layout>

<script>
declare const Plotly: any;

const t = (es: string, en: string) => document.documentElement.lang === 'en' ? en : es;

const COLORS = ['#2563eb','#16a34a','#dc2626','#d97706','#7c3aed','#0891b2'];
const layoutBase = {
  paper_bgcolor: 'transparent',
  plot_bgcolor:  'transparent',
  margin: { t: 20, r: 16, b: 52, l: 58 },
  font: { family: 'Inter, system-ui, sans-serif', size: 11 },
};

let useDemo = true;
let isRunning = false;

const appEl       = document.getElementById('app')!;
const apiUrl      = appEl.dataset.apiUrl!;
const btnDemo     = document.getElementById('btn-demo')!;
const btnUpload   = document.getElementById('btn-upload')!;
const fileInput   = document.getElementById('file-input') as HTMLInputElement;
const fileNameEl  = document.getElementById('file-name')!;
const csvHintEl   = document.getElementById('csv-hint')!;
const runBtn      = document.getElementById('run-btn')!;
const runLabel    = document.getElementById('run-label')!;
const runArrow    = document.getElementById('run-arrow')!;
const runSpinner  = document.getElementById('run-spinner')!;
const errorBox    = document.getElementById('error-box')!;
const placeholder = document.getElementById('placeholder')!;
const resultsEl   = document.getElementById('results')!;

function setSource(demo: boolean) {
  useDemo = demo;
  btnDemo.className   = `src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 transition-colors ${demo ? 'border-blue-500 bg-blue-50 text-blue-700' : 'border-gray-200 text-gray-600 hover:border-blue-300'}`;
  btnUpload.className = `src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 transition-colors ${!demo ? 'border-blue-500 bg-blue-50 text-blue-700' : 'border-gray-200 text-gray-600 hover:border-blue-300'}`;
  csvHintEl.classList.toggle('hidden', demo);
  if (demo) fileNameEl.textContent = t('Demo: máximos anuales sintéticos (40 años, 7 duraciones)', 'Demo: synthetic annual maxima (40 years, 7 durations)');
}

function setRunning(r: boolean) {
  isRunning = r;
  (runBtn as HTMLButtonElement).disabled = r;
  runLabel.textContent = r ? t('Calculando...', 'Computing...') : t('Calcular IDF', 'Compute IDF');
  runArrow.classList.toggle('hidden', r);
  runSpinner.classList.toggle('hidden', !r);
}

function showError(msg: string) { errorBox.textContent = msg; errorBox.classList.remove('hidden'); }
function clearError() { errorBox.classList.add('hidden'); errorBox.textContent = ''; }

btnDemo.addEventListener('click', () => setSource(true));
btnUpload.addEventListener('click', () => fileInput.click());
fileInput.addEventListener('change', () => {
  if (fileInput.files?.[0]) { setSource(false); fileNameEl.textContent = fileInput.files[0].name; }
});

runBtn.addEventListener('click', async () => {
  if (isRunning) return;
  clearError();
  if (!useDemo && !fileInput.files?.[0]) { showError(t('Selecciona un CSV o vuelve a usar los datos demo.', 'Select a CSV or switch back to demo data.')); return; }
  setRunning(true);

  const fd = new FormData();
  fd.append('demo', useDemo ? 'true' : 'false');
  if (!useDemo && fileInput.files?.[0]) fd.append('file', fileInput.files[0]);

  try {
    const res = await fetch(`${apiUrl}/api/idf/compute`, { method: 'POST', body: fd });
    if (!res.ok) { const err = await res.json(); throw new Error(err.detail ?? t('Error en el servidor', 'Server error')); }
    renderResults(await res.json());
  } catch (err: any) {
    showError(err.message ?? t('Error desconocido', 'Unknown error'));
  } finally {
    setRunning(false);
  }
});

const isDark = () => document.documentElement.classList.contains('dark');
const grid = () => isDark() ? '#334155' : '#e2e8f0';
const fontColor = () => isDark() ? '#94a3b8' : '#6b7280';

function statCard(label: string, value: string, unit = '') {
  return `<div class="bg-gray-50 dark:bg-slate-800 rounded-xl p-4 border border-gray-100 dark:border-slate-700">
    <p class="text-xs text-gray-400 dark:text-slate-500 uppercase tracking-wide mb-2">${label}</p>
    <p class="text-3xl font-bold text-gray-900 dark:text-white">${value}</p>
    <p class="text-xs text-gray-400 dark:text-slate-500 mt-1">${unit}</p>
  </div>`;
}

function renderResults(data: any) {
  placeholder.classList.add('hidden');
  resultsEl.classList.remove('hidden');

  const s = data.summary;
  document.getElementById('stats-row')!.innerHTML =
    statCard(t('Años de datos', 'Years of data'), `${s.n_years}`, t('máximos anuales', 'annual maxima')) +
    statCard(t('Duraciones', 'Durations'), `${s.n_durations}`, t('columnas ajustadas', 'fitted columns')) +
    statCard(t('Fuente', 'Source'), s.source === 'demo' ? 'Demo' : s.source, t('datos de entrada', 'input data'));

  // IDF chart (categorical X, log Y)
  const durations: string[] = data.durations;
  const periods: number[]   = data.return_periods;

  const traces = periods.map((T, i) => ({
    x: durations,
    y: data.idf_table[String(T)],
    mode: 'lines+markers',
    name: `T=${T}${t('a', 'yr')}`,
    line: { color: COLORS[i % COLORS.length], width: 2 },
    marker: { size: 6 },
  }));

  Plotly.newPlot('chart-idf', traces, {
    ...layoutBase,
    font: { ...layoutBase.font, color: fontColor() },
    xaxis: { title: t('Duración', 'Duration'), gridcolor: grid(), tickangle: -30 },
    yaxis: { title: t('Intensidad (mm/h)', 'Intensity (mm/h)'), type: 'log', gridcolor: grid() },
    legend: { orientation: 'h', y: -0.28 },
  }, { responsive: true, displayModeBar: false });

  // IDF table
  const idfTbl = document.getElementById('idf-table')!;
  idfTbl.querySelector('thead')!.innerHTML =
    `<tr><th class="py-2 pr-4">${t('T (años)', 'T (years)')}</th>` +
    durations.map(d => `<th class="py-2 px-2 text-right">${d}</th>`).join('') + `</tr>`;
  idfTbl.querySelector('tbody')!.innerHTML = periods.map(T =>
    `<tr class="hover:bg-gray-50 dark:hover:bg-slate-700/50">
      <td class="py-1.5 pr-4 font-semibold text-gray-800 dark:text-slate-200">${T}</td>
      ${(data.idf_table[String(T)] as (number|null)[]).map(v =>
        `<td class="py-1.5 px-2 text-right text-gray-700 dark:text-slate-300">${v != null ? v.toFixed(1) : '—'}</td>`
      ).join('')}
    </tr>`
  ).join('');

  // Params table
  const pTbl = document.getElementById('params-table')!;
  pTbl.querySelector('thead')!.innerHTML =
    `<tr><th class="py-2 pr-4">${t('Duración', 'Duration')}</th><th class="py-2 px-2 text-right">μ</th><th class="py-2 px-2 text-right">σ</th><th class="py-2 px-2 text-right">ξ</th></tr>`;
  pTbl.querySelector('tbody')!.innerHTML = durations.map(d => {
    const p = data.params[d];
    return `<tr class="hover:bg-gray-50 dark:hover:bg-slate-700/50">
      <td class="py-1.5 pr-4 font-medium text-gray-800 dark:text-slate-200">${d}</td>
      <td class="py-1.5 px-2 text-right text-gray-700 dark:text-slate-300">${p.mu != null ? p.mu : '—'}</td>
      <td class="py-1.5 px-2 text-right text-gray-700 dark:text-slate-300">${p.sigma != null ? p.sigma : '—'}</td>
      <td class="py-1.5 px-2 text-right text-gray-700 dark:text-slate-300">${p.xi != null ? p.xi : '—'}</td>
    </tr>`;
  }).join('');
}
</script>
