---
import Layout from '../../layouts/Layout.astro';
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<Layout title="Frecuencia Regional — HYDRA">
  <script src="https://cdn.plot.ly/plotly-2.32.0.min.js" is:inline></script>

  <section class="pt-24 pb-10 bg-gradient-to-br from-slate-950 via-fuchsia-950 to-fuchsia-800 text-white">
    <div class="max-w-7xl mx-auto px-6">
      <a href="/" data-i18n="back.home" class="inline-flex items-center gap-2 text-white/65 hover:text-white text-sm mb-6 transition-colors">
        ← Volver al inicio
      </a>
      <h1 class="text-4xl font-extrabold mb-2" data-t-es="Análisis de frecuencia regional" data-t-en="Regional Frequency Analysis">Análisis de frecuencia regional</h1>
      <p class="text-white/75 text-lg max-w-3xl" data-t-es="Análisis regional por L-momentos: discordancia, heterogeneidad y curva de crecimiento GEV regional para múltiples estaciones." data-t-en="Regional L-moments analysis: discordancy, heterogeneity and regional GEV growth curve for multiple stations.">
        Análisis regional por L-momentos: discordancia, heterogeneidad y curva de crecimiento GEV regional para múltiples estaciones.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-6 py-10" id="app" data-api-url={apiUrl}>
    <div class="grid lg:grid-cols-[320px_1fr] gap-8">

      <aside class="space-y-6">
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm p-6 space-y-6">
          <div>
            <h3 class="font-semibold text-gray-800 dark:text-slate-200 mb-3 text-sm uppercase tracking-wide" data-t-es="Datos" data-t-en="Data">Datos</h3>
            <div class="grid grid-cols-2 gap-2 mb-3">
              <button id="btn-demo" class="src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 border-fuchsia-500 bg-fuchsia-50 text-fuchsia-700 dark:bg-fuchsia-900/30 dark:text-fuchsia-300">Demo</button>
              <button id="btn-upload" class="src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 border-gray-200 dark:border-slate-600 text-gray-600 dark:text-slate-400 hover:border-fuchsia-300 transition-colors" data-t-es="Subir CSV" data-t-en="Upload CSV">Subir CSV</button>
            </div>
            <input type="file" id="file-input" accept=".csv" class="hidden" />
            <p id="file-name" class="text-xs text-gray-400 dark:text-slate-500 italic">Demo: 5 estaciones sintéticas, 40 años de máximos anuales</p>
            <div id="csv-hint" class="hidden mt-2 text-xs text-gray-500 dark:text-slate-400 bg-gray-50 dark:bg-slate-700 rounded-lg p-3" data-t-es="CSV: primera columna = año (índice), columnas siguientes = nombre de estación con máximos anuales." data-t-en="CSV: first column = year (index), following columns = station name with annual maxima.">
              CSV: primera columna = año (índice), columnas siguientes = nombre de estación con máximos anuales.
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-800 dark:text-slate-200 mb-2" for="method-select" data-t-es="Método de ajuste" data-t-en="Fitting method">Método de ajuste</label>
            <select id="method-select" class="w-full rounded-lg border border-gray-200 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-fuchsia-400">
              <option value="lmom" data-t-es="L-momentos (recomendado)" data-t-en="L-moments (recommended)">L-momentos (recomendado)</option>
              <option value="mle" data-t-es="Máxima verosimilitud" data-t-en="Maximum likelihood">Máxima verosimilitud</option>
            </select>
          </div>

          <button id="run-btn" class="w-full bg-fuchsia-600 hover:bg-fuchsia-700 text-white font-semibold py-3 rounded-xl transition-colors flex items-center justify-center gap-2">
            <span id="run-label" data-t-es="Analizar región" data-t-en="Analyse region">Analizar región</span>
            <svg id="run-arrow" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
            <svg id="run-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
            </svg>
          </button>
          <div id="error-box" class="hidden bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-700 rounded-lg p-3 text-sm text-red-700 dark:text-red-300"></div>
        </div>

        <div class="bg-fuchsia-50 dark:bg-fuchsia-950/50 border border-fuchsia-100 dark:border-fuchsia-800 rounded-2xl p-5 text-sm text-fuchsia-900 dark:text-fuchsia-200 space-y-2">
          <p class="font-semibold" data-t-es="Método index-flood" data-t-en="Index-flood method">Método index-flood</p>
          <p data-t-es="Se ajusta una GEV regional a los datos normalizados por el caudal índice (media de cada estación). La curva de crecimiento se obtiene con L-momentos o MLE. Los niveles en cada estación se obtienen multiplicando la curva regional por el caudal índice de la estación." data-t-en="A regional GEV is fitted to data normalised by the index flood (mean of each station). The growth curve is obtained with L-moments or MLE. At-site levels are obtained by multiplying the regional curve by the station's index flood.">Se ajusta una GEV regional a los datos normalizados por el caudal índice (media de cada estación). La curva de crecimiento se obtiene con L-momentos o MLE. Los niveles en cada estación se obtienen multiplicando la curva regional por el caudal índice de la estación.</p>
        </div>
      </aside>

      <main>
        <div id="placeholder" class="min-h-[430px] flex flex-col items-center justify-center text-center rounded-2xl border-2 border-dashed border-gray-200 dark:border-slate-700 p-12">
          <div class="w-16 h-16 rounded-2xl bg-fuchsia-100 dark:bg-fuchsia-900/40 text-fuchsia-800 dark:text-fuchsia-300 flex items-center justify-center mb-4">
            <svg class="w-9 h-9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M3 19 Q5 14 7 12" stroke-width="1.2" stroke-opacity="0.5"/>
              <path d="M6 19 Q8 13 10 10" stroke-width="1.2" stroke-opacity="0.5"/>
              <path d="M9 19 Q11 12 13 9" stroke-width="1.2" stroke-opacity="0.5"/>
              <path d="M5 20 Q10 10 17 5" stroke-width="2" stroke-linecap="round"/>
              <circle cx="17" cy="5" r="2" fill="currentColor" stroke="none"/>
              <line x1="2" y1="20" x2="22" y2="20" stroke-width="1.2"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-700 dark:text-slate-300 mb-2" data-t-es="Listo para el análisis regional" data-t-en="Ready for regional analysis">Listo para el análisis regional</h3>
          <p class="text-gray-400 dark:text-slate-500 max-w-md" data-t-es="Ejecuta la demo o sube un CSV con máximos anuales de múltiples estaciones." data-t-en="Run the demo or upload a CSV with annual maxima from multiple stations.">Ejecuta la demo o sube un CSV con máximos anuales de múltiples estaciones.</p>
        </div>

        <div id="results" class="hidden space-y-8">
          <div id="stats-row" class="grid grid-cols-2 lg:grid-cols-4 gap-4"></div>

          <div class="grid lg:grid-cols-[1fr_340px] gap-8">
            <div class="space-y-6">
              <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm p-6">
                <h3 class="font-semibold text-gray-800 dark:text-slate-200 mb-1" data-t-es="Curva de crecimiento regional (normalizada)" data-t-en="Regional growth curve (normalised)">Curva de crecimiento regional (normalizada)</h3>
                <p class="text-sm text-gray-400 dark:text-slate-500 mb-4" data-t-es="Factor de crecimiento q(T) = nivel(T) / caudal índice. Curva GEV regional ajustada a datos normalizados." data-t-en="Growth factor q(T) = level(T) / index flood. Regional GEV fitted to normalised data.">Factor de crecimiento q(T) = nivel(T) / caudal índice. Curva GEV regional ajustada a datos normalizados.</p>
                <div id="chart-growth" class="h-64"></div>
              </div>
              <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm p-6">
                <h3 class="font-semibold text-gray-800 dark:text-slate-200 mb-1" data-t-es="Niveles de retorno por estación" data-t-en="At-site return levels">Niveles de retorno por estación</h3>
                <p class="text-sm text-gray-400 dark:text-slate-500 mb-4" data-t-es="Niveles en unidades originales = curva regional × caudal índice de cada estación." data-t-en="Levels in original units = regional curve × index flood per station.">Niveles en unidades originales = curva regional × caudal índice de cada estación.</p>
                <div id="chart-atsite" class="h-64"></div>
              </div>
            </div>

            <div class="space-y-6">
              <div id="heterogeneity-card" class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm p-5">
                <h3 class="font-semibold text-gray-800 dark:text-slate-200 mb-3" data-t-es="Heterogeneidad" data-t-en="Heterogeneity">Heterogeneidad</h3>
                <div id="het-content"></div>
              </div>
              <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm p-5">
                <h3 class="font-semibold text-gray-800 dark:text-slate-200 mb-3" data-t-es="Parámetros GEV regional" data-t-en="Regional GEV parameters">Parámetros GEV regional</h3>
                <div id="params-content" class="space-y-2"></div>
              </div>
            </div>
          </div>

          <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm p-6">
            <h3 class="font-semibold text-gray-800 dark:text-slate-200 mb-4" data-t-es="Discordancia por estación" data-t-en="Discordancy by station">Discordancia por estación</h3>
            <div class="overflow-auto">
              <table class="w-full text-sm">
                <thead class="text-left text-gray-500 dark:text-slate-400">
                  <tr>
                    <th class="py-2 pr-6" data-t-es="Estación" data-t-en="Station">Estación</th>
                    <th class="py-2 px-3 text-right">Di</th>
                    <th class="py-2 px-3" data-t-es="Estado" data-t-en="Status">Estado</th>
                  </tr>
                </thead>
                <tbody id="discordancy-table" class="divide-y divide-gray-100 dark:divide-slate-700"></tbody>
              </table>
            </div>
          </div>

          <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm p-6">
            <h3 class="font-semibold text-gray-800 dark:text-slate-200 mb-4" data-t-es="Niveles en cada estación (unidades originales)" data-t-en="At-site return levels (original units)">Niveles en cada estación (unidades originales)</h3>
            <div class="overflow-auto" id="at-site-wrapper"></div>
          </div>
        </div>
      </main>
    </div>
  </div>
</Layout>

<script>
declare const Plotly: any;

const t = (es: string, en: string) => document.documentElement.lang === 'en' ? en : es;

const FUCHSIA = '#a21caf';
const COLORS  = ['#2563eb','#16a34a','#dc2626','#d97706','#7c3aed','#0891b2','#be185d'];

const isDark = () => document.documentElement.classList.contains('dark');
const grid = () => isDark() ? '#334155' : '#e2e8f0';
const fontColor = () => isDark() ? '#94a3b8' : '#6b7280';

const layoutBase = {
  paper_bgcolor: 'transparent',
  plot_bgcolor:  'transparent',
  margin: { t: 20, r: 16, b: 52, l: 58 },
  font: { family: 'Inter, system-ui, sans-serif', size: 11 },
};

let useDemo = true;
let isRunning = false;

const appEl       = document.getElementById('app')!;
const apiUrl      = appEl.dataset.apiUrl!;
const btnDemo     = document.getElementById('btn-demo')!;
const btnUpload   = document.getElementById('btn-upload')!;
const fileInput   = document.getElementById('file-input') as HTMLInputElement;
const fileNameEl  = document.getElementById('file-name')!;
const csvHintEl   = document.getElementById('csv-hint')!;
const runBtn      = document.getElementById('run-btn')!;
const runLabel    = document.getElementById('run-label')!;
const runArrow    = document.getElementById('run-arrow')!;
const runSpinner  = document.getElementById('run-spinner')!;
const errorBox    = document.getElementById('error-box')!;
const placeholder = document.getElementById('placeholder')!;
const resultsEl   = document.getElementById('results')!;

function setSource(demo: boolean) {
  useDemo = demo;
  btnDemo.className   = `src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 transition-colors ${demo ? 'border-fuchsia-500 bg-fuchsia-50 text-fuchsia-700' : 'border-gray-200 text-gray-600 hover:border-fuchsia-300'}`;
  btnUpload.className = `src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 transition-colors ${!demo ? 'border-fuchsia-500 bg-fuchsia-50 text-fuchsia-700' : 'border-gray-200 text-gray-600 hover:border-fuchsia-300'}`;
  csvHintEl.classList.toggle('hidden', demo);
  if (demo) fileNameEl.textContent = t('Demo: 5 estaciones sintéticas, 40 años de máximos anuales', 'Demo: 5 synthetic stations, 40 years of annual maxima');
}

function setRunning(r: boolean) {
  isRunning = r;
  (runBtn as HTMLButtonElement).disabled = r;
  runLabel.textContent = r ? t('Analizando...', 'Analysing...') : t('Analizar región', 'Analyse region');
  runArrow.classList.toggle('hidden', r);
  runSpinner.classList.toggle('hidden', !r);
}

function showError(msg: string) { errorBox.textContent = msg; errorBox.classList.remove('hidden'); }
function clearError() { errorBox.classList.add('hidden'); errorBox.textContent = ''; }

btnDemo.addEventListener('click', () => setSource(true));
btnUpload.addEventListener('click', () => fileInput.click());
fileInput.addEventListener('change', () => {
  if (fileInput.files?.[0]) { setSource(false); fileNameEl.textContent = fileInput.files[0].name; }
});

runBtn.addEventListener('click', async () => {
  if (isRunning) return;
  clearError();
  if (!useDemo && !fileInput.files?.[0]) { showError(t('Selecciona un CSV o vuelve a usar los datos demo.', 'Select a CSV or switch back to demo data.')); return; }
  setRunning(true);

  const fd = new FormData();
  fd.append('demo',   useDemo ? 'true' : 'false');
  fd.append('method', (document.getElementById('method-select') as HTMLSelectElement).value);
  if (!useDemo && fileInput.files?.[0]) fd.append('file', fileInput.files[0]);

  try {
    const res = await fetch(`${apiUrl}/api/rfa/analyze`, { method: 'POST', body: fd });
    if (!res.ok) { const err = await res.json(); throw new Error(err.detail ?? t('Error en el servidor', 'Server error')); }
    renderResults(await res.json());
  } catch (err: any) {
    showError(err.message ?? t('Error desconocido', 'Unknown error'));
  } finally {
    setRunning(false);
  }
});

function statCard(label: string, value: string, unit = '') {
  return `<div class="bg-gray-50 dark:bg-slate-800 rounded-xl p-4 border border-gray-100 dark:border-slate-700">
    <p class="text-xs text-gray-400 dark:text-slate-500 uppercase tracking-wide mb-2">${label}</p>
    <p class="text-2xl font-bold text-gray-900 dark:text-white">${value}</p>
    <p class="text-xs text-gray-400 dark:text-slate-500 mt-1">${unit}</p>
  </div>`;
}

function renderResults(data: any) {
  placeholder.classList.add('hidden');
  resultsEl.classList.remove('hidden');

  const s = data.summary;
  const nFlagged = (data.discordancy as any[]).filter(d => d.flagged).length;

  document.getElementById('stats-row')!.innerHTML =
    statCard(t('Estaciones', 'Stations'), `${s.n_stations}`, s.stations.join(', ').substring(0, 40)) +
    statCard(t('Método', 'Method'), s.method === 'lmom' ? t('L-momentos', 'L-moments') : 'MLE', t('ajuste GEV', 'GEV fit')) +
    statCard(t('Discordantes', 'Discordant'), `${nFlagged}`, 'Di > 3') +
    statCard('H', `${data.heterogeneity.H ?? '—'}`, data.heterogeneity.interpretation);

  // Regional growth curve (normalised — show only regional line)
  const gc = data.growth_curve as {T: number, quantile: number}[];
  const Ts = gc.map(d => d.T);
  const qs = gc.map(d => d.quantile);

  Plotly.newPlot('chart-growth', [
    { x: Ts, y: qs, mode: 'lines+markers', name: t('Curva regional', 'Regional curve'),
      line: { color: FUCHSIA, width: 3 }, marker: { size: 7, color: FUCHSIA } },
  ], {
    ...layoutBase,
    font: { ...layoutBase.font, color: fontColor() },
    xaxis: { title: t('Periodo de retorno (años)', 'Return period (years)'), type: 'log', gridcolor: grid() },
    yaxis: { title: t('Factor de crecimiento q(T)', 'Growth factor q(T)'), gridcolor: grid() },
    showlegend: false,
  }, { responsive: true, displayModeBar: false });

  // At-site return level curves (original units)
  const stations = s.stations as string[];
  const atSiteTraces: any[] = stations.map((st, i) => {
    const levels = data.at_site_levels[st] as {T: number, level: number}[];
    return {
      x: levels.map(d => d.T),
      y: levels.map(d => d.level),
      mode: 'lines+markers',
      name: st,
      line: { color: COLORS[i % COLORS.length], width: 2 },
      marker: { size: 5 },
    };
  });

  Plotly.newPlot('chart-atsite', atSiteTraces, {
    ...layoutBase,
    font: { ...layoutBase.font, color: fontColor() },
    xaxis: { title: t('Periodo de retorno (años)', 'Return period (years)'), type: 'log', gridcolor: grid() },
    yaxis: { title: t('Nivel (unidades originales)', 'Level (original units)'), gridcolor: grid() },
    legend: { orientation: 'h', y: -0.3 },
  }, { responsive: true, displayModeBar: false });

  // Heterogeneity card
  const het = data.heterogeneity;
  const hetColor = het.H == null ? 'gray' : het.H < 1 ? 'green' : het.H < 2 ? 'amber' : 'red';
  const hetBg: Record<string,string> = {
    gray:  'bg-gray-50 dark:bg-gray-800/60 border-gray-200 dark:border-gray-700',
    green: 'bg-green-50 dark:bg-green-950/40 border-green-200 dark:border-green-800',
    amber: 'bg-amber-50 dark:bg-amber-950/40 border-amber-200 dark:border-amber-700',
    red:   'bg-red-50 dark:bg-red-950/40 border-red-200 dark:border-red-800',
  };
  const hetText: Record<string,string> = {
    gray:  'text-gray-700 dark:text-gray-300',
    green: 'text-green-700 dark:text-green-400',
    amber: 'text-amber-700 dark:text-amber-400',
    red:   'text-red-700 dark:text-red-400',
  };
  document.getElementById('het-content')!.innerHTML = `
    <div class="rounded-xl border p-4 ${hetBg[hetColor]}">
      <p class="text-2xl font-bold ${hetText[hetColor]} mb-1">H = ${het.H ?? '—'}</p>
      <p class="text-sm ${hetText[hetColor]}">${het.interpretation}</p>
    </div>`;

  // Regional params
  const rp = data.regional_params;
  document.getElementById('params-content')!.innerHTML = [
    ['μ (loc)', rp.mu],
    ['σ (scale)', rp.sigma],
    ['ξ (shape)', rp.xi],
  ].map(([name, val]) =>
    `<div class="flex justify-between rounded-lg bg-gray-50 dark:bg-slate-700 px-4 py-2.5 border border-gray-100 dark:border-slate-600">
      <span class="text-sm text-gray-500 dark:text-slate-400">${name}</span>
      <span class="text-sm font-bold text-gray-900 dark:text-white">${val ?? '—'}</span>
    </div>`
  ).join('');

  // Discordancy table
  document.getElementById('discordancy-table')!.innerHTML =
    (data.discordancy as {station: string, Di: number, flagged: boolean}[]).map(d =>
      `<tr class="hover:bg-gray-50 dark:hover:bg-slate-700/50 ${d.flagged ? 'bg-red-50 dark:bg-red-950/30' : ''}">
        <td class="py-2 pr-6 font-medium text-gray-800 dark:text-slate-200">${d.station}</td>
        <td class="py-2 px-3 text-right font-semibold ${d.flagged ? 'text-red-700 dark:text-red-400' : 'text-gray-700 dark:text-slate-300'}">${d.Di}</td>
        <td class="py-2 px-3">
          ${d.flagged
            ? `<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-red-100 dark:bg-red-900/50 text-red-700 dark:text-red-300">${t('Discordante (Di>3)', 'Discordant (Di>3)')}</span>`
            : `<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 dark:bg-green-900/50 text-green-700 dark:text-green-300">OK</span>`
          }
        </td>
      </tr>`
    ).join('');

  // At-site table
  const periods = [2, 5, 10, 25, 50, 100, 200, 500];
  let html = `<table class="w-full text-sm min-w-[500px]">
    <thead class="text-left text-gray-500 dark:text-slate-400"><tr>
      <th class="py-2 pr-4">${t('Estación', 'Station')}</th>
      ${periods.map(T => `<th class="py-2 px-2 text-right">T${T}</th>`).join('')}
    </tr></thead>
    <tbody class="divide-y divide-gray-100 dark:divide-slate-700">`;
  stations.forEach(st => {
    const levels = data.at_site_levels[st] as {T: number, level: number | null}[];
    html += `<tr class="hover:bg-gray-50 dark:hover:bg-slate-700/50">
      <td class="py-2 pr-4 font-medium text-gray-800 dark:text-slate-200">${st}</td>
      ${levels.map(l => `<td class="py-2 px-2 text-right text-gray-700 dark:text-slate-300">${l.level != null ? l.level.toFixed(1) : '—'}</td>`).join('')}
    </tr>`;
  });
  html += '</tbody></table>';
  document.getElementById('at-site-wrapper')!.innerHTML = html;
}
</script>
