---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Descarga AEMET — HYDRA">
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />
  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
    is:inline
  ></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js" is:inline></script>

  <section class="pt-24 pb-10 bg-gradient-to-br from-slate-950 via-orange-950 to-orange-800 text-white">
    <div class="max-w-7xl mx-auto px-6">
      <a href="/" class="inline-flex items-center gap-2 text-white/65 hover:text-white text-sm mb-6 transition-colors">
        ← Volver al inicio
      </a>
      <h1 class="text-4xl font-extrabold mb-2">Descarga AEMET OpenData</h1>
      <p class="text-white/76 text-lg max-w-3xl">
        Visualiza la red completa de estaciones AEMET en el mapa, selecciona estación, periodo y descarga datos diarios u horarios en CSV.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-6 py-10">
    <div class="grid lg:grid-cols-[340px_1fr] gap-8">

      <!-- ── PANEL DE CONTROL ── -->
      <aside class="space-y-6">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 space-y-5">

          <!-- API Key -->
          <div>
            <label class="block text-sm font-semibold text-gray-800 mb-2" for="api-key">
              API Key AEMET
            </label>
            <input
              id="api-key"
              type="password"
              placeholder="Tu clave de opendata.aemet.es"
              autocomplete="off"
              class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400"
            />
            <p class="mt-1.5 text-xs text-gray-400">
              Obtén tu clave gratuita en
              <a href="https://opendata.aemet.es/centrodedescargas/altaUsuario" target="_blank" rel="noopener"
                 class="text-orange-600 hover:underline">opendata.aemet.es</a>
            </p>
          </div>

          <!-- Cargar estaciones -->
          <button id="load-stations-btn"
            class="w-full bg-orange-600 hover:bg-orange-700 text-white font-semibold py-2.5 rounded-xl text-sm transition-colors flex items-center justify-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/>
            </svg>
            Cargar estaciones
          </button>
          <p id="stations-count" class="text-xs text-gray-400 -mt-2 text-center">
            Introduce tu API key y pulsa para cargar las estaciones.
          </p>

          <!-- Estación seleccionada -->
          <div class="rounded-xl bg-orange-50 border border-orange-100 p-4">
            <p class="text-xs font-semibold text-orange-700 uppercase tracking-wide mb-1">Estación seleccionada</p>
            <p id="selected-name" class="font-semibold text-gray-900 text-sm">—</p>
            <p id="selected-meta" class="text-xs text-gray-500 mt-0.5">Haz clic en una estación del mapa</p>
          </div>

          <!-- Fechas -->
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-semibold text-gray-800 mb-2" for="start-date">Inicio</label>
              <input id="start-date" type="date" value="2020-01-01"
                class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-800 mb-2" for="end-date">Fin</label>
              <input id="end-date" type="date" value="2020-12-31"
                class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
            </div>
          </div>

          <!-- Frecuencia -->
          <div>
            <label class="block text-sm font-semibold text-gray-800 mb-2">Frecuencia</label>
            <div class="flex gap-2">
              <label class="flex-1 flex items-center justify-center gap-2 rounded-lg border border-gray-200 py-2 text-sm cursor-pointer has-[:checked]:border-orange-500 has-[:checked]:bg-orange-50 dark:has-[:checked]:bg-orange-900/20 dark:has-[:checked]:border-orange-400 dark:text-gray-200">
                <input type="radio" name="freq" value="daily" checked class="accent-orange-600" />
                Diaria
              </label>
              <label class="flex-1 flex items-center justify-center gap-2 rounded-lg border border-gray-200 py-2 text-sm cursor-pointer has-[:checked]:border-orange-500 has-[:checked]:bg-orange-50 dark:has-[:checked]:bg-orange-900/20 dark:has-[:checked]:border-orange-400 dark:text-gray-200">
                <input type="radio" name="freq" value="hourly" class="accent-orange-600" />
                Horaria
              </label>
            </div>
            <p class="mt-1.5 text-xs text-gray-400">Horaria: máx. recomendado ~31 días por petición.</p>
          </div>

          <button id="load-btn"
            class="w-full bg-hydra-600 hover:bg-hydra-700 text-white font-semibold py-3 rounded-xl transition-colors">
            Cargar datos
          </button>
          <button id="download-btn" disabled
            class="w-full border border-gray-200 text-gray-400 font-semibold py-3 rounded-xl transition-colors disabled:opacity-50 disabled:cursor-not-allowed hover:not-disabled:border-orange-300">
            Descargar CSV
          </button>
          <div id="error-box" class="hidden bg-red-50 border border-red-200 rounded-lg p-3 text-sm text-red-700"></div>
        </div>

        <div class="bg-orange-50 border border-orange-100 rounded-2xl p-5 text-sm text-orange-900 space-y-2">
          <p class="font-semibold">Datos disponibles</p>
          <p><strong>Diarios:</strong> prec, tmed/tmin/tmax, viento, racha, sol, presión.</p>
          <p><strong>Horarios:</strong> temp, humedad, viento, presión, precipitación.</p>
        </div>
      </aside>

      <!-- ── PANEL PRINCIPAL ── -->
      <main class="space-y-8 min-w-0">

        <!-- Mapa -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
          <div class="flex flex-wrap items-start justify-between gap-4 mb-5">
            <div>
              <h3 class="font-semibold text-gray-800 mb-1">Red de estaciones AEMET</h3>
              <p id="stations-count-map" class="text-sm text-gray-400">
                Carga las estaciones para verlas en el mapa.
              </p>
            </div>
          </div>
          <div id="aemet-map" class="relative z-0 h-[440px] min-h-[360px] w-full rounded-xl border border-gray-100 overflow-hidden bg-slate-100"></div>
        </div>

        <!-- Stats y preview -->
        <div id="data-panel" class="hidden space-y-6">
          <div class="grid md:grid-cols-4 gap-4">
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">Indicativo</p>
              <p id="stat-station" class="text-xl font-bold text-gray-900">—</p>
            </div>
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">Registros</p>
              <p id="stat-rows" class="text-xl font-bold text-gray-900">—</p>
            </div>
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">Inicio</p>
              <p id="stat-start" class="text-xl font-bold text-gray-900">—</p>
            </div>
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">Fin</p>
              <p id="stat-end" class="text-xl font-bold text-gray-900">—</p>
            </div>
          </div>

          <!-- Gráfica -->
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 space-y-4">
            <div>
              <h3 class="font-semibold text-gray-800 mb-3">Visualización de variables</h3>
              <p class="text-xs text-gray-400 mb-3">Activa/desactiva variables. Eje izquierdo = primera variable activa · Eje derecho = segunda.</p>
              <div id="var-toggles" class="flex flex-wrap gap-2"></div>
            </div>
            <div class="relative" style="height:380px">
              <canvas id="data-chart"></canvas>
            </div>
          </div>
        </div>

        <div id="loading-msg" class="hidden text-center py-16 text-gray-400">
          <div class="inline-block h-8 w-8 animate-spin rounded-full border-4 border-orange-300 border-t-orange-600 mb-4"></div>
          <p class="font-medium">Cargando datos de AEMET…</p>
        </div>
      </main>
    </div>
  </div>
</Layout>

<style>
  :global(.leaflet-popup-content-wrapper) { border-radius: 8px; }
  :global(.leaflet-container) { font-family: Inter, system-ui, sans-serif; }
</style>

<script>
declare const L: any;
declare const Chart: any;

type AemetStation = {
  indicativo: string;
  nombre: string;
  provincia: string;
  altitud: number | null;
  latitude: number;
  longitude: number;
};

// DOM refs
const apiKeyEl         = document.getElementById('api-key') as HTMLInputElement;
const loadStationsBtn  = document.getElementById('load-stations-btn')!;
const stationsCountEl  = document.getElementById('stations-count')!;
const stationsCountMap = document.getElementById('stations-count-map')!;
const selectedNameEl   = document.getElementById('selected-name')!;
const selectedMetaEl   = document.getElementById('selected-meta')!;
const startDateEl      = document.getElementById('start-date') as HTMLInputElement;
const endDateEl        = document.getElementById('end-date') as HTMLInputElement;
const loadBtn          = document.getElementById('load-btn')!;
const downloadBtn      = document.getElementById('download-btn') as HTMLButtonElement;
const errorBox         = document.getElementById('error-box')!;
const dataPanel        = document.getElementById('data-panel')!;
const loadingMsg       = document.getElementById('loading-msg')!;

let map: any = null;
const stationMarkers: any[] = [];
let allStations: AemetStation[] = [];
let selectedStation: AemetStation | null = null;
let lastData: { station: string; start: string; end: string; freq: string } | null = null;
let chart: any = null;
let chartRows: Record<string, any>[] = [];
let activeVars: Set<string> = new Set();

const PALETTE = ['#f97316','#0891b2','#10b981','#8b5cf6','#ef4444','#f59e0b','#06b6d4','#ec4899'];

function buildVarToggles(columns: string[]) {
  const numCols = columns.filter(c => c !== 'fecha' && c !== 'hora');
  const container = document.getElementById('var-toggles')!;
  container.innerHTML = '';
  activeVars.clear();
  numCols.forEach((col, i) => {
    const color = PALETTE[i % PALETTE.length];
    const on = i < 4;
    if (on) activeVars.add(col);
    const btn = document.createElement('button');
    btn.className = 'var-btn px-3 py-1.5 rounded-full text-xs font-semibold border-2 transition-all cursor-pointer';
    btn.textContent = col;
    const setStyle = (active: boolean) => {
      btn.style.borderColor = color;
      btn.style.backgroundColor = active ? color + '22' : 'transparent';
      btn.style.color = active ? color : '#9ca3af';
    };
    setStyle(on);
    btn.addEventListener('click', () => {
      const has = activeVars.has(col);
      if (has) activeVars.delete(col); else activeVars.add(col);
      setStyle(!has);
      renderChart();
    });
    container.appendChild(btn);
  });
}

function renderChart() {
  if (!chartRows.length || !activeVars.size) return;
  const isDark = document.documentElement.classList.contains('dark');
  const gridColor  = isDark ? 'rgba(148,163,184,0.12)' : 'rgba(0,0,0,0.07)';
  const tickColor  = isDark ? '#94a3b8' : '#6b7280';
  const hasHora = chartRows[0] && 'hora' in chartRows[0];
  const labels = hasHora
    ? chartRows.map(r => `${r.fecha} ${r.hora}`)
    : chartRows.map(r => r.fecha ?? '');
  const varList = [...activeVars];
  const datasets = varList.map((col, i) => ({
    label: col,
    data: chartRows.map(r => (r[col] !== null && r[col] !== undefined ? Number(r[col]) : null)),
    borderColor:     PALETTE[i % PALETTE.length],
    backgroundColor: PALETTE[i % PALETTE.length] + '18',
    borderWidth: 1.5,
    pointRadius: chartRows.length > 500 ? 0 : 2,
    tension: 0.3,
    yAxisID: i === 1 ? 'yR' : 'yL',
    spanGaps: true,
  }));
  if (chart) { chart.destroy(); chart = null; }
  const ctx = (document.getElementById('data-chart') as HTMLCanvasElement).getContext('2d')!;
  chart = new Chart(ctx, {
    type: 'line',
    data: { labels, datasets },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      interaction: { mode: 'index', intersect: false },
      plugins: { legend: { position: 'top', labels: { usePointStyle: true, pointStyleWidth: 10, color: tickColor } } },
      scales: {
        x:  { ticks: { maxTicksLimit: 10, maxRotation: 0, color: tickColor }, grid: { color: gridColor } },
        yL: { type: 'linear', position: 'left',
               title: { display: true, text: varList[0] ?? '', color: tickColor },
               ticks: { color: tickColor }, grid: { color: gridColor } },
        ...(varList.length > 1 ? { yR: {
          type: 'linear', position: 'right',
          title: { display: true, text: varList[1], color: tickColor },
          ticks: { color: tickColor }, grid: { drawOnChartArea: false },
        } } : {}),
      },
    },
  });
}

function showError(msg: string) {
  errorBox.textContent = msg;
  errorBox.classList.remove('hidden');
}
function clearError() {
  errorBox.textContent = '';
  errorBox.classList.add('hidden');
}
function freq(): string {
  return (document.querySelector('input[name="freq"]:checked') as HTMLInputElement)?.value ?? 'daily';
}

(window as any).__aemetSelect = (indicativo: string) => {
  const st = allStations.find(s => s.indicativo === indicativo);
  if (st) { selectStation(st); map?.closePopup(); }
};

function markerStyle(active = false) {
  return {
    radius:      active ? 9 : 5,
    color:       active ? '#0f172a' : '#ffffff',
    weight:      active ? 2.5 : 1.5,
    fillColor:   active ? '#f97316' : '#ea580c',
    fillOpacity: active ? 1 : 0.82,
  };
}

function selectStation(st: AemetStation) {
  selectedStation = st;
  selectedNameEl.textContent = st.nombre;
  const lonDir = st.longitude >= 0 ? 'E' : 'O';
  selectedMetaEl.textContent =
    `${st.indicativo} · ${st.provincia}` +
    ` · ${st.latitude.toFixed(3)}°N, ${Math.abs(st.longitude).toFixed(3)}°${lonDir}` +
    (st.altitud != null ? ` · ${st.altitud} m` : '');
  stationMarkers.forEach(m =>
    m.setStyle(markerStyle(m._stData?.indicativo === st.indicativo))
  );
}

function initMap() {
  const mapEl = document.getElementById('aemet-map');
  if (!mapEl || typeof L === 'undefined') return;
  map = L.map('aemet-map', { scrollWheelZoom: false }).setView([40.4, -3.7], 6);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 18,
    attribution: '&copy; OpenStreetMap',
  }).addTo(map);
  window.setTimeout(() => map.invalidateSize(), 0);
  window.addEventListener('resize', () => map.invalidateSize());
}

function clearMarkers() {
  stationMarkers.forEach(m => m.remove());
  stationMarkers.length = 0;
}

async function loadStations() {
  const apiKey = apiKeyEl.value.trim();
  if (!apiKey) { showError('Introduce tu API key de AEMET para cargar las estaciones.'); return; }
  clearError();

  (loadStationsBtn as HTMLButtonElement).disabled = true;
  stationsCountEl.textContent = 'Cargando estaciones AEMET…';
  stationsCountMap.textContent = 'Cargando estaciones…';

  try {
    const res = await fetch(`/api/aemet/stations?api_key=${encodeURIComponent(apiKey)}`);
    const data = await res.json();
    if (!res.ok) throw new Error(data.detail ?? 'Error cargando estaciones');

    allStations = data.stations ?? [];
    clearMarkers();

    const txt = `${allStations.length} estaciones disponibles en AEMET.`;
    stationsCountEl.textContent = txt;
    stationsCountMap.textContent = txt;

    allStations.forEach(st => {
      const m = L.circleMarker([st.latitude, st.longitude], markerStyle(false)).addTo(map);
      m._stData = st;
      const lonDir = st.longitude >= 0 ? 'E' : 'O';
      m.bindPopup(`
        <div style="min-width:170px;font-size:13px">
          <p style="font-weight:700;margin:0 0 2px">${st.nombre}</p>
          <p style="color:#6b7280;margin:0 0 2px">${st.indicativo} · ${st.provincia}</p>
          <p style="color:#6b7280;margin:0 0 8px">${st.latitude.toFixed(4)}°N, ${Math.abs(st.longitude).toFixed(4)}°${lonDir}${st.altitud != null ? ` · ${st.altitud} m` : ''}</p>
          <button type="button"
            onclick="window.__aemetSelect('${st.indicativo}')"
            style="width:100%;background:#f97316;color:#fff;font-weight:600;font-size:12px;padding:6px 10px;border-radius:6px;border:none;cursor:pointer">
            Seleccionar estación
          </button>
        </div>
      `);
      m.on('click', () => selectStation(st));
      stationMarkers.push(m);
    });

    if (allStations.length > 0) {
      map.fitBounds(
        L.latLngBounds(allStations.map((s: AemetStation) => [s.latitude, s.longitude])),
        { padding: [20, 20], maxZoom: 8 }
      );
    }
  } catch (err: any) {
    const msg = err.message ?? 'Error desconocido';
    showError(msg);
    stationsCountEl.textContent = 'Error cargando estaciones.';
    stationsCountMap.textContent = 'Error cargando estaciones.';
  } finally {
    (loadStationsBtn as HTMLButtonElement).disabled = false;
  }
}

async function loadData() {
  clearError();
  const apiKey = apiKeyEl.value.trim();
  if (!apiKey) { showError('Introduce tu API key de AEMET.'); return; }
  if (!selectedStation) { showError('Selecciona primero una estación en el mapa.'); return; }
  const start = startDateEl.value;
  const end   = endDateEl.value;
  if (!start || !end || end < start) { showError('El periodo no es válido.'); return; }
  const f = freq();

  dataPanel.classList.add('hidden');
  loadingMsg.classList.remove('hidden');
  (loadBtn as HTMLButtonElement).disabled = true;
  downloadBtn.disabled = true;

  try {
    const url =
      `/api/aemet/data?station=${encodeURIComponent(selectedStation.indicativo)}` +
      `&start=${start}&end=${end}&freq=${f}&api_key=${encodeURIComponent(apiKey)}`;
    const res  = await fetch(url);
    const data = await res.json();
    if (!res.ok) throw new Error(data.detail ?? 'Error cargando datos');

    document.getElementById('stat-station')!.textContent = selectedStation.indicativo;
    document.getElementById('stat-rows')!.textContent    = String(data.n_rows);
    document.getElementById('stat-start')!.textContent   = start;
    document.getElementById('stat-end')!.textContent     = end;
    chartRows = data.preview;
    buildVarToggles(data.columns);
    renderChart();

    lastData = { station: selectedStation.indicativo, start, end, freq: f };
    downloadBtn.disabled = false;
    dataPanel.classList.remove('hidden');
  } catch (err: any) {
    showError(err.message ?? 'Error desconocido');
  } finally {
    loadingMsg.classList.add('hidden');
    (loadBtn as HTMLButtonElement).disabled = false;
  }
}

async function downloadCsv() {
  if (!lastData) return;
  const apiKey = apiKeyEl.value.trim();
  const { station, start, end, freq: f } = lastData;
  const url =
    `/api/aemet/data?station=${encodeURIComponent(station)}` +
    `&start=${start}&end=${end}&freq=${f}&api_key=${encodeURIComponent(apiKey)}&download=true`;
  const a = document.createElement('a');
  a.href = url;
  a.download = `aemet_${station}_${start}_${end}_${f === 'hourly' ? 'horario' : 'diario'}.csv`;
  a.click();
}

loadStationsBtn.addEventListener('click', loadStations);
loadBtn.addEventListener('click', loadData);
downloadBtn.addEventListener('click', downloadCsv);

initMap();
</script>
