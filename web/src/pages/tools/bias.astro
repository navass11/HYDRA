---
import Layout from '../../layouts/Layout.astro';
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<Layout title="Corrección de sesgo — HYDRA">
  <script src="https://cdn.plot.ly/plotly-2.32.0.min.js" is:inline></script>

  <section class="pt-24 pb-10 bg-gradient-to-br from-slate-950 via-cyan-950 to-cyan-700 text-white">
    <div class="max-w-7xl mx-auto px-6">
      <a href="/" data-i18n="back.home" class="inline-flex items-center gap-2 text-white/65 hover:text-white text-sm mb-6 transition-colors">
        ← Volver al inicio
      </a>
      <h1 class="text-4xl font-extrabold mb-2" data-t-es="Corrección de sesgo" data-t-en="Bias Correction">Corrección de sesgo</h1>
      <p class="text-white/75 text-lg max-w-3xl" data-t-es="Aplica quantile mapping entre serie observada e histórica del modelo. Visualiza QQ-plot y estadísticas antes y después de la corrección." data-t-en="Applies quantile mapping between observed and model historical series. Visualises QQ-plot and statistics before and after correction.">
        Aplica quantile mapping entre serie observada e histórica del modelo. Visualiza QQ-plot y estadísticas antes y después de la corrección.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-6 py-10" id="app" data-api-url={apiUrl}>
    <div class="grid lg:grid-cols-[350px_1fr] gap-8">

      <aside class="space-y-6">
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm p-6 space-y-6">
          <div>
            <h3 class="font-semibold text-gray-800 dark:text-slate-200 mb-3 text-sm uppercase tracking-wide" data-t-es="Datos" data-t-en="Data">Datos</h3>
            <div class="grid grid-cols-2 gap-2 mb-3">
              <button id="btn-demo" class="src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 border-cyan-500 bg-cyan-50 text-cyan-700 dark:bg-cyan-900/30 dark:text-cyan-300">Demo</button>
              <button id="btn-upload" class="src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 border-gray-200 dark:border-slate-600 text-gray-600 dark:text-slate-400 hover:border-cyan-300 transition-colors" data-t-es="Subir CSV" data-t-en="Upload CSV">Subir CSV</button>
            </div>
            <div id="upload-area" class="hidden space-y-3">
              <div>
                <label class="block text-xs font-semibold text-gray-600 dark:text-slate-400 mb-1" data-t-es="Serie observada histórica" data-t-en="Historical observed series">Serie observada histórica</label>
                <input type="file" id="file-obs" accept=".csv" class="w-full text-xs text-gray-500 dark:text-slate-400 file:mr-2 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-cyan-50 file:text-cyan-700 hover:file:bg-cyan-100" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-gray-600 dark:text-slate-400 mb-1" data-t-es="Modelo histórico" data-t-en="Historical model">Modelo histórico</label>
                <input type="file" id="file-mod-hist" accept=".csv" class="w-full text-xs text-gray-500 dark:text-slate-400 file:mr-2 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-cyan-50 file:text-cyan-700 hover:file:bg-cyan-100" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-gray-600 dark:text-slate-400 mb-1" data-t-es="Modelo futuro (opcional)" data-t-en="Future model (optional)">Modelo futuro (opcional)</label>
                <input type="file" id="file-mod-future" accept=".csv" class="w-full text-xs text-gray-500 dark:text-slate-400 file:mr-2 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-cyan-50 file:text-cyan-700 hover:file:bg-cyan-100" />
              </div>
              <p class="text-xs text-gray-400 dark:text-slate-500" data-t-es="CSV: fecha, valor (o solo columna de valores)." data-t-en="CSV: date, value (or value column only).">CSV: fecha, valor (o solo columna de valores).</p>
            </div>
            <p id="demo-note" class="text-xs text-gray-400 dark:text-slate-500 italic" data-t-es="Demo: 30 años precipitación diaria con sesgo húmedo en el modelo (+40%)" data-t-en="Demo: 30 years daily precipitation with wet bias in model (+40%)">Demo: 30 años precipitación diaria con sesgo húmedo en el modelo (+40%)</p>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-800 dark:text-slate-200 mb-2" for="method-select" data-t-es="Método" data-t-en="Method">Método</label>
            <select id="method-select" class="w-full rounded-lg border border-gray-200 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-cyan-400">
              <option value="quantile_mapping" data-t-es="Quantile Mapping (aditivo)" data-t-en="Quantile Mapping (additive)">Quantile Mapping (aditivo)</option>
              <option value="quantile_deltamapping" data-t-es="Quantile Delta Mapping (multiplicativo)" data-t-en="Quantile Delta Mapping (multiplicative)">Quantile Delta Mapping (multiplicativo)</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-800 dark:text-slate-200 mb-2" for="variable-select" data-t-es="Variable" data-t-en="Variable">Variable</label>
            <select id="variable-select" class="w-full rounded-lg border border-gray-200 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-cyan-400">
              <option value="precipitation" data-t-es="Precipitación" data-t-en="Precipitation">Precipitación</option>
              <option value="temperature" data-t-es="Temperatura" data-t-en="Temperature">Temperatura</option>
            </select>
          </div>

          <button id="run-btn" class="w-full bg-cyan-600 hover:bg-cyan-700 text-white font-semibold py-3 rounded-xl transition-colors flex items-center justify-center gap-2">
            <span id="run-label" data-t-es="Corregir sesgo" data-t-en="Correct bias">Corregir sesgo</span>
            <svg id="run-arrow" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
            <svg id="run-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
            </svg>
          </button>
          <div id="error-box" class="hidden bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-700 rounded-lg p-3 text-sm text-red-700 dark:text-red-300"></div>
        </div>

        <div class="bg-cyan-50 dark:bg-cyan-950/50 border border-cyan-100 dark:border-cyan-800 rounded-2xl p-5 text-sm text-cyan-900 dark:text-cyan-200 space-y-2">
          <p class="font-semibold" data-t-es="Método" data-t-en="Method">Método</p>
          <p data-t-es="Quantile Mapping empírico: mapea los cuantiles del modelo a los de la observación. El modo aditivo ajusta diferencias; el multiplicativo ajusta ratios (recomendado para precipitación)." data-t-en="Empirical Quantile Mapping: maps model quantiles to observed quantiles. Additive mode corrects differences; multiplicative mode corrects ratios (recommended for precipitation).">Quantile Mapping empírico: mapea los cuantiles del modelo a los de la observación. El modo aditivo ajusta diferencias; el multiplicativo ajusta ratios (recomendado para precipitación).</p>
        </div>
      </aside>

      <main>
        <div id="placeholder" class="min-h-[430px] flex flex-col items-center justify-center text-center rounded-2xl border-2 border-dashed border-gray-200 dark:border-slate-700 p-12">
          <div class="w-16 h-16 rounded-2xl bg-cyan-100 dark:bg-cyan-900/40 text-cyan-800 dark:text-cyan-300 flex items-center justify-center mb-4">
            <svg class="w-9 h-9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <line x1="3" y1="21" x2="3" y2="4" stroke-width="1.2"/>
              <line x1="3" y1="21" x2="22" y2="21" stroke-width="1.2"/>
              <path d="M5 19 Q9 14 13 10 Q17 6 19 4" stroke-width="1.4" stroke-dasharray="3 2" stroke-opacity="0.6"/>
              <path d="M5 19 Q9 16 13 14 Q17 12 19 4" stroke-width="1.8"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-700 dark:text-slate-300 mb-2" data-t-es="Listo para corregir" data-t-en="Ready to correct">Listo para corregir</h3>
          <p class="text-gray-400 dark:text-slate-500 max-w-md" data-t-es="Ejecuta la demo o sube las series observada y de modelo para aplicar la corrección de sesgo." data-t-en="Run the demo or upload the observed and model series to apply bias correction.">Ejecuta la demo o sube las series observada y de modelo para aplicar la corrección de sesgo.</p>
        </div>

        <div id="results" class="hidden space-y-8">
          <div id="stats-row" class="grid grid-cols-2 lg:grid-cols-4 gap-4"></div>

          <div class="grid lg:grid-cols-2 gap-8">
            <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm p-6">
              <h3 class="font-semibold text-gray-800 dark:text-slate-200 mb-1">QQ-plot</h3>
              <p class="text-sm text-gray-400 dark:text-slate-500 mb-4" data-t-es="Cuantiles obs vs modelo (antes/después). La línea perfecta es y=x." data-t-en="Observed vs model quantiles (before/after). The perfect fit line is y=x.">Cuantiles obs vs modelo (antes/después). La línea perfecta es y=x.</p>
              <div id="chart-qq" class="h-80"></div>
            </div>
            <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm p-6">
              <h3 class="font-semibold text-gray-800 dark:text-slate-200 mb-1" data-t-es="Medias mensuales" data-t-en="Monthly means">Medias mensuales</h3>
              <p class="text-sm text-gray-400 dark:text-slate-500 mb-4" data-t-es="Comparación obs, modelo bruto y modelo corregido por mes." data-t-en="Comparison of observed, raw model, and corrected model by month.">Comparación obs, modelo bruto y modelo corregido por mes.</p>
              <div id="chart-monthly" class="h-80"></div>
            </div>
          </div>

          <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm p-6">
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-semibold text-gray-800 dark:text-slate-200" data-t-es="Estadísticas antes / después" data-t-en="Statistics before / after">Estadísticas antes / después</h3>
              <button id="download-btn" class="text-sm font-medium text-cyan-600 dark:text-cyan-400 hover:text-cyan-800 dark:hover:text-cyan-200 border border-cyan-200 dark:border-cyan-700 rounded-lg px-3 py-1.5 transition-colors" data-t-es="Descargar CSV corregido" data-t-en="Download corrected CSV">
                Descargar CSV corregido
              </button>
            </div>
            <div class="overflow-auto">
              <table class="w-full text-sm">
                <thead class="text-left text-gray-500 dark:text-slate-400">
                  <tr>
                    <th class="py-2 pr-4" data-t-es="Estadístico" data-t-en="Statistic">Estadístico</th>
                    <th class="py-2 px-3 text-right" data-t-es="Observado" data-t-en="Observed">Observado</th>
                    <th class="py-2 px-3 text-right" data-t-es="Modelo (antes)" data-t-en="Model (before)">Modelo (antes)</th>
                    <th class="py-2 px-3 text-right" data-t-es="Modelo (después)" data-t-en="Model (after)">Modelo (después)</th>
                  </tr>
                </thead>
                <tbody id="stats-table" class="divide-y divide-gray-100 dark:divide-slate-700"></tbody>
              </table>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
</Layout>

<script>
declare const Plotly: any;

const t = (es: string, en: string) => document.documentElement.lang === 'en' ? en : es;

const TEAL   = '#0891b2';
const GRAY   = '#94a3b8';
const ORANGE = '#f97316';
const MONTHS_ES = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
const MONTHS_EN = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const MONTHS = document.documentElement.lang === 'en' ? MONTHS_EN : MONTHS_ES;

const layoutBase = {
  paper_bgcolor: 'transparent',
  plot_bgcolor:  'transparent',
  margin: { t: 20, r: 16, b: 52, l: 58 },
  font: { family: 'Inter, system-ui, sans-serif', size: 11 },
};

let useDemo = true;
let isRunning = false;
let correctedCsvB64 = '';

const appEl        = document.getElementById('app')!;
const apiUrl       = appEl.dataset.apiUrl!;
const btnDemo      = document.getElementById('btn-demo')!;
const btnUpload    = document.getElementById('btn-upload')!;
const uploadArea   = document.getElementById('upload-area')!;
const demoNote     = document.getElementById('demo-note')!;
const runBtn       = document.getElementById('run-btn')!;
const runLabel     = document.getElementById('run-label')!;
const runArrow     = document.getElementById('run-arrow')!;
const runSpinner   = document.getElementById('run-spinner')!;
const errorBox     = document.getElementById('error-box')!;
const placeholder  = document.getElementById('placeholder')!;
const resultsEl    = document.getElementById('results')!;
const downloadBtn  = document.getElementById('download-btn')!;

function setSource(demo: boolean) {
  useDemo = demo;
  btnDemo.className   = `src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 transition-colors ${demo ? 'border-cyan-500 bg-cyan-50 text-cyan-700' : 'border-gray-200 text-gray-600 hover:border-cyan-300'}`;
  btnUpload.className = `src-btn py-2 px-3 rounded-lg text-sm font-medium border-2 transition-colors ${!demo ? 'border-cyan-500 bg-cyan-50 text-cyan-700' : 'border-gray-200 text-gray-600 hover:border-cyan-300'}`;
  uploadArea.classList.toggle('hidden', demo);
  demoNote.classList.toggle('hidden', !demo);
}

function setRunning(r: boolean) {
  isRunning = r;
  (runBtn as HTMLButtonElement).disabled = r;
  runLabel.textContent = r ? t('Calculando...', 'Computing...') : t('Corregir sesgo', 'Correct bias');
  runArrow.classList.toggle('hidden', r);
  runSpinner.classList.toggle('hidden', !r);
}

function showError(msg: string) { errorBox.textContent = msg; errorBox.classList.remove('hidden'); }
function clearError() { errorBox.classList.add('hidden'); errorBox.textContent = ''; }

btnDemo.addEventListener('click', () => setSource(true));
btnUpload.addEventListener('click', () => setSource(false));

downloadBtn.addEventListener('click', () => {
  if (!correctedCsvB64) return;
  const bytes = atob(correctedCsvB64);
  const blob = new Blob([bytes], { type: 'text/csv' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = 'corrected_series.csv'; a.click();
  URL.revokeObjectURL(url);
});

runBtn.addEventListener('click', async () => {
  if (isRunning) return;
  clearError();
  setRunning(true);

  const fd = new FormData();
  fd.append('demo',     useDemo ? 'true' : 'false');
  fd.append('method',   (document.getElementById('method-select') as HTMLSelectElement).value);
  fd.append('variable', (document.getElementById('variable-select') as HTMLSelectElement).value);

  if (!useDemo) {
    const fObs    = (document.getElementById('file-obs') as HTMLInputElement).files?.[0];
    const fModH   = (document.getElementById('file-mod-hist') as HTMLInputElement).files?.[0];
    const fModF   = (document.getElementById('file-mod-future') as HTMLInputElement).files?.[0];
    if (!fObs || !fModH) { showError(t('Se necesitan al menos file_obs y file_mod_hist.', 'At least file_obs and file_mod_hist are required.')); setRunning(false); return; }
    fd.append('file_obs', fObs);
    fd.append('file_mod_hist', fModH);
    if (fModF) fd.append('file_mod_future', fModF);
  }

  try {
    const res = await fetch(`${apiUrl}/api/bias/correct`, { method: 'POST', body: fd });
    if (!res.ok) { const err = await res.json(); throw new Error(err.detail ?? t('Error en el servidor', 'Server error')); }
    renderResults(await res.json());
  } catch (err: any) {
    showError(err.message ?? t('Error desconocido', 'Unknown error'));
  } finally {
    setRunning(false);
  }
});

function statCard(label: string, value: string, unit = '') {
  return `<div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
    <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">${label}</p>
    <p class="text-2xl font-bold text-gray-900">${value}</p>
    <p class="text-xs text-gray-400 mt-1">${unit}</p>
  </div>`;
}

function renderResults(data: any) {
  placeholder.classList.add('hidden');
  resultsEl.classList.remove('hidden');
  correctedCsvB64 = data.corrected_csv_b64 ?? '';

  const s = data.summary;
  document.getElementById('stats-row')!.innerHTML =
    statCard(t('Fuente', 'Source'), s.source === 'demo' ? 'Demo' : 'Upload', '') +
    statCard(t('Método', 'Method'), s.method === 'quantile_mapping' ? t('QM aditivo', 'Additive QM') : t('QM multiplicativo', 'Multiplicative QM'), '') +
    statCard(t('Días observados', 'Observed days'), `${s.n_obs_hist.toLocaleString()}`, t('histórico', 'historical')) +
    statCard(t('Días corregidos', 'Corrected days'), `${s.n_mod_future.toLocaleString()}`, t('escenario', 'scenario'));

  // QQ plot
  const qBefore = data.qq_before as {obs: number, mod: number}[];
  const qAfter  = data.qq_after  as {obs: number, mod: number}[];
  const allObs  = qBefore.map(d => d.obs);
  const diagMax = Math.max(...allObs, ...qBefore.map(d => d.mod), ...qAfter.map(d => d.mod));

  Plotly.newPlot('chart-qq', [
    { x: qBefore.map(d => d.obs), y: qBefore.map(d => d.mod),
      mode: 'markers', name: t('Antes', 'Before'), marker: { color: GRAY, size: 4, opacity: 0.7 } },
    { x: qAfter.map(d => d.obs),  y: qAfter.map(d => d.mod),
      mode: 'markers', name: t('Después', 'After'), marker: { color: TEAL, size: 4, opacity: 0.85 } },
    { x: [0, diagMax], y: [0, diagMax], mode: 'lines', name: 'y=x',
      line: { color: '#334155', width: 1.5, dash: 'dot' }, hoverinfo: 'skip' },
  ], {
    ...layoutBase,
    xaxis: { title: t('Cuantiles observados', 'Observed quantiles'), gridcolor: '#f3f4f6' },
    yaxis: { title: t('Cuantiles modelo', 'Model quantiles'), gridcolor: '#f3f4f6' },
    legend: { orientation: 'h', y: -0.25 },
  }, { responsive: true, displayModeBar: false });

  // Monthly means
  const mm = data.monthly_means as {month: string, obs: number, mod_raw: number, mod_corrected: number}[];
  Plotly.newPlot('chart-monthly', [
    { x: mm.map(m => m.month), y: mm.map(m => m.obs),           type: 'bar', name: t('Observado', 'Observed'),
      marker: { color: '#334155', opacity: 0.7 } },
    { x: mm.map(m => m.month), y: mm.map(m => m.mod_raw),       type: 'bar', name: t('Modelo (antes)', 'Model (before)'),
      marker: { color: GRAY,  opacity: 0.8 } },
    { x: mm.map(m => m.month), y: mm.map(m => m.mod_corrected), type: 'bar', name: t('Modelo (después)', 'Model (after)'),
      marker: { color: TEAL, opacity: 0.9 } },
  ], {
    ...layoutBase,
    barmode: 'group',
    xaxis: { gridcolor: '#f3f4f6' },
    yaxis: { title: t('Media diaria', 'Daily mean'), gridcolor: '#f3f4f6' },
    legend: { orientation: 'h', y: -0.25 },
  }, { responsive: true, displayModeBar: false });

  // Stats table
  const st = data.stats;
  const fmt = (v: number | null) => v != null ? v.toFixed(3) : '—';
  const rows = [
    [t('Media', 'Mean'),             st.obs.mean,           st.before.mean,          st.after.mean],
    [t('Desv. est.', 'Std. dev.'),   st.obs.std,            st.before.std,           st.after.std],
    ['P90',                          st.obs.p90,            st.before.p90,           st.after.p90],
    [t('Máximo', 'Max'),             st.obs.max,            st.before.max,           st.after.max],
    [t('Frac. húmeda', 'Wet fraction'), st.obs.wet_fraction, st.before.wet_fraction, st.after.wet_fraction],
  ];
  document.getElementById('stats-table')!.innerHTML = rows.map(([name, obs, before, after]) =>
    `<tr class="hover:bg-gray-50">
      <td class="py-2 pr-4 font-medium text-gray-700">${name}</td>
      <td class="py-2 px-3 text-right text-gray-700">${fmt(obs as number)}</td>
      <td class="py-2 px-3 text-right text-gray-500">${fmt(before as number)}</td>
      <td class="py-2 px-3 text-right font-semibold text-cyan-700">${fmt(after as number)}</td>
    </tr>`
  ).join('');
}
</script>
