---
import Layout from '../../layouts/Layout.astro';
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<Layout title="Eventos Compuestos — HYDRA">
  <script src="https://cdn.plot.ly/plotly-2.32.0.min.js" is:inline></script>

  <section class="pt-24 pb-10 bg-gradient-to-br from-slate-950 via-violet-950 to-indigo-900 text-white">
    <div class="max-w-7xl mx-auto px-6">
      <a href="/" class="inline-flex items-center gap-2 text-white/65 hover:text-white text-sm mb-6 transition-colors">
        ← Volver al inicio
      </a>
      <h1 class="text-4xl font-extrabold mb-2">Eventos Compuestos</h1>
      <p class="text-white/76 text-lg max-w-3xl">
        Ajusta una cópula bivariante, calcula períodos de retorno conjuntos AND y OR, y localiza el Evento de Diseño de Máxima Probabilidad (MPDE) sobre cada isoline.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-6 py-10" id="app" data-api-url={apiUrl}>
    <div class="grid lg:grid-cols-[320px_1fr] gap-8">

      <!-- ── PANEL DE CONTROL ── -->
      <aside class="space-y-6">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 space-y-5">

          <div>
            <label class="block text-sm font-semibold text-gray-800 mb-2">Fuente de datos</label>
            <label class="flex items-center gap-3 p-3 rounded-xl border border-gray-200 cursor-pointer mb-2 has-[:checked]:border-violet-500 has-[:checked]:bg-violet-50">
              <input type="radio" name="datasource" value="demo" checked class="accent-violet-600" />
              <span class="text-sm font-medium text-gray-700">Demo (Qmax vs Nivel del mar, n=120)</span>
            </label>
            <label class="flex items-center gap-3 p-3 rounded-xl border border-gray-200 cursor-pointer has-[:checked]:border-violet-500 has-[:checked]:bg-violet-50">
              <input type="radio" name="datasource" value="csv" class="accent-violet-600" />
              <span class="text-sm font-medium text-gray-700">CSV propio</span>
            </label>
          </div>

          <div id="csv-area" class="hidden space-y-3">
            <div>
              <label class="block text-xs font-semibold text-gray-700 mb-1">CSV (al menos dos columnas numéricas)</label>
              <input id="csv-file" type="file" accept=".csv"
                class="block w-full text-sm text-gray-500 file:rounded-lg file:border-0 file:bg-violet-50 file:px-3 file:py-1.5 file:text-xs file:font-semibold file:text-violet-700 hover:file:bg-violet-100" />
            </div>
            <div class="grid grid-cols-2 gap-2">
              <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Variable X</label>
                <input id="var1" type="text" value="Qmax_m3s"
                  class="w-full rounded-lg border border-gray-200 px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-violet-400" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Variable Y</label>
                <input id="var2" type="text" value="SL_m"
                  class="w-full rounded-lg border border-gray-200 px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-violet-400" />
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-800 mb-2">Familia de cópula</label>
            <select id="copula-family"
              class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-violet-400 bg-white">
              <option value="gumbel">Gumbel (cola superior)</option>
              <option value="clayton">Clayton (cola inferior)</option>
              <option value="frank">Frank (simétrica)</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-800 mb-2">Períodos de retorno</label>
            <input id="t-list" value="2,10,50,100,500"
              class="w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-violet-400" />
            <p class="text-xs text-gray-400 mt-1">Separados por comas, en años.</p>
          </div>

          <button id="fit-btn"
            class="w-full bg-violet-600 hover:bg-violet-700 text-white font-semibold py-3 rounded-xl transition-colors flex items-center justify-center gap-2">
            <span id="fit-label">Ajustar cópula</span>
            <svg id="fit-arrow" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
            <svg id="fit-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 0 0 12h4z"/>
            </svg>
          </button>
          <div id="error-box" class="hidden bg-red-50 border border-red-200 rounded-lg p-3 text-sm text-red-700"></div>
        </div>

        <div class="bg-violet-50 border border-violet-100 rounded-2xl p-5 text-sm text-violet-900 space-y-2">
          <p class="font-semibold">Interpretación</p>
          <p><strong>OR</strong> (azul): evento extremo si X <em>o</em> Y superan el umbral.</p>
          <p><strong>AND</strong> (rojo): evento extremo si X <em>y</em> Y superan el umbral simultáneamente.</p>
          <p><strong>MaxProb ×</strong>: Evento de Diseño de Máxima Probabilidad (MPDE) — el punto de mayor densidad conjunta sobre cada isoline.</p>
        </div>
      </aside>

      <!-- ── RESULTADOS ── -->
      <main class="space-y-8">

        <div id="placeholder" class="rounded-2xl border border-dashed border-gray-200 bg-gray-50 p-16 text-center text-gray-400">
          <svg class="w-14 h-14 mx-auto mb-4 text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3">
            <ellipse cx="12.5" cy="13" rx="7" ry="4" transform="rotate(-30 12.5 13)"/>
            <ellipse cx="12.5" cy="13" rx="3.5" ry="2" transform="rotate(-30 12.5 13)"/>
            <line x1="3" y1="21" x2="3" y2="4" stroke-width="1.2"/><line x1="3" y1="21" x2="22" y2="21" stroke-width="1.2"/>
          </svg>
          <p class="font-medium text-gray-500">Configura los parámetros y haz clic en "Ajustar cópula"</p>
        </div>

        <div id="results" class="hidden space-y-8">

          <!-- Stats -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">N eventos</p>
              <p id="stat-n" class="text-2xl font-bold text-gray-900">—</p>
            </div>
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Cópula · marginal</p>
              <p id="stat-family" class="text-xl font-bold text-gray-900">—</p>
            </div>
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">τ Kendall</p>
              <p id="stat-tau" class="text-2xl font-bold text-gray-900">—</p>
            </div>
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">ρ Spearman</p>
              <p id="stat-rho" class="text-2xl font-bold text-gray-900">—</p>
            </div>
          </div>

          <!-- ── DIAGRAMA CONJUNTO ── -->
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h3 class="font-semibold text-gray-800 mb-1">Diagrama de período de retorno conjunto</h3>
            <p class="text-sm text-gray-400 mb-4">
              Isolíneas AND (rojo) y OR (azul) con puntos de máxima probabilidad (×). PDFs marginales paramétricas en los bordes.
            </p>
            <div id="chart-joint" class="h-[600px]"></div>
          </div>

          <!-- Cuantiles marginales por período de retorno -->
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h3 class="font-semibold text-gray-800 mb-1">Cuantiles marginales univariantes</h3>
            <p class="text-sm text-gray-400 mb-4">Valores de diseño para cada variable individualmente (distribución marginal ajustada).</p>
            <div class="overflow-x-auto">
              <table class="w-full text-sm border-collapse">
                <thead class="text-xs text-gray-500 uppercase tracking-wide border-b border-gray-100">
                  <tr>
                    <th class="py-2 px-3 text-left">T (años)</th>
                    <th id="col-x-quant" class="py-2 px-3 text-right">X</th>
                    <th id="col-y-quant" class="py-2 px-3 text-right">Y</th>
                  </tr>
                </thead>
                <tbody id="quantiles-tbody" class="divide-y divide-gray-50"></tbody>
              </table>
            </div>
          </div>

          <!-- T_OR y T_AND para los eventos observados -->
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h3 class="font-semibold text-gray-800 mb-1">Eventos observados — períodos de retorno conjuntos</h3>
            <p class="text-sm text-gray-400 mb-4">Los 25 eventos más severos por T<sub>OR</sub>.</p>
            <div class="overflow-x-auto">
              <table class="w-full text-sm border-collapse">
                <thead class="text-xs text-gray-500 uppercase tracking-wide border-b border-gray-100">
                  <tr>
                    <th id="col-x" class="py-2 px-3 text-right">X</th>
                    <th id="col-y" class="py-2 px-3 text-right">Y</th>
                    <th class="py-2 px-3 text-right">u = F(X)</th>
                    <th class="py-2 px-3 text-right">v = F(Y)</th>
                    <th class="py-2 px-3 text-right">T<sub>OR</sub> (a)</th>
                    <th class="py-2 px-3 text-right">T<sub>AND</sub> (a)</th>
                  </tr>
                </thead>
                <tbody id="obs-tbody" class="divide-y divide-gray-50"></tbody>
              </table>
            </div>
          </div>

        </div>
      </main>
    </div>
  </div>
</Layout>

<script>
declare const Plotly: any;

const appEl   = document.getElementById('app')!;
const apiUrl  = appEl.dataset.apiUrl!;
const dsRadios = document.querySelectorAll<HTMLInputElement>('input[name="datasource"]');
const csvArea  = document.getElementById('csv-area')!;
const csvFileEl = document.getElementById('csv-file') as HTMLInputElement;
const var1El   = document.getElementById('var1') as HTMLInputElement;
const var2El   = document.getElementById('var2') as HTMLInputElement;
const familyEl = document.getElementById('copula-family') as HTMLSelectElement;
const tListEl  = document.getElementById('t-list') as HTMLInputElement;
const fitBtn   = document.getElementById('fit-btn')!;
const fitLabel = document.getElementById('fit-label')!;
const fitArrow = document.getElementById('fit-arrow')!;
const fitSpinner = document.getElementById('fit-spinner')!;
const errorBox = document.getElementById('error-box')!;
const placeholder = document.getElementById('placeholder')!;
const resultsEl   = document.getElementById('results')!;

dsRadios.forEach(r => r.addEventListener('change', () => {
  csvArea.classList.toggle('hidden', r.value === 'demo' && r.checked);
}));

function showError(msg: string) { errorBox.textContent = msg; errorBox.classList.remove('hidden'); }
function clearError() { errorBox.textContent = ''; errorBox.classList.add('hidden'); }
function setRunning(v: boolean) {
  (fitBtn as HTMLButtonElement).disabled = v;
  fitLabel.textContent = v ? 'Ajustando…' : 'Ajustar cópula';
  fitArrow.classList.toggle('hidden', v);
  fitSpinner.classList.toggle('hidden', !v);
}

// ── Joint plot rendering (same as copulas.astro) ─────────────────────────────
const T_COLORS_OR  = ['#1d4ed8','#2563eb','#3b82f6','#60a5fa','#93c5fd'];
const T_COLORS_AND = ['#991b1b','#dc2626','#ef4444','#f87171','#fca5a5'];
const OLIVE = '#78716c';

function renderJointPlot(d: any) {
  const T_vals: number[] = Object.keys(d.isolines_or).map(Number).sort((a,b)=>a-b);
  const traces: any[] = [];
  const ext = d.extent;

  traces.push({
    x: d.synthetic.x, y: d.synthetic.y,
    mode: 'markers', type: 'scatter', name: 'Simulados',
    marker: { color: '#94a3b8', size: 3, opacity: 0.35 },
    xaxis: 'x', yaxis: 'y', showlegend: true,
  });
  traces.push({
    x: d.observed.x, y: d.observed.y,
    mode: 'markers', type: 'scatter', name: 'Observados',
    marker: { color: '#0f172a', size: 8, opacity: 0.9, line: { color: '#fff', width: 0.5 } },
    xaxis: 'x', yaxis: 'y', showlegend: true,
  });

  // OR isolines (blue)
  T_vals.forEach((T, i) => {
    const iso = d.isolines_or[String(T)];
    if (!iso) return;
    traces.push({
      x: iso.x, y: iso.y, mode: 'lines', type: 'scatter',
      name: i === 0 ? 'OR' : `OR T${T}`,
      showlegend: i === 0, legendgroup: 'or',
      line: { color: T_COLORS_OR[i % T_COLORS_OR.length], width: 2.2 },
      xaxis: 'x', yaxis: 'y',
      hovertemplate: `OR  T=${T} a<br>${d.x_var}: %{x:.1f}<br>${d.y_var}: %{y:.3f}<extra></extra>`,
    });
    const mid = Math.floor((iso.x.length) * 0.55);
    if (iso.x[mid] != null) traces.push({
      x: [iso.x[mid]], y: [iso.y[mid]],
      mode: 'text', type: 'scatter', showlegend: false,
      text: [`T${T}`], textfont: { color: T_COLORS_OR[i % T_COLORS_OR.length], size: 10, family: 'Inter' },
      xaxis: 'x', yaxis: 'y',
    });
  });

  // AND isolines (red)
  T_vals.forEach((T, i) => {
    const iso = d.isolines_and[String(T)];
    if (!iso) return;
    traces.push({
      x: iso.x, y: iso.y, mode: 'lines', type: 'scatter',
      name: i === 0 ? 'AND' : `AND T${T}`,
      showlegend: i === 0, legendgroup: 'and',
      line: { color: T_COLORS_AND[i % T_COLORS_AND.length], width: 2.2 },
      xaxis: 'x', yaxis: 'y',
      hovertemplate: `AND  T=${T} a<br>${d.x_var}: %{x:.1f}<br>${d.y_var}: %{y:.3f}<extra></extra>`,
    });
  });

  // MaxProb OR
  const mpOrX: number[] = [], mpOrY: number[] = [], mpOrT: string[] = [];
  T_vals.forEach(T => { const mp = d.maxprob_or[String(T)]; if (mp) { mpOrX.push(mp.x); mpOrY.push(mp.y); mpOrT.push(`T${T}`); } });
  if (mpOrX.length) traces.push({
    x: mpOrX, y: mpOrY, text: mpOrT,
    mode: 'markers+text', type: 'scatter', name: 'MaxProb OR',
    textposition: 'top center', textfont: { color: '#1d4ed8', size: 10 },
    marker: { symbol: 'x', color: '#1d4ed8', size: 14, line: { width: 2.5 } },
    xaxis: 'x', yaxis: 'y', showlegend: true,
  });

  // MaxProb AND
  const mpAndX: number[] = [], mpAndY: number[] = [], mpAndT: string[] = [];
  T_vals.forEach(T => { const mp = d.maxprob_and[String(T)]; if (mp) { mpAndX.push(mp.x); mpAndY.push(mp.y); mpAndT.push(`T${T}`); } });
  if (mpAndX.length) traces.push({
    x: mpAndX, y: mpAndY, text: mpAndT,
    mode: 'markers+text', type: 'scatter', name: 'MaxProb AND',
    textposition: 'top center', textfont: { color: '#991b1b', size: 10 },
    marker: { symbol: 'x', color: '#991b1b', size: 14, line: { width: 2.5 } },
    xaxis: 'x', yaxis: 'y', showlegend: true,
  });

  // Marginal T lines on main
  T_vals.forEach(T => {
    const qx = d.marginal_x.quantiles[String(T)];
    const qy = d.marginal_y.quantiles[String(T)];
    if (qx != null) traces.push({ x: [qx,qx], y: [ext[2],ext[3]], mode:'lines', type:'scatter', showlegend:false,
      line:{color:'#c084fc',width:0.8,dash:'dot'}, xaxis:'x', yaxis:'y', hoverinfo:'skip' });
    if (qy != null) traces.push({ x: [ext[0],ext[1]], y: [qy,qy], mode:'lines', type:'scatter', showlegend:false,
      line:{color:'#c084fc',width:0.8,dash:'dot'}, xaxis:'x', yaxis:'y', hoverinfo:'skip' });
  });

  // Bottom marginal PDF (x, inverted y = grows upward)
  traces.push({
    x: d.marginal_x.vals, y: d.marginal_x.pdf,
    fill: 'tozeroy', mode: 'lines', type: 'scatter', name: `PDF ${d.x_var}`,
    line: { color: OLIVE, width: 1.5 }, fillcolor: 'rgba(101,90,49,0.2)',
    xaxis: 'x2', yaxis: 'y2', showlegend: true,
    hovertemplate: `${d.x_var}: %{x:.2f}<br>PDF: %{y:.5f}<extra></extra>`,
  });
  T_vals.forEach(T => {
    const qx = d.marginal_x.quantiles[String(T)];
    if (qx == null) return;
    const yMax = Math.max(...d.marginal_x.pdf);
    traces.push({ x:[qx,qx], y:[0,yMax*0.65], mode:'lines+text', type:'scatter', showlegend:false,
      text:['',`T${T}`], textposition:'top center', textfont:{color:OLIVE,size:9},
      line:{color:OLIVE,width:1,dash:'dot'}, xaxis:'x2', yaxis:'y2' });
  });

  // Left marginal PDF (y, inverted x = grows rightward)
  traces.push({
    x: d.marginal_y.pdf, y: d.marginal_y.vals,
    fill: 'tozerox', mode: 'lines', type: 'scatter', name: `PDF ${d.y_var}`,
    line: { color: OLIVE, width: 1.5 }, fillcolor: 'rgba(101,90,49,0.2)',
    xaxis: 'x3', yaxis: 'y3', showlegend: true,
    hovertemplate: `PDF: %{x:.5f}<br>${d.y_var}: %{y:.3f}<extra></extra>`,
  });
  T_vals.forEach(T => {
    const qy = d.marginal_y.quantiles[String(T)];
    if (qy == null) return;
    const xMax = Math.max(...d.marginal_y.pdf);
    traces.push({ x:[0,xMax*0.65], y:[qy,qy], mode:'lines+text', type:'scatter', showlegend:false,
      text:[`T${T}`,''], textposition:'middle left', textfont:{color:OLIVE,size:9},
      line:{color:OLIVE,width:1,dash:'dot'}, xaxis:'x3', yaxis:'y3' });
  });

  Plotly.newPlot('chart-joint', traces, {
    paper_bgcolor: 'white', plot_bgcolor: '#f8fafc',
    font: { family: 'Inter, system-ui, sans-serif', size: 11 },
    margin: { t: 10, r: 170, b: 10, l: 10 },
    xaxis:  { domain:[0.20,1], range:[ext[0],ext[1]], title:d.x_var, gridcolor:'#e2e8f0', zeroline:false },
    yaxis:  { domain:[0.22,1], range:[ext[2],ext[3]], title:d.y_var, gridcolor:'#e2e8f0', zeroline:false },
    xaxis2: { domain:[0.20,1], range:[ext[0],ext[1]], anchor:'y2', showgrid:false, showticklabels:false },
    yaxis2: { domain:[0,0.20], autorange:'reversed', anchor:'x2', showgrid:false, title:'PDF' },
    xaxis3: { domain:[0,0.18], autorange:'reversed', anchor:'y3', showgrid:false, title:'PDF' },
    yaxis3: { domain:[0.22,1], range:[ext[2],ext[3]], anchor:'x3', showgrid:false, showticklabels:false },
    legend: { x:1.01, y:0.85, xanchor:'left', bgcolor:'rgba(255,255,255,0.92)', bordercolor:'#e2e8f0', borderwidth:1 },
    showlegend: true,
  }, { responsive:true, displayModeBar:false });
}

async function fitCopula() {
  clearError();
  setRunning(true);
  const demo = (document.querySelector('input[name="datasource"]:checked') as HTMLInputElement)?.value === 'demo';

  const fd = new FormData();
  fd.append('demo', demo ? 'true' : 'false');
  fd.append('demo_type', 'compound');
  fd.append('x_var', demo ? 'Qmax_m3s' : var1El.value.trim());
  fd.append('y_var', demo ? 'SL_m'     : var2El.value.trim());
  fd.append('family', familyEl.value);
  fd.append('t_list', tListEl.value);
  fd.append('n_synthetic', '2500');
  if (!demo) {
    const f = csvFileEl.files?.[0];
    if (!f) { showError('Sube un archivo CSV.'); setRunning(false); return; }
    fd.append('file', f);
  }

  placeholder.classList.add('hidden');
  resultsEl.classList.add('hidden');

  try {
    const res = await fetch(`${apiUrl}/api/copulas/joint-plot`, { method:'POST', body:fd });
    const data = await res.json();
    if (!res.ok) throw new Error(data.detail ?? 'Error ajustando cópula');

    // Stats
    document.getElementById('stat-n')!.textContent = String(data.n_obs);
    document.getElementById('stat-family')!.textContent =
      `${data.family} · ${data.marginal_x_family ?? ''}`;
    document.getElementById('stat-tau')!.textContent = String(data.kendall_tau);
    document.getElementById('stat-rho')!.textContent = String(data.spearman_rho);

    // Column headers
    document.getElementById('col-x')!.textContent = data.x_var;
    document.getElementById('col-y')!.textContent = data.y_var;
    document.getElementById('col-x-quant')!.textContent = data.x_var;
    document.getElementById('col-y-quant')!.textContent = data.y_var;

    // Quantiles table
    const T_vals = Object.keys(data.marginal_x.quantiles).map(Number).sort((a,b)=>a-b);
    document.getElementById('quantiles-tbody')!.innerHTML = T_vals.map(T => {
      const qx = data.marginal_x.quantiles[String(T)];
      const qy = data.marginal_y.quantiles[String(T)];
      return `<tr>
        <td class="py-1.5 px-3 font-semibold text-violet-700">T=${T}</td>
        <td class="py-1.5 px-3 text-right text-gray-700">${qx != null ? Number(qx).toFixed(2) : '—'}</td>
        <td class="py-1.5 px-3 text-right text-gray-700">${qy != null ? Number(qy).toFixed(3) : '—'}</td>
      </tr>`;
    }).join('');

    // Observed events table (top 25 by T_OR)
    const top25 = [...(data.observed_rp ?? [])].sort((a:any,b:any) => b.T_or - a.T_or).slice(0,25);
    document.getElementById('obs-tbody')!.innerHTML = top25.map((pt:any) => `<tr>
      <td class="py-1.5 px-3 text-right text-gray-700">${pt.x}</td>
      <td class="py-1.5 px-3 text-right text-gray-700">${pt.y}</td>
      <td class="py-1.5 px-3 text-right text-gray-500">${pt.u}</td>
      <td class="py-1.5 px-3 text-right text-gray-500">${pt.v}</td>
      <td class="py-1.5 px-3 text-right font-semibold ${pt.T_or>=100?'text-red-600':pt.T_or>=10?'text-orange-500':'text-gray-700'}">${pt.T_or}</td>
      <td class="py-1.5 px-3 text-right text-gray-600">${pt.T_and}</td>
    </tr>`).join('');

    resultsEl.classList.remove('hidden');
    requestAnimationFrame(() => renderJointPlot(data));

  } catch (err: any) {
    showError(err.message ?? 'Error desconocido');
    placeholder.classList.remove('hidden');
  } finally {
    setRunning(false);
  }
}

fitBtn.addEventListener('click', fitCopula);
</script>
