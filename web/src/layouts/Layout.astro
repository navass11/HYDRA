---
import { ui } from '../i18n/ui';
import { phraseTranslations } from '../i18n/phrases';

export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'HYDRA',
  description = 'Librería modular de Python para análisis hidrológico y climático',
} = Astro.props;

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base.replace(/\/$/, '')}${path}`;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href={asset('/favicon.png')} />
    <script is:inline>
      (() => {
        const storedTheme = localStorage.getItem('hydra-theme');
        const prefersDark = window.matchMedia?.('(prefers-color-scheme: dark)').matches;
        const theme = storedTheme ?? (prefersDark ? 'dark' : 'light');
        document.documentElement.classList.toggle('dark', theme === 'dark');
        document.documentElement.dataset.theme = theme;
        document.documentElement.lang = localStorage.getItem('hydra-lang') ?? 'es';
      })();
    </script>
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased transition-colors duration-300">
    <!-- Navbar -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-200/80">
      <nav class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href={base} class="flex items-center gap-2.5 font-bold text-xl text-hydra-800">
          <img src={asset('/favicon.png')} alt="" class="h-9 w-9 rounded-xl shadow-sm" />
          HYDRA
        </a>
        <div class="flex md:hidden items-center gap-2">
          <div class="flex items-center gap-1 rounded-full border border-slate-200 bg-white/75 p-1 shadow-sm">
            <button type="button" class="hydra-lang-btn rounded-full px-2.5 py-1 text-xs font-bold text-slate-600 transition-colors" data-lang="es" aria-label="Español">ES</button>
            <button type="button" class="hydra-lang-btn rounded-full px-2.5 py-1 text-xs font-bold text-slate-600 transition-colors" data-lang="en" aria-label="English">EN</button>
          </div>
          <button
            type="button"
            class="theme-toggle inline-flex h-9 w-9 items-center justify-center rounded-full border border-slate-200 bg-white/75 text-slate-700 shadow-sm transition-colors hover:border-hydra-400 hover:text-hydra-700"
            aria-label="Cambiar modo claro u oscuro"
            title="Tema claro/oscuro"
          >
            <svg class="theme-icon-light h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
            </svg>
            <svg class="theme-icon-dark hidden h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20.5 14.5A8.5 8.5 0 0 1 9.5 3.5 7 7 0 1 0 20.5 14.5Z"></path>
            </svg>
          </button>
        </div>
        <div class="hidden md:flex items-center gap-6 text-sm font-medium text-slate-600">
          <a href={`${base}#modulos`} class="hover:text-hydra-600 transition-colors" data-i18n="nav.modules">Módulos</a>
          <a href={`${base}#notebooks`} class="hover:text-hydra-600 transition-colors" data-i18n="nav.notebooks">Notebooks</a>
          <a href={`${base}#herramientas`} class="hover:text-hydra-600 transition-colors" data-i18n="nav.tools">Herramientas</a>
          <a href={`${base}#casos-piloto`} class="hover:text-hydra-600 transition-colors" data-i18n="nav.cases">Casos piloto</a>
          <a href={`${base}#instalacion`} class="hover:text-hydra-600 transition-colors" data-i18n="nav.install">Instalación</a>
          <a href={`${base}#autor`} class="hover:text-hydra-600 transition-colors" data-i18n="nav.author">Autor</a>
          <div class="flex items-center gap-1 rounded-full border border-slate-200 bg-white/75 p-1 shadow-sm">
            <button
              type="button"
              class="hydra-lang-btn rounded-full px-2.5 py-1 text-xs font-bold text-slate-600 transition-colors"
              data-lang="es"
              aria-label="Español"
            >
              ES
            </button>
            <button
              type="button"
              class="hydra-lang-btn rounded-full px-2.5 py-1 text-xs font-bold text-slate-600 transition-colors"
              data-lang="en"
              aria-label="English"
            >
              EN
            </button>
          </div>
          <button
            type="button"
            class="theme-toggle inline-flex h-9 w-9 items-center justify-center rounded-full border border-slate-200 bg-white/75 text-slate-700 shadow-sm transition-colors hover:border-hydra-400 hover:text-hydra-700"
            aria-label="Cambiar modo claro u oscuro"
            title="Tema claro/oscuro"
          >
            <svg class="theme-icon-light h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
            </svg>
            <svg class="theme-icon-dark hidden h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20.5 14.5A8.5 8.5 0 0 1 9.5 3.5 7 7 0 1 0 20.5 14.5Z"></path>
            </svg>
          </button>
          <a
            href="https://github.com/navass11/pyhydra"
            target="_blank"
            class="flex items-center gap-1.5 bg-gray-900 text-white px-4 py-2 rounded-lg hover:bg-gray-700 transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            GitHub
          </a>
        </div>
      </nav>
      <div class="md:hidden border-t border-slate-200/80 bg-white/90 backdrop-blur-md">
        <div class="max-w-7xl mx-auto px-6 py-2 flex gap-4 overflow-x-auto text-xs font-medium text-slate-600 whitespace-nowrap">
          <a href={`${base}#modulos`} class="hover:text-hydra-600 transition-colors" data-i18n="nav.modules">Módulos</a>
          <a href={`${base}#notebooks`} class="hover:text-hydra-600 transition-colors" data-i18n="nav.notebooks">Notebooks</a>
          <a href={`${base}#herramientas`} class="hover:text-hydra-600 transition-colors" data-i18n="nav.tools">Herramientas</a>
          <a href={`${base}#casos-piloto`} class="hover:text-hydra-600 transition-colors" data-i18n="nav.cases">Casos piloto</a>
          <a href={`${base}#instalacion`} class="hover:text-hydra-600 transition-colors" data-i18n="nav.install">Instalación</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-950 text-gray-400 py-12 mt-24">
      <div class="max-w-7xl mx-auto px-6 text-center">
        <div class="flex items-center justify-center gap-2 text-white font-semibold text-lg mb-3">
          <img src={asset('/favicon.png')} alt="" class="h-8 w-8 rounded-lg" />
          HYDRA
        </div>
        <p class="text-sm" data-i18n="footer.description">Librería modular de Python para análisis hidrológico y climático.</p>
        <p class="text-sm mt-2">
          <a href="https://github.com/navass11/pyhydra" class="hover:text-hydra-400 transition-colors underline" target="_blank">
            github.com/navass11/pyhydra
          </a>
        </p>
      </div>
    </footer>

    <!-- Smooth scroll, theme and language controls -->
    <script define:vars={{ ui, phraseTranslations }}>
      const translations = ui;
      const originalTextNodes = new WeakMap();

      const translateTextNodes = (lang) => {
        const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT);
        const nodes = [];
        while (walker.nextNode()) nodes.push(walker.currentNode);
        nodes.forEach((node) => {
          const parent = node.parentElement;
          if (!parent || parent.closest('script, style, code, pre, [data-i18n], [data-t-es], [data-t-en]')) return;
          if (!originalTextNodes.has(node)) originalTextNodes.set(node, node.nodeValue ?? '');
          const original = originalTextNodes.get(node);
          const trimmed = original.trim();
          if (!trimmed) return;
          const translated = lang === 'en' ? phraseTranslations[trimmed] : trimmed;
          if (!translated) {
            node.nodeValue = original;
            return;
          }
          node.nodeValue = original.replace(trimmed, translated);
        });
      };

      const setTheme = (theme) => {
        document.documentElement.classList.toggle('dark', theme === 'dark');
        document.documentElement.dataset.theme = theme;
        localStorage.setItem('hydra-theme', theme);
        document.querySelectorAll('.theme-icon-light').forEach((icon) => icon.classList.toggle('hidden', theme === 'dark'));
        document.querySelectorAll('.theme-icon-dark').forEach((icon) => icon.classList.toggle('hidden', theme !== 'dark'));
      };

      const applyDataTranslations = (lang) => {
        document.querySelectorAll('[data-t-es]').forEach((el) => {
          const es = el.getAttribute('data-t-es') ?? '';
          const en = el.getAttribute('data-t-en') ?? '';
          if (el.getAttribute('data-html') === 'true') {
            el.innerHTML = lang === 'en' ? en : es;
          } else {
            el.textContent = lang === 'en' ? en : es;
          }
        });
      };

      const originalTitle = document.title;

      const setLanguage = (lang) => {
        const dict = translations[lang] ?? translations.es;
        document.documentElement.lang = lang;
        localStorage.setItem('hydra-lang', lang);
        document.title = lang === 'en' ? (phraseTranslations[originalTitle] ?? originalTitle) : originalTitle;
        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const key = el.getAttribute('data-i18n');
          if (key && dict[key]) el.textContent = dict[key];
        });
        document.querySelectorAll('.hydra-lang-btn').forEach((btn) => {
          const active = btn.getAttribute('data-lang') === lang;
          btn.classList.toggle('is-active', active);
          btn.setAttribute('aria-pressed', String(active));
        });
        applyDataTranslations(lang);
        translateTextNodes(lang);
        document.dispatchEvent(new CustomEvent('hydra:lang', { detail: { lang } }));
      };

      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => e.isIntersecting && e.target.classList.add('visible')),
        { threshold: 0.1 }
      );
      document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

      document.querySelectorAll('.hydra-lang-btn').forEach((btn) => {
        btn.addEventListener('click', () => setLanguage(btn.getAttribute('data-lang') ?? 'es'));
      });
      document.querySelectorAll('.theme-toggle').forEach((button) => {
        button.addEventListener('click', () => {
          const current = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
          setTheme(current === 'dark' ? 'light' : 'dark');
        });
      });
      setTheme(localStorage.getItem('hydra-theme') ?? (document.documentElement.classList.contains('dark') ? 'dark' : 'light'));
      setLanguage(localStorage.getItem('hydra-lang') ?? 'es');
    </script>

    <style is:global>
      .fade-in {
        opacity: 0;
        transform: translateY(24px);
        transition: opacity 0.6s ease, transform 0.6s ease;
      }
      .fade-in.visible {
        opacity: 1;
        transform: translateY(0);
      }
      .hydra-lang-btn.is-active {
        background: #0d9488;
        color: #ffffff;
      }
      html.dark body {
        background: #020617;
        color: #e5edf6;
      }
      html.dark header {
        background: rgba(2, 6, 23, 0.88);
        border-color: rgba(51, 65, 85, 0.8);
      }
      html.dark footer,
      html.dark .bg-gray-950,
      html.dark .bg-slate-950 {
        background-color: #020617;
      }
      html.dark .bg-white,
      html.dark .bg-gray-50 {
        background-color: #0f172a;
      }
      html.dark .bg-white\/75 {
        background-color: rgba(15, 23, 42, 0.82);
      }
      html.dark .bg-white\/90 {
        background-color: rgba(2, 6, 23, 0.88);
      }
      html.dark .border-gray-100,
      html.dark .border-gray-200,
      html.dark .border-slate-200\/80,
      html.dark .border-slate-200 {
        border-color: rgba(71, 85, 105, 0.8);
      }
      html.dark .text-gray-900,
      html.dark .text-gray-800,
      html.dark .text-slate-700,
      html.dark .text-slate-600 {
        color: #e2e8f0;
      }
      html.dark .text-gray-700,
      html.dark .text-gray-600,
      html.dark .text-gray-500,
      html.dark .text-gray-400,
      html.dark .text-slate-500 {
        color: #94a3b8;
      }
      html.dark input,
      html.dark select,
      html.dark textarea {
        background-color: #020617;
        border-color: #334155;
        color: #e2e8f0;
      }
      html.dark .shadow-sm,
      html.dark .shadow-lg,
      html.dark .shadow-xl,
      html.dark .shadow-2xl {
        box-shadow: none;
      }
      /* Light-tinted *-50 backgrounds don't auto-adapt — convert to subtle dark tints */
      html.dark .bg-hydra-50   { background-color: rgba(20, 184, 166, 0.10); }
      html.dark .bg-sky-50     { background-color: rgba(14, 165, 233, 0.10); }
      html.dark .bg-orange-50  { background-color: rgba(249, 115,  22, 0.10); }
      html.dark .bg-indigo-50  { background-color: rgba(99,  102, 241, 0.10); }
      html.dark .bg-violet-50  { background-color: rgba(139,  92, 246, 0.10); }
      html.dark .bg-purple-50  { background-color: rgba(168,  85, 247, 0.10); }
      html.dark .bg-teal-50    { background-color: rgba(20,  184, 166, 0.10); }
      html.dark .bg-cyan-50    { background-color: rgba(6,   182, 212, 0.10); }
      html.dark .bg-emerald-50 { background-color: rgba(52,  211, 153, 0.10); }
      html.dark .bg-rose-50    { background-color: rgba(251, 113, 133, 0.10); }
      html.dark .bg-red-50     { background-color: rgba(239,  68,  68, 0.10); }
      html.dark .bg-amber-50   { background-color: rgba(251, 191,  36, 0.10); }
      html.dark .bg-yellow-50  { background-color: rgba(253, 224,  71, 0.10); }
      html.dark .bg-blue-50    { background-color: rgba(59,  130, 246, 0.10); }
      html.dark .bg-fuchsia-50 { background-color: rgba(232,  121, 249, 0.10); }
      /* Border counterparts */
      html.dark .border-hydra-100  { border-color: rgba(20,  184, 166, 0.25); }
      html.dark .border-sky-100    { border-color: rgba(14,  165, 233, 0.25); }
      html.dark .border-orange-100 { border-color: rgba(249, 115,  22, 0.25); }
      html.dark .border-indigo-100 { border-color: rgba(99,  102, 241, 0.25); }
      html.dark .border-violet-100 { border-color: rgba(139,  92, 246, 0.25); }
      html.dark .border-purple-100 { border-color: rgba(168,  85, 247, 0.25); }
      html.dark .border-teal-100   { border-color: rgba(20,  184, 166, 0.25); }
      html.dark .border-red-100,
      html.dark .border-red-200    { border-color: rgba(239,  68,  68, 0.30); }
      /* Coloured text inside these panels needs to lighten in dark mode */
      html.dark .text-sky-900,
      html.dark .text-sky-800    { color: #7dd3fc; }
      html.dark .text-sky-700    { color: #38bdf8; }
      html.dark .text-orange-900,
      html.dark .text-orange-800 { color: #fdba74; }
      html.dark .text-orange-700 { color: #fb923c; }
      html.dark .text-indigo-800 { color: #a5b4fc; }
      html.dark .text-violet-800 { color: #c4b5fd; }
      html.dark .text-purple-800 { color: #d8b4fe; }
      html.dark .text-teal-800   { color: #5eead4; }
      html.dark .text-cyan-800   { color: #67e8f9; }
      html.dark .text-emerald-700 { color: #6ee7b7; }
      html.dark .text-rose-800   { color: #fda4af; }
      html.dark .text-amber-800  { color: #fcd34d; }
      html.dark .text-blue-800   { color: #93c5fd; }
      html.dark .text-fuchsia-800 { color: #f0abfc; }
      html.dark .text-red-700    { color: #fca5a5; }
    </style>
  </body>
</html>
