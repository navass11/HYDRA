FROM node:20-slim AS builder

WORKDIR /web
COPY web/package*.json ./
RUN npm ci
COPY web/ .

# Copy notebooks so build_notebooks.py can scan them
COPY notebooks/ notebooks/

# python3 (stdlib only) generates notebooks.json with JupyterLab URLs
RUN apt-get update && apt-get install -y --no-install-recommends python3 \
    && rm -rf /var/lib/apt/lists/*

ENV DEPLOY_TARGET=docker
ARG PUBLIC_API_URL=""
ENV PUBLIC_API_URL=${PUBLIC_API_URL}
RUN python3 scripts/build_notebooks.py

RUN npx astro build

# ── Production: nginx serves static files ────────────────────────────────────
FROM nginx:alpine
COPY --from=builder /web/dist /usr/share/nginx/html
COPY docker/nginx.conf.template /etc/nginx/templates/default.conf.template
