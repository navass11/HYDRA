# HYDRA Docker runtime configuration
#
# Optional. Point this to a host-mounted Azure Files share when notebooks,
# model inputs and outputs should live in shared storage.
#
# Examples:
# HYDRA_DATA_PATH=/Volumes/hydra-share/data
# HYDRA_DATA_PATH=/mnt/hydra-share/data
#
# If unset, Docker Compose uses the repository-local ./data directory.
HYDRA_DATA_PATH=../data
