# Model data: exclude large/generated by default; track small input project files
# Note: 'data/*' (not 'data/') allows parent dir to be traversed for negative patterns
data/*
!data/README.md
!data/setup.py

# HMS: track Tifton input files (later rules override earlier ones)
!data/hms/
data/hms/*
!data/hms/Tifton/
!data/hms/Tifton/**
data/hms/Tifton/*.dss
data/hms/Tifton/*.log
data/hms/Tifton/*.out
data/hms/Tifton/Outputs/*
!data/hms/Tifton/Outputs/*.csv
data/hms/Tifton/scripts/
data/hms/HEC-HMS-4.13/
data/hms/*.tar.gz

# HEC-RAS: track Muncie project stub
!data/hec_ras/
data/hec_ras/*
!data/hec_ras/Muncie/
!data/hec_ras/Muncie/**
data/hec_ras/*.exe

# GIS (small reference data)
!data/gis/
!data/gis/**

# SFINCS and SWAT: generated at runtime, not tracked
data/sfincs/
data/swat/
*.pyc
